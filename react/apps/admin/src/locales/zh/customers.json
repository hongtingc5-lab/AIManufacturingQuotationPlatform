  "mainHtml": "<div class=\"mb-6\">\n<nav class=\"flex text-label-sm font-label-sm text-on-surface-variant mb-2\">\n<ol class=\"flex items-center space-x-2\">\n<li><a class=\"hover:text-primary transition-colors\" href=\"/\">首页</a></li>\n<li><span class=\"material-symbols-outlined text-[14px]\">chevron_right</span></li>\n<li class=\"text-on-surface font-semibold\">客户管理</li>\n</ol>\n</nav>\n<div class=\"flex flex-col xl:flex-row xl:items-end xl:justify-between gap-4\">\n<div>\n<h1 class=\"text-display-lg font-display-lg text-on-surface m-0\">客户管理</h1>\n<p class=\"text-body-md font-body-md text-on-surface-variant mt-1\">统一查看客户画像、B2B 企业账号、地址簿与成交健康度，作为客户运营的首页入口。</p>\n</div>\n<div class=\"flex flex-wrap gap-3\">\n<a class=\"h-10 px-4 bg-surface-container-lowest border border-outline-variant rounded-lg text-title-sm font-title-sm text-on-surface flex items-center gap-2 hover:bg-surface-container transition-colors shadow-sm\" href=\"/customers/enterprise\"><span class=\"material-symbols-outlined text-[18px]\">groups</span>查看企业用户</a>\n<button class=\"h-10 px-4 bg-primary text-on-primary rounded-lg text-title-sm font-title-sm flex items-center gap-2 hover:bg-primary-container hover:text-on-primary-container transition-colors shadow-sm\"><span class=\"material-symbols-outlined text-[18px]\">person_add</span>新建客户档案</button>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8\">\n<div class=\"bg-surface-container-lowest rounded-xl p-5 border border-outline-variant/50 shadow-[0_1px_3px_0_rgba(0,0,0,0.1),0_1px_2px_-1px_rgba(0,0,0,0.1)]\"><div class=\"flex items-start justify-between mb-4\"><div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center text-primary\"><span class=\"material-symbols-outlined\">apartment</span></div><span class=\"inline-flex items-center text-label-sm font-label-sm text-tertiary-container bg-tertiary-fixed px-2 py-1 rounded-full\"><span class=\"material-symbols-outlined text-[12px] mr