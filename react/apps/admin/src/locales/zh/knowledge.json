  "mainHtml": "<div class=\"max-w-[1440px] mx-auto\">\n<header class=\"mb-8 flex justify-between items-end\">\n<div>\n<nav class=\"flex text-label-sm text-on-surface-variant mb-2\">\n<span>知识中心</span>\n<span class=\"mx-2\">/</span>\n<span class=\"text-primary font-medium\">平台总览</span>\n</nav>\n<h2 class=\"text-display-lg font-display-lg text-on-surface\">知识库管理中心</h2>\n</div>\n<div class=\"flex gap-3\">\n<button class=\"flex items-center gap-2 px-4 py-2 bg-surface-container-lowest border border-outline-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"history\">history</span>\n                            审计日志\n                        </button>\n<button class=\"flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:opacity-90 transition-opacity shadow-sm\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"add\">add</span>\n                            新增资源\n                        </button>\n</div>\n</header>\n<!-- Bento Grid Layout -->\n<div class=\"bento-grid\">\n<!-- Material Knowledge (Large List) -->\n<section class=\"col-span-8 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex justify-between items-center mb-6\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"inventory_2\">inventory_2</span>\n<h3 class=\"font-title-sm text-title-sm\">材料知识库</h3>\n</div>\n<button class=\"text-primary text-label-sm font-bold hover:underline\">查看全部材料</button>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left\">\n<thead class=\"bg-surface-container text-label-sm font-bold text-on-surface-variant uppercase tracking-wider\">\n<tr>\n<th class=\"px-4 py-3 first:rounded-l-lg\">材料编码</th>\n<th class=\"px-4 py-3\">密度 (g/cm³)</th>\n<th class=\"px-4 py-3\">硬度 (HB)</th>\n<th class=\"px-4 py-3\">典型应用</th>\n<th class=\"px-4 py-3 last:rounded-r-lg text-right\">操作</th>\n</tr>\n</thead>\n<tbody class=\"text-body-md divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Aluminum 6061-T6</td>\n<td class=\"px-4 py-4 font-mono-data\">2.70</td>\n<td class=\"px-4 py-4 font-mono-data\">95</td>\n<td class=\"px-4 py-4\">航空零件、船用配件</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Stainless Steel 316L</td>\n<td class=\"px-4 py-4 font-mono-data\">8.00</td>\n<td class=\"px-4 py-4 font-mono-data\">217</td>\n<td class=\"px-4 py-4\">化工容器、医疗植入件</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Titanium Gr5</td>\n<td class=\"px-4 py-4 font-mono-data\">4.43</td>\n<td class=\"px-4 py-4 font-mono-data\">340</td>\n<td class=\"px-4 py-4\">发动机部件、机体结构件</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">POM (Delrin)</td>\n<td class=\"px-4 py-4 font-mono-data\">1.41</td>\n<td class=\"px-4 py-4 font-mono-data\">120</td>\n<td class=\"px-4 py-4\">精密齿轮、衬套、轴承</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</section>\n<!-- 加工工艺 (Small Vertical) -->\n<section class=\"col-span-4 flex flex-col gap-6\">\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm flex-1\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"precision_manufacturing\">precision_manufacturing</span>\n<h3 class=\"font-title-sm text-title-sm\">加工工艺</h3>\n</div>\n<div class=\"space-y-3\">\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"hub\">hub</span>\n<span class=\"text-body-md font-medium\">三轴 CNC 铣削</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"cached\">cached</span>\n<span class=\"text-body-md font-medium\">CNC 车削（车床）</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"layers\">layers</span>\n<span class=\"text-body-md font-medium\">五轴联动加工</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"bolt\">bolt</span>\n<span class=\"text-body-md font-medium\">电火花加工</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n</div>\n</div>\n</section>\n<!-- CNC百科 (Medium Card) -->\n<section class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-tertiary\" data-icon=\"menu_book\">menu_book</span>\n<h3 class=\"font-title-sm text-title-sm\">CNC百科</h3>\n</div>\n<p class=\"text-body-md text-on-surface-variant mb-4\">集中整理标准 CNC 术语与最佳实践的操作指南。</p>\n<div class=\"flex flex-wrap gap-2 mb-6\">\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">G-Code</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">M-Code</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">刀具路径</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">进给与转速</span>\n</div>\n<button class=\"w-full py-2 border border-primary text-primary font-label-md text-label-md rounded-lg hover:bg-primary hover:text-on-primary transition-all\">浏览百科</button>\n</section>\n<!-- Drawing Specs & Tolerance (Medium Card) -->\n<section class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm overflow-hidden relative\">\n<div class=\"relative z-10\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"architecture\">architecture</span>\n<h3 class=\"font-title-sm text-title-sm\">图纸与公差</h3>\n</div>\n<ul class=\"space-y-4\">\n<li class=\"flex items-start gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[18px] mt-0.5\" data-icon=\"check_circle\">check_circle</span>\n<div>\n<p class=\"text-body-md font-bold\">ISO 2768-m</p>\n<p class=\"text-label-sm text-on-surface-variant\">线性与角度尺寸的一般公差标准。</p>\n</div>\n</li>\n<li class=\"flex items-start gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[18px] mt-0.5\" data-icon=\"check_circle\">check_circle</span>\n<div>\n<p class=\"text-body-md font-bold\">ASME Y14.5-2018</p>\n<p class=\"text-label-sm text-on-surface-variant\">几何尺寸与公差（GD&amp;T）标准。</p>\n</div>\n</li>\n</ul>\n<div class=\"mt-6\">\n<div class=\"bg-primary/5 rounded-lg p-3 border border-primary/20\">\n<p class=\"text-label-sm font-bold text-primary uppercase\">状态</p>\n<p class=\"text-body-md text-on-surface font-medium\">2 天前由质量部门更新</p>\n</div>\n</div>\n</div>\n<!-- Background Pattern -->\n<div class=\"absolute top-0 right-0 w-32 h-32 opacity-5 pointer-events-none transform translate-x-10 -translate-y-10\">\n<span class=\"material-symbols-outlined text-[120px]\" data-icon=\"straighten\">straighten</span>\n</div>\n</section>\n<!-- AI报价知识 (Medium Card) -->\n<section class=\"col-span-4 bg-primary text-on-primary rounded-xl p-6 shadow-lg\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined\" data-icon=\"auto_awesome\">auto_awesome</span>\n<h3 class=\"font-title-sm text-title-sm\">AI报价知识</h3>\n</div>\n<p class=\"text-body-md opacity-90 mb-6\">基于几何复杂度与批量的自动成本估算神经网络参数。</p>\n<div class=\"space-y-4 mb-6\">\n<div class=\"flex justify-between items-end border-b border-white/20 pb-2\">\n<span class=\"text-label-sm\">几何识别置信度</span>\n<span class=\"font-mono-data text-body-md font-bold\">98.2%</span>\n</div>\n<div class=\"flex justify-between items-end border-b border-white/20 pb-2\">\n<span class=\"text-label-sm\">市场价格同步</span>\n<span class=\"font-mono-data text-body-md font-bold\">实时</span>\n</div>\n</div>\n<button class=\"w-full py-2 bg-on-primary text-primary font-label-md text-label-md rounded-lg font-bold shadow-md hover:bg-primary-fixed transition-all\">配置AI模型</button>\n</section>\n<!-- SEO/GEO Articles (Column) -->\n<section class=\"col-span-6 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex justify-between items-center mb-6\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"article\">article</span>\n<h3 class=\"font-title-sm text-title-sm\">SEO与区域内容</h3>\n</div>\n<span class=\"px-2 py-0.5 bg-error-container text-on-error-container text-[10px] font-bold rounded uppercase\">3 条待处理</span>\n</div>\n<div class=\"space-y-4\">\n<div class=\"flex gap-4 items-center\">\n<div class=\"w-16 h-16 bg-surface-container rounded-lg flex-shrink-0\">\n<img class=\"w-full h-full object-cover rounded-lg\" data-alt=\"High-resolution industrial photography showing precision CNC machined metal parts with complex geometries, cinematic lighting, shallow depth of field.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBymcQa4gTSnstLJyEn4Em2Ouig-YrMPM2PTqnASlGAIsoD43sqkQsIbEXOCMkOnRw15PGdrAVZVqiyrprrP6ifRb3CxxLN5llEN6P2nvUlsnYa6MjPkzh-U4N17uMG12DyN-oePIq_wN3d-ZW1GvnuEqPnZhdAhyvTx0iwoG_I2LGRnenoIp58UGbgG1HLRw2HTXW3l5hTW01E-DuhL93unhIaSqS8OiRcoyPn4OprkamDJl0Pq0k7WAmeUT83t9hs2Mo2mW2zGoo\"/>\n</div>\n<div class=\"flex-1\">\n<h4 class=\"text-body-md font-bold hover:text-primary cursor-pointer\">2024 铝件 CNC 加工最佳实践</h4>\n<p class=\"text-label-sm text-on-surface-variant line-clamp-1\">关键词：CNC铝件、6061-T6加工、工业生产...</p>\n</div>\n<div class=\"flex flex-col items-end\">\n<span class=\"text-label-sm text-on-surface-variant\">已发布</span>\n<div class=\"flex gap-1 mt-1\">\n<button class=\"material-symbols-outlined text-[16px] text-on-surface-variant\" data-icon=\"edit\">edit</button>\n<button class=\"material-symbols-outlined text-[16px] text-on-surface-variant\" data-icon=\"public\">public</button>\n</div>\n</div>\n</div>\n<div class=\"flex gap-4 items-center opacity-60\">\n<div class=\"w-16 h-16 bg-surface-container rounded-lg flex-shrink-0\">\n<img class=\"w-full h-full object-cover rounded-lg\" data-alt=\"Close up view of stainless steel medical surgical instruments, clinical laboratory setting, clean minimal aesthetic, professional lighting.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCYPEj18w1hNEJHgK_KQK4t_teOR1bd5gMBub6iVQZkvt8pW0ELeK8ETr1OCYREXEuDaFcV--IJ2v9wVnLEvxjVWp58VATqHkOv0_uEg6pshnR-esfql08RLda_apN483jiS93smfLtMXO9tSlBtBExPKYDvzTOWe5KyBISnC4r0GT2j0PLEInJCkaDa6fESRrlX-Xq0zw-5_eUKkPhnaJ7UP8NdDAWQ9UJc6uIQolJJ3yaoQY42Lx9dm3lU97IWYNgt1S1h9nrd0c\"/>\n</div>\n<div class=\"flex-1\">\n<h4 class=\"text-body-md font-bold\">欧洲市场医用级不锈钢标准</h4>\n<p class=\"text-label-sm text-on-surface-variant line-clamp-1\">关键词：ISO 13485、316L 不锈钢、欧盟医疗器械法规...</p>\n</div>\n<div class=\"flex flex-col items-end\">\n<span class=\"text-label-sm text-error font-bold\">草稿</span>\n<div class=\"flex gap-1 mt-1\">\n<button class=\"material-symbols-outlined text-[16px] text-on-surface-variant\" data-icon=\"edit\">edit</button>\n<button class=\"material-symbols-outlined text-[16px] text-on-surface-variant\" data-icon=\"visibility\">visibility</button>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Content Audit & FAQ (Column) -->\n<section class=\"col-span-6 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex items-center gap-3 mb-6\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"fact_check\">fact_check</span>\n<h3 class=\"font-title-sm text-title-sm\">FAQ与内容审核</h3>\n</div>\n<div class=\"grid grid-cols-2 gap-4 mb-6\">\n<div class=\"p-4 rounded-xl bg-surface-container border border-outline-variant\">\n<p class=\"text-label-sm text-on-surface-variant uppercase font-bold mb-1\">FAQ总数</p>\n<p class=\"text-headline-md font-bold\">142</p>\n<div class=\"mt-2 flex items-center gap-1 text-success text-[10px] text-primary\">\n<span class=\"material-symbols-outlined text-[12px]\" data-icon=\"trending_up\">trending_up</span>\n                                    本月 +12\n                                </div>\n</div>\n<div class=\"p-4 rounded-xl bg-surface-container border border-outline-variant\">\n<p class=\"text-label-sm text-on-surface-variant uppercase font-bold mb-1\">待审核</p>\n<p class=\"text-headline-md font-bold text-tertiary\">08</p>\n<div class=\"mt-2 flex items-center gap-1 text-[10px] text-on-surface-variant\">\n<span class=\"material-symbols-outlined text-[12px]\" data-icon=\"schedule\">schedule</span>\n                                    平均 4 小时响应\n                                </div>\n</div>\n</div>\n<div class=\"space-y-3\">\n<div class=\"flex items-center justify-between p-3 bg-surface-container-low rounded-lg\">\n<span class=\"text-body-md font-medium\">如何计算 CNC 交付周期？</span>\n<button class=\"px-3 py-1 bg-primary text-on-primary text-label-sm rounded-lg\">审核</button>\n</div>\n<div class=\"flex items-center justify-between p-3 bg-surface-container-low rounded-lg\">\n<span class=\"text-body-md font-medium\">航空航天材料认证有哪些？</span>\n<button class=\"px-3 py-1 bg-primary text-on-primary text-label-sm rounded-lg\">审核</button>\n</div>\n</div>\n</section>\n</div>\n</div>"
