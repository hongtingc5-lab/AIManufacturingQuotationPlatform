  "mainHtml": "<div class=\"max-w-[1440px] mx-auto\">\n<header class=\"mb-8 flex justify-between items-end\">\n<div>\n<nav class=\"flex text-label-sm text-on-surface-variant mb-2\">\n<span>Knowledge Center</span>\n<span class=\"mx-2\">/</span>\n<span class=\"text-primary font-medium\">Dashboard</span>\n</nav>\n<h2 class=\"text-display-lg font-display-lg text-on-surface\">Knowledge Management Center</h2>\n</div>\n<div class=\"flex gap-3\">\n<button class=\"flex items-center gap-2 px-4 py-2 bg-surface-container-lowest border border-outline-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"history\">history</span>\n                            Audit Log\n                        </button>\n<button class=\"flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:opacity-90 transition-opacity shadow-sm\">\n<span class=\"material-symbols-outlined text-[18px]\" data-icon=\"add\">add</span>\n                            New Resource\n                        </button>\n</div>\n</header>\n<!-- Bento Grid Layout -->\n<div class=\"bento-grid\">\n<!-- Material Knowledge (Large List) -->\n<section class=\"col-span-8 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex justify-between items-center mb-6\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"inventory_2\">inventory_2</span>\n<h3 class=\"font-title-sm text-title-sm\">Material Knowledge Repository</h3>\n</div>\n<button class=\"text-primary text-label-sm font-bold hover:underline\">View All Materials</button>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left\">\n<thead class=\"bg-surface-container text-label-sm font-bold text-on-surface-variant uppercase tracking-wider\">\n<tr>\n<th class=\"px-4 py-3 first:rounded-l-lg\">Material Code</th>\n<th class=\"px-4 py-3\">Density (g/cm³)</th>\n<th class=\"px-4 py-3\">Hardness (HB)</th>\n<th class=\"px-4 py-3\">Typical Application</th>\n<th class=\"px-4 py-3 last:rounded-r-lg text-right\">Actions</th>\n</tr>\n</thead>\n<tbody class=\"text-body-md divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Aluminum 6061-T6</td>\n<td class=\"px-4 py-4 font-mono-data\">2.70</td>\n<td class=\"px-4 py-4 font-mono-data\">95</td>\n<td class=\"px-4 py-4\">Aerospace components, marine fittings</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Stainless Steel 316L</td>\n<td class=\"px-4 py-4 font-mono-data\">8.00</td>\n<td class=\"px-4 py-4 font-mono-data\">217</td>\n<td class=\"px-4 py-4\">Chemical containers, medical implants</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">Titanium Gr5</td>\n<td class=\"px-4 py-4 font-mono-data\">4.43</td>\n<td class=\"px-4 py-4 font-mono-data\">340</td>\n<td class=\"px-4 py-4\">Engine components, structural airframes</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-4 py-4 font-bold text-primary\">POM (Delrin)</td>\n<td class=\"px-4 py-4 font-mono-data\">1.41</td>\n<td class=\"px-4 py-4 font-mono-data\">120</td>\n<td class=\"px-4 py-4\">Precision gears, bushings, bearings</td>\n<td class=\"px-4 py-4 text-right\">\n<button class=\"material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors text-[20px]\" data-icon=\"edit\">edit</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</section>\n<!-- Processing Technology (Small Vertical) -->\n<section class=\"col-span-4 flex flex-col gap-6\">\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm flex-1\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"precision_manufacturing\">precision_manufacturing</span>\n<h3 class=\"font-title-sm text-title-sm\">Processing Technology</h3>\n</div>\n<div class=\"space-y-3\">\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"hub\">hub</span>\n<span class=\"text-body-md font-medium\">3-Axis CNC Milling</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"cached\">cached</span>\n<span class=\"text-body-md font-medium\">CNC Turning (Lathe)</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"layers\">layers</span>\n<span class=\"text-body-md font-medium\">5-Axis Simultaneous</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n<div class=\"p-3 bg-surface-container rounded-lg border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary transition-all\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-[20px]\" data-icon=\"bolt\">bolt</span>\n<span class=\"text-body-md font-medium\">EDM Machining</span>\n</div>\n<span class=\"material-symbols-outlined text-[18px] opacity-0 group-hover:opacity-100 transition-opacity\" data-icon=\"chevron_right\">chevron_right</span>\n</div>\n</div>\n</div>\n</section>\n<!-- CNC Encyclopedia (Medium Card) -->\n<section class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-tertiary\" data-icon=\"menu_book\">menu_book</span>\n<h3 class=\"font-title-sm text-title-sm\">CNC Encyclopedia</h3>\n</div>\n<p class=\"text-body-md text-on-surface-variant mb-4\">Centralized glossary and operational guidelines for standard CNC terminology and best practices.</p>\n<div class=\"flex flex-wrap gap-2 mb-6\">\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">G-Code</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">M-Code</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">Tool Path</span>\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded\">Feeds &amp; Speeds</span>\n</div>\n<button class=\"w-full py-2 border border-primary text-primary font-label-md text-label-md rounded-lg hover:bg-primary hover:text-on-primary transition-all\">Browse Encyclopedia</button>\n</section>\n<!-- Drawing Specs & Tolerance (Medium Card) -->\n<section class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm overflow-hidden relative\">\n<div class=\"relative z-10\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"architecture\">architecture</span>\n<h3 class=\"font-title-sm text-title-sm\">Drawing &amp; Tolerance</h3>\n</div>\n<ul class=\"space-y-4\">\n<li class=\"flex items-start gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[18px] mt-0.5\" data-icon=\"check_circle\">check_circle</span>\n<div>\n<p class=\"text-body-md font-bold\">ISO 2768-m</p>\n<p class=\"text-label-sm text-on-surface-variant\">General tolerances for linear and angular dimensions.</p>\n</div>\n</li>\n<li class=\"flex items-start gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[18px] mt-0.5\" data-icon=\"check_circle\">check_circle</span>\n<div>\n<p class=\"text-body-md font-bold\">ASME Y14.5-2018</p>\n<p class=\"text-label-sm text-on-surface-variant\">Geometric Dimensioning and Tolerancing (GD&amp;T) standards.</p>\n</div>\n</li>\n</ul>\n<div class=\"mt-6\">\n<div class=\"bg-primary/5 rounded-lg p-3 border border-primary/20\">\n<p class=\"text-label-sm font-bold text-primary uppercase\">Status</p>\n<p class=\"text-body-md text-on-surface font-medium\">Updated 2 days ago by Quality Dept.</p>\n</div>\n</div>\n</div>\n<!-- Background Pattern -->\n<div class=\"absolute top-0 right-0 w-32 h-32 opacity-5 pointer-events-none transform translate-x-10 -translate-y-10\">\n<span class=\"material-symbols-outlined text-[120px]\" data-icon=\"straighten\">straighten</span>\n</div>\n</section>\n<!-- AI Quoting Knowledge (Medium Card) -->\n<section class=\"col-span-4 bg-primary text-on-primary rounded-xl p-6 shadow-lg\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined\" data-icon=\"auto_awesome\">auto_awesome</span>\n<h3 class=\"font-title-sm text-title-sm\">AI Quoting Knowledge</h3>\n</div>\n<p class=\"text-body-md opacity-90 mb-6\">Neural network parameters for automated cost estimation based on geometry complexity and volume.</p>\n<div class=\"space-y-4 mb-6\">\n<div class=\"flex justify-between items-end border-b border-white/20 pb-2\">\n<span class=\"text-label-sm\">Geometry Confidence</span>\n<span class=\"font-mono-data text-body-md font-bold\">98.2%</span>\n</div>\n<div class=\"flex justify-between items-end border-b border-white/20 pb-2\">\n<span class=\"text-label-sm\">Market Price Sync</span>\n<span class=\"font-mono-data text-body-md font-bold\">Live</span>\n</div>\n</div>\n<button class=\"w-full py-2 bg-on-primary text-primary font-label-md text-label-md rounded-lg font-bold shadow-md hover:bg-primary-fixed transition-all\">Configure AI Model</button>\n</section>\n<!-- SEO/GEO Articles (Column) -->\n<section class=\"col-span-6 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm\">\n<div class=\"flex justify-between items-center mb-6\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"article\">article</span>\n<h3 class=\"font-title-sm text-title-sm\">SEO &amp; Regional Content</h3>\n</div>\n<span class=\"px-2 py-0.5 bg-error-container text-on-error-container text-[10px] font-bold rounded uppercase\">3 Pending</span>\n</div>\n<div class=\"space-y-4\">\n<div class=\"flex gap-4 items-center\">\n<div class=\"w-16 h-16 bg-surface-container rounded-lg flex-shrink-0\">\n<img class=\"w-full h-full object-cover rounded-lg\" data-alt=\"High-resolution industrial photography showin