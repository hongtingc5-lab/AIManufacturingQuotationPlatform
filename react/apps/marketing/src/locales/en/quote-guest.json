  "mainHtml": "\n<section class=\"guest-quote-hero is-upload-layout\" id=\"quote-upload\">\n<div class=\"container guest-entry-bar\">\n<div aria-label=\"Solution entry\" class=\"guest-mode-switch\">\n<button class=\"guest-mode-option is-active\" data-mode-option=\"quickQuote\" type=\"button\">Instant Quote</button>\n<button class=\"guest-mode-option\" data-mode-option=\"smartQuote\" type=\"button\">Smart Quote</button>\n<button class=\"guest-mode-option\" data-mode-option=\"rapidPrototype\" type=\"button\">Rapid Prototype</button>\n<button class=\"guest-mode-option\" data-mode-option=\"dfm\" type=\"button\">DFM Check</button>\n<button class=\"guest-mode-option\" data-mode-option=\"imageTo3d\" type=\"button\">Image to 3D</button>\n<button class=\"guest-mode-option\" data-mode-option=\"textTo3d\" type=\"button\">Text to 3D</button>\n<button class=\"guest-mode-option\" data-mode-option=\"formatConvert\" type=\"button\">3D Format Convert</button>\n<button class=\"guest-mode-option\" data-mode-option=\"threeToTwo\" type=\"button\">3D to 2D Drawing</button>\n<button class=\"guest-mode-option\" data-mode-option=\"bubble\" type=\"button\">2D Balloon Markup</button>\n</div>\n</div>\n<div class=\"container guest-quote-layout\">\n<div class=\"guest-quote-copy\">\n<span class=\"template-kicker\" data-mode-kicker=\"\">INSTANT QUOTE</span>\n<h1 data-mode-title=\"\">Upload a model for a fast manufacturing quote</h1>\n<p data-mode-description=\"\">After you submit a 3D model, 2D drawing, or PDF package, we evaluate materials, process, quantity, lead time, and finishing so you can judge cost and manufacturing path faster.</p>\n<div aria-label=\"Quote entry benefits\" class=\"guest-quote-points\">\n<span data-mode-point=\"0\">Multi-format upload</span>\n<span data-mode-point=\"1\">Initial DFM review</span>\n<span data-mode-point=\"2\">Manual quote available</span>\n</div>\n</div>\n<div class=\"guest-upload-card is-upload-mode\" id=\"guest-panel\">\n<div class=\"guest-upload-head\">\n<div>\n<h2 data-card-title=\"\">Upload quote files</h2>\n<p data-card-description=\"\">Submit a single part or multiple engineering files — models and drawings together.</p>\n</div>\n<span class=\"guest-upload-badge\" data-card-badge=\"\">Instant QuoteEntry</span>\n</div>\n<div class=\"guest-drop-zone\" id=\"drop-zone\">\n<div>\n<div aria-hidden=\"true\" class=\"guest-upload-icon\">\n<svg fill=\"none\" role=\"img\" viewbox=\"0 0 24 24\">\n<path d=\"M12 15V4m0 0 4 4m-4-4-4 4\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.8\"></path>\n<path d=\"M5 14v3.5A2.5 2.5 0 0 0 7.5 20h9a2.5 2.5 0 0 0 2.5-2.5V14\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-width=\"1.8\"></path>\n</svg>\n</div>\n<h3 data-drop-title=\"\">Drag files here, or click to browse</h3>\n<p data-drop-detail=\"\">Supports .STEP, .STP, .STL, .IGES, .OBJ, .DWG, .DXF, .PDF. Prefer under 100MB per file.</p>\n<button class=\"guest-file-button\" data-file-button=\"\" type=\"button\">Browse files</button>\n<input accept=\".step,.stp,.stl,.iges,.igs,.obj,.dwg,.dxf,.pdf\" hidden=\"\" id=\"file-input\" multiple=\"\" type=\"file\"/>\n</div>\n</div>\n<div class=\"guest-lite-chat\">\n<div class=\"guest-chat-quota\">\n<div>\n<strong>Guest chat</strong>\n<span data-quota-copy=\"\">3 light guest chats remaining</span>\n</div>\n<span class=\"guest-quota-pill\" data-quota-pill=\"\">0 / 3</span>\n</div>\n<div class=\"guest-chat-board\" data-chat-board=\"\">\n<div class=\"guest-chat-bubble\" data-chat-welcome=\"\">Describe the part, image, or model goal first — I'll help route you to the right workspace.</div>\n</div>\n<div class=\"guest-chat-message\" data-chat-answer=\"\"><strong>AgileMakeAI：</strong>Upload files first, or add materials, quantity, lead time, or application in one sentence.</div>\n<div class=\"guest-composer\">\n<button aria-label=\"Upload attachment\" class=\"guest-icon-action\" id=\"chat-upload-trigger\" type=\"button\">\n<svg aria-hidden=\"true\" fill=\"none\" viewbox=\"0 0 24 24\">\n<path d=\"M12 5v14M5 12h14\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-width=\"1.9\"></path>\n</svg>\n</button>\n<textarea class=\"guest-need-input\" id=\"guest-need-input\" maxlength=\"240\" placeholder=\"Describe needs, material, quantity, lead time, or model goals...\"></textarea>\n<button aria-label=\"Send\" class=\"guest-primary-action guest-send-action\" id=\"send-guest-message\" type=\"button\">\n<svg aria-hidden=\"true\" fill=\"none\" viewbox=\"0 0 24 24\">\n<path d=\"M5 12h13m0 0-5-5m5 5-5 5\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"></path>\n</svg>\n</button>\n</div>\n<div class=\"guest-chat-actions\">\n<div class=\"guest-quick-chips\">\n<button class=\"guest-quick-chip\" data-quick-chip=\"Material: Aluminum 6061-T6; Qty: 50; Lead time: 10 days.\" type=\"button\">Quote params</button>\n<button class=\"guest-quick-chip\" data-quick-chip=\"Please check manufacturability and flag machining risks first.\" type=\"button\">DFM risks</button>\n<button class=\"guest-quick-chip\" data-quick-chip=\"I want a 3D model direction that can be evaluated further.\" type=\"button\">Model gen</button>\n</div>\n<button class=\"guest-primary-action\" id=\"continue-workbench\" type=\"button\">Open workspace</button>\n</div>\n</div>\n<div aria-live=\"polite\" class=\"guest-status hidden\" id=\"status-area\">\n<div>\n<strong data-status-title=\"\">Files received</strong>\n<span data-status-detail=\"\">Next, add material, quantity, and lead-time details for quoting.</span>\n</div>\n<span data-status-percent=\"\">Saved</span>\n</div>\n<div aria-label=\"Quote options\" class=\"quote-choice-strip\">\n<div class=\"quote-choice-copy\">\n<span aria-hidden=\"true\" class=\"quote-choice-icon\">\n<svg fill=\"none\" viewbox=\"0 0 24 24\">\n<path d=\"M12 3 5 6v5c0 4.5 2.8 8.1 7 10 4.2-1.9 7-5.5 7-10V6l-7-3Z\" stroke=\"currentColor\" stroke-linejoin=\"round\" stroke-width=\"1.7\"></path>\n<path d=\"m9 12 2 2 4-5\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.7\"></path>\n</svg>\n</span>\n<span data-choice-copy=\"\">Engineering files are used for quote evaluation only. For complex, volume, or no-model cases, request a manual RFQ.</span>\n</div>\n<div class=\"quote-choice-actions\">\n<a data-choice-primary=\"\" href=\"/solutions/instant-quoting\">View samples</a>\n<a data-choice-secondary=\"\" href=\"/about#contact\">Manual quote / RFQ</a>\n</div>\n</div>\n</div>\n</div>\n</section>\n<section aria-label=\"Quote workflow\" class=\"container quote-workflow-section\">\n<div class=\"quote-workflow-head\">\n<h2 data-workflow-title=\"\">How quoting works</h2>\n<p data-workflow-description=\"\">Before you submit files, here is the path from upload to quote confirmation so you can prepare materials, quantity, lead time, and quality needs.</p>\n</div>\n<div class=\"quote-workflow-track\">\n<article class=\"quote-workflow-step\"><b>01</b><h3 data-workflow-step-title=\"0\">Upload part data</h3><p data-workflow-step-copy=\"0\">Submit 3D models, 2D drawings, PDF notes, or key machining requirements.</p></article>\n<article class=\"quote-workflow-step\"><b>02</b><h3 data-workflow-step-title=\"1\">Add detailsQuote params</h3><p data-workflow-step-copy=\"1\">Confirm material, quantity, finishing, critical tolerances, and target lead time.</p></article>\n<article class=\"quote-workflow-step\"><b>03</b><h3 data-workflow-step-title=\"2\">Engineering quote</h3><p data-workflow-step-copy=\"2\">Run DFM checks, process path judgment, cost breakdown, and risk notes.</p></article>\n<article class=\"quote-workflow-step\"><b>04</b><h3 data-workflow-step-title=\"3\">Confirm & deliver</h3><p data-workflow-step-copy=\"3\">After quote confirmation, move into scheduling, QC tracking, and delivery.</p></article>\n</div>\n</section>\n"
}
