center gap-md\">\n<span class=\"material-symbols-outlined text-tertiary text-[32px]\">history</span>\n<div>\n<p class=\"font-label-md text-label-md font-bold\">最近审计</p>\n<p class=\"font-body-sm text-body-sm text-on-surface-variant\">14 天前完成</p>\n</div>\n</div>\n</div>\n</section>\n</div>\n<!-- Right Column: Status & Visuals -->\n<div class=\"col-span-4 space-y-lg\">\n<!-- Verification Status Card -->\n<section class=\"bg-primary-container text-on-primary-container rounded-xl p-lg shadow-lg relative overflow-hidden\">\n<div class=\"relative z-10\">\n<h3 class=\"font-headline-sm text-headline-sm mb-sm\">一级供应商</h3>\n<p class=\"font-body-sm text-body-sm opacity-90 mb-lg\">您的企业已获得平台最高信任评级。</p>\n<div class=\"space-y-md\">\n<div class=\"flex justify-between items-center text-label-sm font-label-sm\">\n<span>资料完整度</span>\n<span>95%</span>\n</div>\n<div class=\"w-full bg-on-primary-container/20 h-2 rounded-full overflow-hidden\">\n<div class=\"bg-on-primary-container h-full w-[95%]\"></div>\n</div>\n</div>\n</div>\n<!-- Subtle Background Pattern -->\n<div class=\"absolute -bottom-4 -right-4 opacity-10\">\n<span class=\"material-symbols-outlined text-[160px]\">verified_user</span>\n</div>\n</section>\n<!-- Industry Classification -->\n<section class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm\">\n<h3 class=\"font-label-md text-label-md font-bold mb-md\">行业聚焦</h3>\n<div class=\"flex flex-wrap gap-sm\">\n<span class=\"px-md py-sm bg-surface-container-high rounded-lg font-label-sm text-label-sm\">精密加工</span>\n<span class=\"px-md py-sm bg-surface-container-high rounded-lg font-label-sm text-label-sm\">航空航天合金</span>\n<span class=\"px-md py-sm bg-surface-container-high rounded-lg font-label-sm text-label-sm\">物联网传感器</span>\n<span class=\"px-md py-sm bg-surface-container-high rounded-lg font-label-sm text-label-sm\">智能制造</span>\n</div>\n</section>\n<!-- Corporate Identity Image -->\n<div class=\"rounded-xl overflow-hidden h-64 border border-