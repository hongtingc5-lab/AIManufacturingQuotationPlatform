  "mainHtml": "<div class=\"max-w-[1400px] mx-auto space-y-lg\">\n<!-- Dashboard Header Section -->\n<div class=\"grid grid-cols-12 gap-lg\">\n<!-- 综合评分 Card -->\n<div class=\"col-span-12 lg:col-span-4 bg-surface-container-low border border-outline-variant rounded-xl p-xl flex flex-col items-center justify-center relative overflow-hidden\">\n<div class=\"absolute top-0 right-0 p-4 opacity-10\">\n<span class=\"material-symbols-outlined text-primary text-[120px]\">analytics</span>\n</div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface mb-8 self-start\">综合评分</h3>\n<div class=\"gauge-container mb-4\">\n<div class=\"gauge-body\">\n<div class=\"gauge-fill\"></div>\n<div class=\"gauge-cover\">\n<span class=\"text-[48px] font-bold text-primary leading-none\">94</span>\n<span class=\"text-label-md text-outline\">优秀状态</span>\n</div>\n</div>\n</div>\n<p class=\"text-body-sm text-on-surface-variant text-center px-4\">\n                        您本季度的表现位列电子类供应商前 <span class=\"text-primary font-bold\">3%</span> 电子类供应商。\n                    </p>\n</div>\n<!-- Secondary KPI Grid -->\n<div class=\"col-span-12 lg:col-span-8 grid grid-cols-2 md:grid-cols-4 gap-lg\">\n<!-- KPI 1 -->\n<div class=\"bg-white p-lg rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between\">\n<div>\n<div class=\"w-10 h-10 bg-primary-fixed rounded-lg flex items-center justify-center text-primary mb-4\">\n<span class=\"material-symbols-outlined\">check_circle</span>\n</div>\n<p class=\"text-label-md text-outline\">接单率</p>\n</div>\n<div class=\"mt-4\">\n<h4 class=\"text-headline-md font-bold text-on-surface\">98.2%</h4>\n<div class=\"flex items-center gap-1 text-tertiary text-label-sm mt-1\">\n<span class=\"material-symbols-outlined text-[14px]\">trending_up</span>\n<span>较上月 +1.4%</span>\n</div>\n</div>\n</div>\n<!-- KPI 2 -->\n<div class=\"bg-white p-lg rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between\">\n<div>\n<div class=\"w-10 h-10 bg-secondary-fixed rounded-lg flex items-center justify-center text-secondary mb-4\">\n<span class=\"material-symbols-outlined\">schedule</span>\n</div>\n<p class=\"text-label-md text-outline\">准时交付率</p>\n</div>\n<div class=\"mt-4\">\n<h4 class=\"text-headline-md font-bold text-on-surface\">96.5%</h4>\n<div class=\"flex items-center gap-1 text-tertiary text-label-sm mt-1\">\n<span class=\"material-symbols-outlined text-[14px]\">trending_up</span>\n<span>较上月 +0.8%</span>\n</div>\n</div>\n</div>\n<!-- KPI 3 -->\n<div class=\"bg-white p-lg rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between\">\n<div>\n<div class=\"w-10 h-10 bg-tertiary-fixed rounded-lg flex items-center justify-center text-tertiary mb-4\">\n<span class=\"material-symbols-outlined\">verified</span>\n</div>\n<p class=\"text-label-md text-outline\">合格率</p>\n</div>\n<div class=\"mt-4\">\n<h4 class=\"text-headline-md font-bold text-on-surface\">99.1%</h4>\n<div class=\"flex items-center gap-1 text-error text-label-sm mt-1\">\n<span class=\"material-symbols-outlined text-[14px]\">trending_down</span>\n<span>较上月 -0.2%</span>\n</div>\n</div>\n</div>\n<!-- KPI 4 -->\n<div class=\"bg-white p-lg rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between\">\n<div>\n<div class=\"w-10 h-10 bg-surface-container-highest rounded-lg flex items-center justify-center text-on-surface-variant mb-4\">\n<span class=\"material-symbols-outlined\">star</span>\n</div>\n<p class=\"text-label-md text-outline\">客户评分</p>\n</div>\n<div class=\"mt-4\">\n<h4 class=\"text-headline-md font-bold text-on-surface\">4.9/5.0</h4>\n<div class=\"flex items-center gap-1 text-tertiary text-label-sm mt-1\">\n<span class=\"material-symbols-outlined text-[14px]\">trending_up</span>\n<span>稳定</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Detailed Analysis and Progress -->\n<div class=\"grid grid-cols-12 gap-lg\">\n<!-- Long-term Cooperation Status -->\n<div class=\"col-span-12 lg:col-span-7 bg-white rounded-xl border border-outline-variant p-lg shadow-sm\">\n<div class=\"flex justify-between items-center mb-6\">\n<h3 class=\"text-headline-sm font-headline-sm\">长期合作资质</h3>\n<span class=\"px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-label-sm font-bold uppercase tracking-wider\">黄金等级</span>\n</div>\n<div class=\"relative bg-surface-container-low rounded-xl p-xl mb-6 overflow-hidden\">\n<!-- Abstract Background Decoration -->\n<div class=\"absolute inset-0 opacity-5 pointer-events-none\">\n</div>\n<div class=\"flex justify-between items-center mb-4\">\n<span class=\"text-label-md font-bold text-on-surface\">晋升钻石供应商进度</span>\n<span class=\"text-label-md font-bold text-primary\">已完成 85%</span>\n</div>\n<div class=\"w-full bg-outline-variant h-3 rounded-full overflow-hidden mb-6\">\n<div class=\"bg-primary h-full rounded-full transition-all duration-1000 ease-out\" style=\"width: 85%\"></div>\n</div>\n<div class=\"grid grid-cols-3 gap-md\">\n<div class=\"text-center\">\n<p class=\"text-label-sm text-outline mb-1\">订单总量</p>\n<p class=\"text-body-lg font-bold\">1,248 / 1,500</p>\n</div>\n<div class=\"text-center border-x border-outline-variant\">\n<p class=\"text-label-sm text-outline mb-1\">合作时长</p>\n<p class=\"text-body-lg font-bold\">2.4 / 3.0 年</p>\n</div>\n<div class=\"text-center\">\n<p class=\"text-label-sm text-outline mb-1\">质量事故</p>\n<p class=\"text-body-lg font-bold text-green-600\">0 / 2 上限</p>\n</div>\n</div>\n</div>\n<div class=\"space-y-4\">\n<div class=\"flex items-start gap-4 p-4 border border-outline-variant rounded-lg bg-surface-container-low/50\">\n<span class=\"material-symbols-outlined text-primary\">diamond</span>\n<div>\n<h4 class=\"text-label-md font-bold\">钻石供应商权益</h4>\n<p class=\"text-body-sm text-outline\">可优先获取 RFQ、享受 0% 平台服务费及专属客户经理支持。</p>\n</div>\n</div>\n</div>\n</div>\n<!-- 奖励机制 -->\n<div class=\"col-span-12 lg:col-span-5 bg-white rounded-xl border border-outline-variant p-lg shadow-sm\">\n<h3 class=\"text-headline-sm font-headline-sm mb-6\">奖励机制</h3>\n<div class=\"space-y-gutter\">\n<!-- Points Program -->\n<div class=\"p-lg bg-surface-container rounded-lg relative overflow-hidden group hover:bg-surface-container-high transition-colors\">\n<div class=\"flex justify-between items-start mb-2\">\n<div class=\"z-10\">\n<h4 class=\"text-label-md font-bold flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-tertiary\">monetization_on</span>\n                                        积分权益\n                                    </h4>\n<p class=\"text-body-sm text-on-surface-variant mt-2 max-w-[80%]\">每成功完成一笔订单可获得 10 积分。积分可兑换平台广告位或技术培训服务。</p>\n</div>\n<span class=\"text-headline-sm font-bold text-tertiary\">4,250 <span class=\"text-label-sm font-normal\">积分</span></span>\n</div>\n<button class=\"text-primary text-label-md font-bold mt-4 flex items-center gap-1 hover:underline\">\n                                兑换积分 <span class=\"material-symbols-outlined text-[18px]\">chevron_right</span>\n</button>\n</div>\n<!-- Tier Discounts -->\n<div class=\"p-lg bg-primary-fixed-dim/20 rounded-lg border border-primary/10\">\n<h4 class=\"text-label-md font-bold flex items-center gap-2 mb-4\">\n<span class=\"material-symbols-outlined text-primary\">percent</span>\n                                等级折扣\n                            </h4>\n<div class=\"space-y-3\">\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface\">物流返利</span>\n<span class=\"font-bold text-primary\">5% 折扣</span>\n</div>\n<div class=\"w-full h-[1px] bg-outline-variant\"></div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface\">检验费减免</span>\n<span class=\"font-bold text-primary\">部分减免</span>\n</div>\n<div class=\"w-full h-[1px] bg-outline-variant\"></div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface\">快速结算</span>\n<span class=\"font-bold text-primary\">T+7 天</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Recent Assessment Reports Table -->\n<div class=\"col-span-12 bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden\">\n<div class=\"px-lg py-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-low\">\n<h3 class=\"text-label-md font-bold\">月度考核记录</h3>\n<button class=\"text-primary text-label-md font-bold flex items-center gap-1\">\n                        全部下载 <span class=\"material-symbols-outlined text-[18px]\">download</span>\n</button>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left border-collapse\">\n<thead>\n<tr class=\"bg-surface-container-highest/30\">\n<th class=\"px-lg py-3 text-label-sm text-outline font-bold uppercase tracking-wider\">考核周期</th>\n<th class=\"px-lg py-3 text-label-sm text-outline font-bold uppercase tracking-wider\">分数</th>\n<th class=\"px-lg py-3 text-label-sm text-outline font-bold uppercase tracking-wider\">Status</th>\n<th class=\"px-lg py-3 text-label-sm text-outline font-bold uppercase tracking-wider\">关键改进</th>\n<th class=\"px-lg py-3 text-label-sm text-outline font-bold uppercase tracking-wider text-right\">Action</th>\n</tr>\n</thead>\n<tbody class=\"divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-medium\">2023年10月</td>\n<td class=\"px-lg py-4\">\n<div class=\"flex items-center gap-2\">\n<span class=\"font-bold\">94.2</span>\n<div class=\"w-20 bg-outline-variant h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full\" style=\"width: 94%\"></div>\n</div>\n</div>\n</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-green-100 text-green-700 text-label-sm rounded-md font-bold\">优秀</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">优化包装流程后，交期缩短 4 小时。</td>\n<td class=\"px-lg py-4 text-right\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">\n<span class=\"material-symbols-outlined\">visibility</span>\n</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-medium\">2023年9月</td>\n<td class=\"px-lg py-4\">\n<div class=\"flex items-center gap-2\">\n<span class=\"font-bold\">91.8</span>\n<div class=\"w-20 bg-outline-variant h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full\" style=\"width: 91%\"></div>\n</div>\n</div>\n</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-green-100 text-green-700 text-label-sm rounded-md font-bold\">优秀</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">客户满意度调查达到 4.95 的历史高位。</td>\n<td class=\"px-lg py-4 text-right\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">\n<span class=\"material-symbols-outlined\">visibility</span>\n</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-medium\">2023年8月</td>\n<td class=\"px-lg py-4\">\n<div class=\"flex items-center gap-2\">\n<span class=\"font-bold\">88.5</span>\n<div class=\"w-20 bg-outline-variant h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full\" style=\"width: 88%\"></div>\n</div>\n</div>\n</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-secondary-container text-on-secondary-container text-label-sm rounded-md font-bold\">良好</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">区域台风期间出现轻微物流延误。</td>\n<td class=\"px-lg py-4 text-right\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">\n<span class=\"material-symbols-outlined\">visibility</span>\n</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</div>"
}
