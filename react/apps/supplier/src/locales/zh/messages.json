{
  "slug": "messages",
  "route": "/messages",
  "docTitle": "敏捷智造 - 消息中心",
  "navLabel": "消息中心",
  "mainClass": "h-screen flex overflow-hidden bg-surface",
  "mainHtml": "<section class=\"w-80 flex flex-col border-r border-outline-variant bg-surface-container-lowest\">\n<div class=\"p-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-low\">\n<h2 class=\"text-headline-sm font-headline-sm\">消息</h2>\n<button class=\"text-primary hover:bg-primary/10 p-1 rounded transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_square\">edit_square</span>\n</button>\n</div>\n<div class=\"flex-1 overflow-y-auto\">\n<!-- Conversation Item: Active -->\n<div class=\"p-4 bg-secondary-container/30 border-l-4 border-primary cursor-pointer transition-all\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">精密零件公司</span>\n<span class=\"text-[10px] text-on-surface-variant\">10:45 AM</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">钛合金外壳件的更新 RFQ 已可供查看。</p>\n<div class=\"mt-2 flex gap-1\">\n<span class=\"px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded\">RFQ</span>\n</div>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">系统管理员</span>\n<span class=\"text-[10px] text-on-surface-variant\">昨天</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">您的密码已成功更新，请注意账号安全。</p>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<div class=\"flex items-center gap-1\">\n<span class=\"text-label-md font-bold text-on-surface\">订单 #88219</span>\n<span class=\"w-2 h-2 bg-error rounded-full\"></span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant\">昨天</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">第 04 批次货运已生成新的运单标签。</p>\n<div class=\"mt-2 flex gap-1\">\n<span class=\"px-2 py-0.5 bg-secondary/10 text-secondary text-[10px] font-bold rounded\">订单</span>\n</div>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">财务部</span>\n<span class=\"text-[10px] text-on-surface-variant\">10月24日</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">发票 INV-2023-001 已标记为已付款。</p>\n</div>\n<!-- More placeholder items -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">平台动态</span>\n<span class=\"text-[10px] text-on-surface-variant\">10月22日</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">本周末 AI 报价引擎将迎来重大更新。</p>\n</div>\n</div>\n</section><section class=\"flex-1 flex flex-col bg-surface overflow-hidden relative\">\n<!-- Message Header -->\n<div class=\"h-16 border-b border-outline-variant flex items-center justify-between px-6 bg-surface-container-lowest shrink-0\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold\">P</div>\n<div>\n<h3 class=\"text-label-md font-bold\">精密零件公司</h3>\n<p class=\"text-[11px] text-on-surface-variant\">工程供应商 • 已认证</p>\n</div>\n</div>\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center gap-2 px-3 py-1.5 border border-outline text-body-sm font-medium rounded hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-sm\" data-icon=\"visibility\">visibility</span>\n                        查看 RFQ\n                    </button>\n<button class=\"text-on-surface-variant hover:text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</div>\n<!-- 消息 Timeline -->\n<div class=\"flex-1 overflow-y-auto p-6 space-y-6\">\n<div class=\"flex justify-center\">\n<span class=\"px-3 py-1 bg-surface-container-high rounded-full text-[10px] text-on-surface-variant font-medium\">2023-10-25</span>\n</div>\n<!-- Received Message -->\n<div class=\"flex items-start gap-3 max-w-[80%]\">\n<div class=\"w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold shrink-0\">P</div>\n<div class=\"bg-surface-container-high p-4 rounded-xl rounded-tl-none\">\n<p class=\"text-body-sm\">您好，我们已经审阅了 RFQ #2023-A9 的技术规格，对于内孔公差要求有一些问题需要确认。</p>\n<span class=\"text-[10px] text-on-surface-variant mt-2 block\">10:42 AM</span>\n</div>\n</div>\n<!-- My Message -->\n<div class=\"flex items-start gap-3 max-w-[80%] ml-auto flex-row-reverse\">\n<div class=\"w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container text-xs font-bold shrink-0\">我</div>\n<div class=\"bg-primary text-white p-4 rounded-xl rounded-tr-none shadow-md\">\n<p class=\"text-body-sm\">您好，Precision 团队，这些公差基于 ISO 2768-m 标准。请问当前 CNC 设定对这些参数是否存在问题？</p>\n<span class=\"text-[10px] text-blue-100 mt-2 block text-right\">10:44 AM</span>\n</div>\n</div>\n<!-- Received Message -->\n<div class=\"flex items-start gap-3 max-w-[80%]\">\n<div class=\"w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold shrink-0\">P</div>\n<div class=\"bg-surface-container-high p-4 rounded-xl rounded-tl-none\">\n<p class=\"text-body-sm\">钛合金外壳件的更新 RFQ 已可供查看，我们已附上根据讨论公差调整后的修订报价。</p>\n<div class=\"mt-3 p-3 bg-white border border-outline-variant rounded-lg flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-error\" data-icon=\"picture_as_pdf\">picture_as_pdf</span>\n<div class=\"flex-1\">\n<p class=\"text-[12px] font-bold\">RFQ_Revised_A9.pdf</p>\n<p class=\"text-[10px] text-on-surface-variant\">2.4 MB • PDF</p>\n</div>\n<button class=\"text-primary\"><span class=\"material-symbols-outlined\" data-icon=\"download\">download</span></button>\n</div>\n<span class=\"text-[10px] text-on-surface-variant mt-2 block\">10:45 AM</span>\n</div>\n</div>\n</div>\n<!-- Message Input -->\n<div class=\"p-4 bg-surface-container-lowest border-t border-outline-variant\">\n<div class=\"flex items-end gap-3 bg-surface-container border border-outline-variant rounded-xl p-2 focus-within:ring-2 focus-within:ring-primary/20 transition-all\">\n<div class=\"flex flex-col flex-1\">\n<textarea class=\"w-full bg-transparent border-none focus:ring-0 text-body-sm resize-none py-2 px-3 min-h-[40px] max-h-[120px]\" placeholder=\"输入消息...\" rows=\"1\"></textarea>\n<div class=\"flex items-center gap-2 px-2 pb-1\">\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"attach_file\">attach_file</span>\n</button>\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"mood\">mood</span>\n</button>\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"image\">image</span>\n</button>\n</div>\n</div>\n<button class=\"bg-primary text-white w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary-container transition-colors shadow-sm\">\n<span class=\"material-symbols-outlined\" data-icon=\"send\">send</span>\n</button>\n</div>\n</div>\n</section><section class=\"w-72 bg-surface-container-low border-l border-outline-variant flex flex-col p-6 overflow-y-auto\">\n<h3 class=\"text-label-md font-bold mb-6 text-on-surface-variant uppercase tracking-wider\">消息分类</h3>\n<div class=\"space-y-2\">\n<!-- 系统通知 -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"notifications_active\">notifications_active</span>\n<span class=\"text-body-sm font-medium\">系统通知</span>\n</div>\n<span class=\"bg-error text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full\">3</span>\n</button>\n<!-- RFQ通知 -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg bg-primary/5 border border-primary/20 transition-colors group\">\n<div class=\"flex items-center gap-3 text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"request_quote\">request_quote</span>\n<span class=\"text-body-sm font-bold\">RFQ通知</span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant font-medium\">12</span>\n</button>\n<!-- 订单消息 -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"shopping_bag\">shopping_bag</span>\n<span class=\"text-body-sm font-medium\">订单消息</span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant font-medium\">5</span>\n</button>\n<!-- Finance Notifications -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"payments\">payments</span>\n<span class=\"text-body-sm font-medium\">财务通知</span>\n</div>\n</button>\n<!-- 平台公告 -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"campaign\">campaign</span>\n<span class=\"text-body-sm font-medium\">平台公告</span>\n</div>\n<span class=\"w-2 h-2 bg-primary rounded-full\"></span>\n</button>\n</div>\n<div class=\"mt-10 border-t border-outline-variant pt-8\">\n<h3 class=\"text-label-md font-bold mb-4 text-on-surface-variant uppercase tracking-wider\">快捷操作</h3>\n<div class=\"grid grid-cols-2 gap-3\">\n<button class=\"flex flex-col items-center justify-center p-4 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary hover:text-primary transition-all gap-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"history\">history</span>\n<span class=\"text-[10px] font-bold\">历史记录</span>\n</button>\n<button class=\"flex flex-col items-center justify-center p-4 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary hover:text-primary transition-all gap-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"star\">star</span>\n<span class=\"text-[10px] font-bold\">收藏</span>\n</button>\n</div>\n</div>\n<div class=\"mt-auto pt-8\">\n<div class=\"bg-primary/5 p-4 rounded-xl border border-primary/10\">\n<p class=\"text-[11px] font-bold text-primary mb-2\">小提示</p>\n<p class=\"text-[11px] text-on-surface-variant leading-relaxed\">开启桌面通知，避免错过任何 RFQ 更新或订单状态变化。</p>\n<button class=\"mt-3 text-[11px] font-bold text-primary hover:underline\">立即开启</button>\n</div>\n</div>\n</section>"
}
