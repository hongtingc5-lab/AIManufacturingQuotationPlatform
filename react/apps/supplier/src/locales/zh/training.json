  "mainHtml": "<div class=\"max-w-[1440px] mx-auto p-lg lg:p-xl space-y-xl\">\n<!-- Page Header & Tabs -->\n<section class=\"space-y-lg\">\n<div class=\"flex flex-col md:flex-row md:items-end justify-between gap-md\">\n<div>\n<h2 class=\"font-headline-lg text-headline-lg text-on-surface\">培训中心</h2>\n<p class=\"text-on-surface-variant font-body-lg\">提升您的制造能力，掌握最新的行业标准与工艺规范</p>\n</div>\n<div class=\"flex items-center gap-sm bg-surface-container rounded-xl p-1 shadow-sm\">\n<button class=\"px-md py-2 bg-surface rounded-lg text-primary font-label-md shadow-sm border border-outline-variant/30 transition-all\">我的学习</button>\n<button class=\"px-md py-2 text-on-surface-variant hover:text-on-surface font-label-md transition-all\">全平台公开课</button>\n</div>\n</div>\n<div class=\"flex items-center gap-md overflow-x-auto pb-2 border-b border-outline-variant no-scrollbar\">\n<button class=\"px-md pb-4 border-b-2 border-primary text-primary font-label-md whitespace-nowrap\">入驻培训</button>\n<button class=\"px-md pb-4 text-on-surface-variant hover:text-primary font-label-md whitespace-nowrap\">平台规则</button>\n<button class=\"px-md pb-4 text-on-surface-variant hover:text-primary font-label-md whitespace-nowrap\">工艺规范</button>\n<button class=\"px-md pb-4 text-on-surface-variant hover:text-primary font-label-md whitespace-nowrap\">视频课程</button>\n<button class=\"px-md pb-4 text-on-surface-variant hover:text-primary font-label-md whitespace-nowrap\">文档资料</button>\n<button class=\"px-md pb-4 text-on-surface-variant hover:text-primary font-label-md whitespace-nowrap\">在线考试</button>\n</div>\n</section>\n<!-- Featured Course Banner -->\n<section class=\"relative h-64 md:h-80 rounded-xl overflow-hidden shadow-lg group\">\n<div class=\"absolute inset-0 bg-gradient-to-r from-on-primary-fixed to-transparent z-10 opacity-80\"></div>\n<div class=\"absolute inset-0 z-0 bg-center bg-cover transition-transform duration-700 group-hover:scale-105\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuDy44cPd3NBPPiZ87kl4n-UsktZBeOw81no0UMI6pCebjiZKfbPgX4KOyjA-kI-o0Hz7S0foaKyGcDTzTHsWVsd3IqUrYiZZQz5Q7GBlRj7tZaDMo7xjM7nGv0InCqljWapiI7xiWAEYLx3BNIUoDOb5ttlxKEbpFPBUcyKXB7srEL05f18-OeC6hbH_zfuGmHiV-ayEK5rciFk8cx5mQqouoHHOnx4dwApR9CiQoYKGAiX20DZm6auWrte5c7yU2SX5rKud7qJ1AU\");'></div>\n<div class=\"absolute inset-0 z-20 flex flex-col justify-center px-lg md:px-xl space-y-md\">\n<span class=\"inline-block px-3 py-1 bg-primary text-white font-label-sm rounded-full w-fit\">热门课程</span>\n<h3 class=\"font-headline-lg text-white max-w-2xl leading-tight\">2024 平台质量合规：高级制造标准课程</h3>\n<p class=\"text-primary-fixed max-w-xl font-body-lg\">掌握工业4.0背景下的精益生产质量控制与数字化合规审计要点。</p>\n<div class=\"flex items-center gap-md pt-4\">\n<button class=\"px-xl py-3 bg-white text-primary font-label-md rounded-lg hover:bg-primary-fixed transition-colors flex items-center gap-2\">\n                            立即开始学习 <span class=\"material-symbols-outlined\">play_circle</span>\n</button>\n<span class=\"text-white/80 font-label-sm\">预计耗时：12 小时 | 1,240 人已学</span>\n</div>\n</div>\n</section>\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-xl\">\n<!-- 课程库 (Left 8 columns) -->\n<div class=\"lg:col-span-8 space-y-lg\">\n<div class=\"flex items-center justify-between\">\n<h4 class=\"font-headline-sm text-on-surface flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-primary\">local_library</span>\n                            课程库\n                        </h4>\n<a class=\"text-primary font-label-md flex items-center hover:underline\" href=\"#\">查看更多 <span class=\"material-symbols-outlined text-sm ml-1\">chevron_right</span></a>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-lg\">\n<!-- Course Card 1 -->\n<div class=\"bg-surface rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-all overflow-hidden group\">\n<div class=\"relative h-40 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDcW-HO-WKd_ZrjwvkSd8FdvlDWBbILZ0lshT1DEqDcqywgSIZLLt-ioJiHJ-jmQtkXKj_CHgbz8iQcwrZaV62X87VbO6t0ybGfu7Q-cJd22JUbpLKRiRj__3zO8S68nJkJ26OUA30ArayX2i4n5zvoKqHEKmYW0JMjH7EREj9Acczhysyr4wu7yDrU_k8z0_p9U41fhWqjz8DkyzzdEcSxwmwXVy7LpjolfPRa3eMqkQEkNxunqwTVJlWyXcryk1r3UUZLMSPaeN0\"/>\n<div class=\"absolute top-2 right-2 bg-black/60 backdrop-blur-md text-white text-[10px] px-2 py-1 rounded-md uppercase font-bold tracking-widest\">进阶</div>\n</div>\n<div class=\"p-md space-y-md\">\n<h5 class=\"font-headline-sm text-base text-on-surface line-clamp-1\">工业5轴CNC加工：精密工艺优化</h5>\n<div class=\"flex items-center gap-4 text-on-surface-variant font-label-sm\">\n<span class=\"flex items-center gap-1\"><span class=\"material-symbols-outlined text-[16px]\">schedule</span> 4.5 小时</span>\n<span class=\"flex items-center gap-1\"><span class=\"material-symbols-outlined text-[16px]\">signal_cellular_alt</span> 难度：中等</span>\n</div>\n<div class=\"space-y-1.5\">\n<div class=\"flex justify-between text-[11px] font-bold text-on-surface-variant\">\n<span class=\"\">当前进度</span>\n<span class=\"\">65%</span>\n</div>\n<div class=\"w-full h-1.5 bg-outline-variant rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full rounded-full\" style=\"width: 65%;\"></div>\n</div>\n</div>\n</div>\n</div>\n<!-- Course Card 2 -->\n<div class=\"bg-surface rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-all overflow-hidden group\">\n<div class=\"relative h-40 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAqjxH_YLmscFSF7uvubo5rj82hZuetp3FdOD1Vi978paVs7Oid1k5j5rQPikuwMS8qytJyrBIXeP2P-R1lMFsYCMYzjoQs5yC2Xu4nhqdf4zKr4JynqEDeKBCrHabWFPCbRZzo6pQNEC_4Oyu3ygPozVVlKJJ51BgqZ3lAveHHqjOz-ltexBzMz4BHWRqqONXNywa1RSg7cZUvyOM1X-wCu-fkgHAxNURC9Q4mxfvIHUyxjXn0FprIUNEPQu9iBhYg9gSYnxppUj8\"/>\n<div class=\"absolute top-2 right-2 bg-primary text-white text-[10px] px-2 py-1 rounded-md uppercase font-bold tracking-widest\">必修</div>\n</div>\n<div class=\"p-md space-y-md\">\n<h5 class=\"font-headline-sm text-base text-on-surface line-clamp-1\">质量实验室：精密测量与数据分析</h5>\n<div class=\"flex items-center gap-4 text-on-surface-variant font-label-sm\">\n<span class=\"flex items-center gap-1\"><span class=\"material-symbols-outlined text-[16px]\">schedule</span> 2.0 小时</span>\n<span class=\"flex items-center gap-1\"><span class=\"material-symbols-outlined text-[16px]\">signal_cellular_alt</span> 难度：初级</span>\n</div>\n<div class=\"space-y-1.5\">\n<div class=\"flex justify-between text-[11px] font-bold text-on-surface-variant\">\n<span class=\"\">当前进度</span>\n<span class=\"\">12%</span>\n</div>\n<div class=\"w-full h-1.5 bg-outline-variant rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full rounded-full\" style=\"width: 12%;\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Right Sidebar (4 columns) -->\n<div class=\"lg:col-span-4 space-y-xl\">\n<!-- Upcoming Exams -->\n<div class=\"bg-surface border border-outline-variant rounded-xl p-md space-y-md shadow-sm\">\n<h4 class=\"font-label-md text-on-surface-variant font-bold uppercase tracking-wider flex items-center justify-between\">\n                            待办考试\n                            <span class=\"bg-error/10 text-error px-2 py-0.5 rounded-full text-[10px]\">2项待完成</span>\n</h4>\n<div class=\"space-y-sm\">\n<div class=\"p-md bg-surface-container rounded-lg border border-outline-variant/30 flex items-center gap-md\">\n<div class=\"p-2 bg-primary/10 rounded-lg text-primary\">\n<span class=\"material-symbols-outlined\">quiz</span>\n</div>\n<div class=\"flex-1\">\n<p class=\"font-label-md text-on-surface font-semibold\">过程能力指数 (Cpk) 测试</p>\n<p class=\"text-[11px] text-error font-medium flex items-center gap-1 mt-0.5\">\n<span class=\"material-symbols-outlined text-[12px]\">timer</span> 剩余时间: 2 天\n                                    </p>\n</div>\n<button class=\"px-3 py-1.5 bg-primary text-white text-[12px] font-bold rounded hover:opacity-90 transition-opacity\">开始</button>\n</div>\n<div class=\"p-md bg-surface-container rounded-lg border border-outline-variant/30 flex items-center gap-md opacity-75\">\n<div class=\"p-2 bg-secondary-container rounded-lg text-secondary\">\n<span class=\"material-symbols-outlined\">description</span>\n</div>\n<div class=\"flex-1\">\n<p class=\"font-label-md text-on-surface font-semibold\">安全生产月度考核</p>\n<p class=\"text-[11px] text-on-surface-variant mt-0.5\">截止日期: 2024-06-30</p>\n</div>\n<button class=\"px-3 py-1.5 border border-outline text-[12px] font-bold rounded hover:bg-surface transition-colors\">待解锁</button>\n</div>\n</div>\n</div>\n<!-- Recent Certificates -->\n<div class=\"bg-surface border border-outline-variant rounded-xl p-md space-y-md shadow-sm\">\n<h4 class=\"font-label-md text-on-surface-variant font-bold uppercase tracking-wider flex items-center justify-between\">\n                            已获证书\n                            <span class=\"material-symbols-outlined text-primary-fixed-dim\">verified</span>\n</h4>\n<div class=\"grid grid-cols-1 gap-sm\">\n<div class=\"group flex items-center gap-md p-md bg-surface-container-low border border-primary/20 rounded-lg cursor-pointer hover:border-primary transition-colors\">\n<div class=\"relative w-12 h-16 bg-white border border-outline-variant rounded flex items-center justify-center shadow-sm\">\n<span class=\"material-symbols-outlined text-primary text-3xl\">workspace_premium</span>\n<div class=\"absolute bottom-1 right-1 bg-primary w-2 h-2 rounded-full border border-white\"></div>\n</div>\n<div>\n<p class=\"font-label-md text-on-surface font-semibold\">ISO 9001 合规认证</p>\n<p class=\"text-[11px] text-on-surface-variant\">颁发日期: 2024-03-12</p>\n<div class=\"flex items-center gap-2 mt-1\">\n<span class=\"text-[10px] px-1.5 py-0.5 bg-green-100 text-green-700 rounded border border-green-200\">已生效</span>\n<span class=\"text-[10px] text-primary hover:underline font-bold\">查看详情</span>\n</div>\n</div>\n</div>\n<div class=\"flex items-center gap-md p-md bg-surface-container-low border border-outline-variant/30 rounded-lg\">\n<div class=\"w-12 h-16 bg-white border border-outline-variant rounded flex items-center justify-center shadow-sm grayscale\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-3xl\">military_tech</span>\n</div>\n<div>\n<p class=\"font-label-md text-on-surface font-semibold\">精益供应链管理证书</p>\n<p class=\"text-[11px] text-on-surface-variant\">颁发日期: 2023-11-20</p>\n<div class=\"flex items-center gap-2 mt-1\">\n<span class=\"text-[10px] px-1.5 py-0.5 bg-surface-container text-on-surface-variant rounded border border-outline-variant\">已过期</span>\n<span class=\"text-[10px] text-primary hover:underline font-bold\">重新认证</span>\n</div>\n</div>\n</div>\n</div>\n<button class=\"w-full py-2 border-2 border-dashed border-outline-variant text-on-surface-variant font-label-md rounded-lg hover:bg-surface-container-low transition-colors\">\n                            申请新认证\n                        </button>\n</div>\n</div>\n</div>\n</div>"
