  "mainHtml": "<div class=\"mt-3 mb-8\">\n<div class=\"flex flex-col md:flex-row justify-between items-end gap-4\">\n<div>\n<h2 class=\"text-headline-lg font-headline-lg text-on-surface mb-1\">欢迎回来，XXX公司</h2>\n<p class=\"text-body-lg font-body-lg text-on-surface-variant\">您的工厂运行平稳，今日有 12 项新询盘待处理。</p>\n</div>\n<div class=\"flex gap-3\">\n<button class=\"px-4 py-2 border border-outline text-on-surface rounded-lg text-label-md font-label-md hover:bg-surface-variant transition-colors flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-[18px]\">download</span> 导出月报\n                </button>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-gutter mb-8\">\n<!-- KPI 1: 今日待报价 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">今日待报价</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">12</span>\n<span class=\"text-[10px] px-1.5 py-0.5 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded\">新</span>\n</div>\n<p class=\"text-[11px] text-primary mt-1\">较昨日 +15%</p>\n</div>\n<!-- KPI 2: 今日待接单 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">今日待接单</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">08</span>\n<span class=\"text-[10px] px-1.5 py-0.5 bg-error-container text-on-error-container rounded\">紧急</span>\n</div>\n<p class=\"text-[11px] text-outline mt-1\">状态：平稳</p>\n</div>\n<!-- KPI 3: 在制订单 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">在制订单</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">45</span>\n<span class=\"material-symbols-outlined text-primary text-[18px]\">precision_manufacturing</span>\n</div>\n<p class=\"text-[11px] text-primary mt-1\">5个工单即将交付</p>\n</div>\n<!-- KPI 4: 准时交付率 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">准时交付率</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">94.8%</span>\n<span class=\"material-symbols-outlined text-primary text-[18px]\">schedule</span>\n</div>\n<p class=\"text-[11px] text-primary mt-1\">↑ 2.4% 本月提升</p>\n</div>\n<!-- KPI 5: 产品合格率 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">产品合格率</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">99.2%</span>\n<span class=\"material-symbols-outlined text-primary text-[18px]\">verified</span>\n</div>\n<p class=\"text-[11px] text-primary mt-1\">↑ 0.5% 质量稳定</p>\n</div>\n<!-- KPI 6: 本月收益 -->\n<div class=\"bg-surface-container-lowest p-5 rounded-lg border border-outline-variant card-shadow hover:border-primary transition-all\">\n<h3 class=\"text-on-surface-variant text-label-sm font-label-sm mb-2\">本月收益 (¥)</h3>\n<div class=\"flex items-baseline justify-between\">\n<span class=\"text-headline-sm font-headline-sm text-on-surface\">1.2M</span>\n<span class=\"material-symbols-outlined text-primary text-[18px]\">payments</span>\n</div>\n<p class=\"text-[11px] text-primary mt-1\">完成月目标的 82%</p>\n</div>\n</div><d