  "mainClass": "min-h-screen bg-surface",
  "mainHtml": "<div class=\"p-margin space-y-lg\">\n<!-- Hero Search Section -->\n<section class=\"relative rounded-xl overflow-hidden h-[320px] flex flex-col items-center justify-center text-center p-xl\">\n<div class=\"absolute inset-0 bg-primary/10 backdrop-blur-[2px]\"></div>\n<div class=\"relative z-10 space-y-6 w-full max-w-2xl\">\n<h2 class=\"text-headline-lg font-headline-lg text-on-primary\">Help Center &amp; Feedback</h2>\n<p class=\"text-body-lg font-body-lg text-primary-fixed\">How can we help you? Search user guides or contact our technical support team.</p>\n<div class=\"relative shadow-xl rounded-full\">\n<span class=\"material-symbols-outlined absolute left-6 top-1/2 -translate-y-1/2 text-primary text-2xl\">search</span>\n<input \"payment=\"\" class=\"w-full pl-16 pr-24 py-5 rounded-full border-none text-body-lg focus:ring-4 focus:ring-primary/20\" flow\"=\"\" or=\"\" placeholder=\"Enter keywords such as \" quotation=\"\" security\"...\"=\"\" type=\"text\"/>\n<button class=\"absolute right-3 top-1/2 -translate-y-1/2 bg-primary text-on-primary px-6 py-2.5 rounded-full font-bold hover:bg-primary-container transition-colors\">\n                            Search\n                        </button>\n</div>\n</div>\n</section>\n<!-- Quick Access Grid -->\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-lg\">\n<div class=\"bento-card bg-surface-container-lowest p-lg rounded-xl border border-outline-variant flex items-start gap-4 cursor-pointer\">\n<div class=\"w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-primary text-2xl\">quiz</span>\n</div>\n<div>\n<h3 class=\"text-headline-sm font-headline-sm mb-2\">Frequently Asked Questions (FAQ)</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Quickly find answers about account management, order status, and settlement cycles.</p>\n</div>\n</div>\n<div class=\"bento-card bg-surface-container-lowest p-lg rounded-xl border border-outline-variant flex items-start gap-4 cursor-pointer\">\n<div class=\"w-12 h-12 rounded-lg bg-tertiary-fixed flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-tertiary text-2xl\">menu_book</span>\n</div>\n<div>\n<h3 class=\"text-headline-sm font-headline-sm mb-2\">User Guides</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Step-by-step guidance for using each enterprise function on the AgileMakeAI platform efficiently.</p>\n</div>\n</div>\n<div class=\"bento-card bg-surface-container-lowest p-lg rounded-xl border border-outline-variant flex items-start gap-4 cursor-pointer\">\n<div class=\"w-12 h-12 rounded-lg bg-secondary-fixed flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-secondary text-2xl\">gavel</span>\n</div>\n<div>\n<h3 class=\"text-headline-sm font-headline-sm mb-2\">Platform Rules</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Learn supplier onboarding standards, transaction agreements, and platform compliance requirements.</p>\n</div>\n</div>\n</div>\n<!-- Two Column Layout: Support & Tickets -->\n<div class=\"grid grid-cols-1 lg:grid-cols-12 gap-lg\">\n<!-- Work Order Feedback (Ticket History) -->\n<div class=\"lg:col-span-8 bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden\">\n<div class=\"p-lg border-b border-outline-variant flex justify-between items-center\">\n<div>\n<h3 class=\"text-headline-sm font-headline-sm\">Ticket Feedback</h3>\n<p class=\"text-label-sm text-on-surface-variant\">Review your recently submitted technical support and business inquiry tickets.</p>\n</div>\n<button class=\"flex items-center gap-2 text-primary font-bold hover:underline\">\n<span class=\"material-symbols-outlined text-sm\">add</span>\n                            Submit New Ticket\n                        </button>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left\">\n<thead class=\"bg-surface-container-low text-label-md text-on-surface-variant\">\n<tr>\n<th class=\"px-lg py-4 font-bold\">Ticket ID</th>\n<th class=\"px-lg py-4 font-bold\">Ticket Subject</th>\n<th class=\"px-lg py-4 font-bold\">Status</th>\n<th class=\"px-lg py-4 font-bold\">Last Updated</th>\n<th class=\"px-lg py-4 font-bold\">Actions</th>\n</tr>\n</thead>\n<tbody class=\"divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-variant/20 transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-mono\">TK-882941</td>\n<td class=\"px-lg py-4 text-body-sm\">RFQ Auto-Import Failure Troubleshooting</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-primary/10 text-primary rounded-md text-[10px] font-bold uppercase\">In Progress</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">15 minutes ago</td>\n<td class=\"px-lg py-4\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">View Details</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-variant/20 transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-mono\">TK-882705</td>\n<td class=\"px-lg py-4 text-body-sm\">Account Entity Change Material Review</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-green-100 text-green-700 rounded-md text-[10px] font-bold uppercase\">Resolved</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">Yesterday 14:20</td>\n<td class=\"px-lg py-4\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">View Details</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-variant/20 transition-colors\">\n<td class=\"px-lg py-4 text-body-sm font-mono\">TK-882192</td>\n<td class=\"px-lg py-4 text-body-sm\">Bulk Order Settlement Difference Request</td>\n<td class=\"px-lg py-4\">\n<span class=\"px-2 py-1 bg-green-100 text-green-700 rounded-md text-[10px] font-bold uppercase\">Resolved</span>\n</td>\n<td class=\"px-lg py-4 text-body-sm text-on-surface-variant\">3 days ago</td>\n<td class=\"px-lg py-4\">\n<button class=\"text-primary hover:text-on-primary-fixed-variant transition-colors\">View Details</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"p-4 bg-surface-container-low text-center\">\n<button class=\"text-label-md font-label-md text-on-surface-variant hover:text-primary\">View All Ticket History</button>\n</div>\n</div>\n<!-- Contact Support Widget -->\n<div class=\"lg:col-span-4 space-y-lg\">\n<div class=\"bg-primary text-on-primary rounded-xl p-lg shadow-lg relative overflow-hidden group\">\n<div class=\"absolute -right-4 -bottom-4 opacity-10 rotate-12 transition-transform group-hover:scale-110\">\n<span class=\"material-symbols-outlined text-[120px]\">support_agent</span>\n</div>\n<h3 class=\"text-headline-sm font-headline-sm mb-2 relative z-10\">Contact Support</h3>\n<p class=\"text-body-sm text-primary-fixed mb-6 relative z-10\">Facing an urgent issue? Our expert team is available around the clock to support you.</p>\n<div class=\"space-y-3 relative z-10\">\n<button class=\"w-full bg-on-primary text-primary py-3 rounded-lg font-bold flex items-center justify-center gap-2 hover:bg-primary-fixed transition-colors\">\n<span class=\"material-symbols-outlined\">chat_bubble</span>\n                                Live Chat (Online)\n                            </button>\n<button class=\"w-full bg-primary-container border border-on-primary/30 text-on-primary py-3 rounded-lg font-bold flex items-center justify-center gap-2 hover:bg-primary/80 transition-colors\">\n<span class=\"material-symbols-outlined\">call</span>\n                                Call Support Hotline\n                            </button>\n</div>\n<div class=\"mt-6 pt-6 border-t border-on-primary/20 relative z-10\">\n<div class=\"flex justify-between items-center text-label-sm\">\n<span>Current Queue</span>\n<span class=\"font-bold\">2 people</span>\n</div>\n<div class=\"flex justify-between items-center text-label-sm mt-2\">\n<span>Estimated Wait Time</span>\n<span class=\"font-bold\">&lt; 3 minutes</span>\n</div>\n</div>\n</div>\n<!-- Platform Announcements -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-lg\">\n<h3 class=\"text-label-md font-bold mb-4 flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-tertiary\">campaign</span>\n                            Platform Announcements\n                        </h3>\n<ul class=\"space-y-4\">\n<li>\n<a class=\"group\" href=\"#\">\n<p class=\"text-body-sm font-medium group-hover:text-primary transition-colors\">Notice on the 2024 Annual Supplier Qualification Review</p>\n<p class=\"text-label-sm text-on-surface-variant\">2024-05-12</p>\n</a>\n</li>\n<li>\n<a class=\"group\" href=\"#\">\n<p class=\"text-body-sm font-medium group-hover:text-primary transition-colors\">System Upgrade Notice: Order Management Module Performance Improvements</p>\n<p class=\"text-label-sm text-on-surface-variant\">2024-05-10</p>\n</a>\n</li>\n<li>\n<a class=\"group\" href=\"#\">\n<p class=\"text-body-sm font-medium group-hover:text-primary transition-colors\">[Important] Urgent Notice on Payment Gateway Maintenance</p>\n<p class=\"text-label-sm text-on-surface-variant\">2024-05-08</p>\n</a>\n</li>\n</ul>\n</div>\n</div>\n</div>\n<!-- Visual Decorative Section (Featured Content) -->\n<section class=\"grid grid-cols-1 md:grid-cols-2 gap-lg mt-xl\">\n<div class=\"relative h-48 rounded-xl overflow-hidden group cursor-pointer\">\n<div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110\" data-alt=\"Close-up of high-precision CNC machining parts reflecting bright studio lights in a clean manufacturing environment, shallow depth of field, cool blue tones, industrial high-tech aesthetic.\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCCWzoFj3Loo7ImmuJ8UIb549WZ-r9v3EbQtBu-HA9ke8MS8vzkCdEARlXD1ImMY8wn-RvJ91w89_xcOVbsGf1R2Tl1QHVRQlPmdJokZ40R20_FcKuc3ZBk2xnC8OEhg4rzJjTvIIrLPb0f0YV8YWbhMu7smYKw9qoMUqcNObu5zYFWt_TIWcScTSfM2VFEgqrBDMqdCpnIQo5xaWCLm8JOIKmMuwY-G7YVphZpYl5S_NU5nMexQNqHQ21SBwQfIE5wNWtYUWpVjCc')\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-r from-black/80 to-transparent flex flex-col justify-center p-lg\">\n<span class=\"text-primary-fixed text-[10px] font-bold uppercase tracking-wider mb-2\">Hot Topics</span>\n<h4 class=\"text-headline-sm text-white font-bold mb-1\">Efficient Quotation Strategy Guide</h4>\n<p class=\"text-body-sm text-white/70 max-w-xs\">How to improve RFQ response speed and increase win rates?</p>\n</div>\n</div>\n<div class=\"relative h-48 rounded-xl overflow-hidden group cursor-pointer\">\n<div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110\" data-alt=\"A futuristic digital dashboard displaying complex logistical data and maps, glowing interfaces, dark background with vibrant cyan and white data visualization, corporate SaaS aesthetic.\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuB029rmreHZu1xDywBU013nDzUGiPM2iSpvmNA7WSks2xKbeOoT-wCuZBliVgd7UFxjoPScEN6_6DS-tiwjnZj5BnLNSxgAbRoHeCyKeIkt6cI7gNM3IcaT-b69fwnGUBX9i6leHK_8jkhmxcqYQ9eEqTDrsrlFves9f4BJe3rPtAy9Yd2izePGt_JEiGpkBr4b_lPwU4TkOzlKibmuHTy_BHT66ZZjNnmOUP9H-CHjs7bbR72kZfjpMvSnr8fxtL4MV-VjvpmAFPg')\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-r from-black/80 to-transparent flex flex-col justify-center p-lg\">\n<span class=\"text-primary-fixed text-[10px] font-bold uppercase tracking-wider mb-2\">New Feature Release</span>\n<h4 class=\"text-headline-sm text-white font-bold mb-1\">Intelligent Supply Chain Forecasting Tool</h4>\n<p class=\"text-body-sm text-white/70 max-w-xs\">Use AI to anticipate raw material fluctuations and delivery risks.</p>\n</div>\n</div>\n</section>\n</div>"
