  "docTitle": "AgileMakeAI - Message Center",
  "navLabel": "Messages",
  "mainClass": "h-screen flex overflow-hidden bg-surface",
  "mainHtml": "<section class=\"w-80 flex flex-col border-r border-outline-variant bg-surface-container-lowest\">\n<div class=\"p-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-low\">\n<h2 class=\"text-headline-sm font-headline-sm\">Messages</h2>\n<button class=\"text-primary hover:bg-primary/10 p-1 rounded transition-colors\">\n<span class=\"material-symbols-outlined\" data-icon=\"edit_square\">edit_square</span>\n</button>\n</div>\n<div class=\"flex-1 overflow-y-auto\">\n<!-- Conversation Item: Active -->\n<div class=\"p-4 bg-secondary-container/30 border-l-4 border-primary cursor-pointer transition-all\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">Precision Parts Co.</span>\n<span class=\"text-[10px] text-on-surface-variant\">10:45 AM</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">The updated RFQ for the titanium housing is now available for review.</p>\n<div class=\"mt-2 flex gap-1\">\n<span class=\"px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded\">RFQ</span>\n</div>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">System Admin</span>\n<span class=\"text-[10px] text-on-surface-variant\">Yesterday</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">Your password has been successfully updated. Secure your account.</p>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<div class=\"flex items-center gap-1\">\n<span class=\"text-label-md font-bold text-on-surface\">Order #88219</span>\n<span class=\"w-2 h-2 bg-error rounded-full\"></span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant\">Yesterday</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">New shipping label generated for the batch 04 shipment.</p>\n<div class=\"mt-2 flex gap-1\">\n<span class=\"px-2 py-0.5 bg-secondary/10 text-secondary text-[10px] font-bold rounded\">Order</span>\n</div>\n</div>\n<!-- Conversation Item -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">Finance Dept.</span>\n<span class=\"text-[10px] text-on-surface-variant\">Oct 24</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">Invoice INV-2023-001 has been marked as paid.</p>\n</div>\n<!-- More placeholder items -->\n<div class=\"p-4 hover:bg-surface-container cursor-pointer transition-all border-b border-outline-variant/50\">\n<div class=\"flex justify-between items-start mb-1\">\n<span class=\"text-label-md font-bold text-on-surface\">Platform News</span>\n<span class=\"text-[10px] text-on-surface-variant\">Oct 22</span>\n</div>\n<p class=\"text-body-sm text-on-surface-variant line-clamp-1\">Major updates to the AI quoting engine coming this weekend.</p>\n</div>\n</div>\n</section><section class=\"flex-1 flex flex-col bg-surface overflow-hidden relative\">\n<!-- Message Header -->\n<div class=\"h-16 border-b border-outline-variant flex items-center justify-between px-6 bg-surface-container-lowest shrink-0\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold\">P</div>\n<div>\n<h3 class=\"text-label-md font-bold\">Precision Parts Co.</h3>\n<p class=\"text-[11px] text-on-surface-variant\">Engineering Supplier • Verified</p>\n</div>\n</div>\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center gap-2 px-3 py-1.5 border border-outline text-body-sm font-medium rounded hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-sm\" data-icon=\"visibility\">visibility</span>\n                        View RFQ\n                    </button>\n<button class=\"text-on-surface-variant hover:text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</div>\n<!-- Messages Timeline -->\n<div class=\"flex-1 overflow-y-auto p-6 space-y-6\">\n<div class=\"flex justify-center\">\n<span class=\"px-3 py-1 bg-surface-container-high rounded-full text-[10px] text-on-surface-variant font-medium\">October 25, 2023</span>\n</div>\n<!-- Received Message -->\n<div class=\"flex items-start gap-3 max-w-[80%]\">\n<div class=\"w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold shrink-0\">P</div>\n<div class=\"bg-surface-container-high p-4 rounded-xl rounded-tl-none\">\n<p class=\"text-body-sm\">Hello, we've reviewed the technical specifications for the RFQ #2023-A9. We have a few questions regarding the tolerance requirements on the internal bore.</p>\n<span class=\"text-[10px] text-on-surface-variant mt-2 block\">10:42 AM</span>\n</div>\n</div>\n<!-- My Message -->\n<div class=\"flex items-start gap-3 max-w-[80%] ml-auto flex-row-reverse\">\n<div class=\"w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container text-xs font-bold shrink-0\">ME</div>\n<div class=\"bg-primary text-white p-4 rounded-xl rounded-tr-none shadow-md\">\n<p class=\"text-body-sm\">Hi Precision Team, the tolerances are based on the ISO 2768-m standard. Are you seeing any issues with the current CNC setup for these parameters?</p>\n<span class=\"text-[10px] text-blue-100 mt-2 block text-right\">10:44 AM</span>\n</div>\n</div>\n<!-- Received Message -->\n<div class=\"flex items-start gap-3 max-w-[80%]\">\n<div class=\"w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-bold shrink-0\">P</div>\n<div class=\"bg-surface-container-high p-4 rounded-xl rounded-tl-none\">\n<p class=\"text-body-sm\">The updated RFQ for the titanium housing is now available for review. We have attached the revised quote with the tolerance adjustments discussed.</p>\n<div class=\"mt-3 p-3 bg-white border border-outline-variant rounded-lg flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-error\" data-icon=\"picture_as_pdf\">picture_as_pdf</span>\n<div class=\"flex-1\">\n<p class=\"text-[12px] font-bold\">RFQ_Revised_A9.pdf</p>\n<p class=\"text-[10px] text-on-surface-variant\">2.4 MB • PDF</p>\n</div>\n<button class=\"text-primary\"><span class=\"material-symbols-outlined\" data-icon=\"download\">download</span></button>\n</div>\n<span class=\"text-[10px] text-on-surface-variant mt-2 block\">10:45 AM</span>\n</div>\n</div>\n</div>\n<!-- Message Input -->\n<div class=\"p-4 bg-surface-container-lowest border-t border-outline-variant\">\n<div class=\"flex items-end gap-3 bg-surface-container border border-outline-variant rounded-xl p-2 focus-within:ring-2 focus-within:ring-primary/20 transition-all\">\n<div class=\"flex flex-col flex-1\">\n<textarea class=\"w-full bg-transparent border-none focus:ring-0 text-body-sm resize-none py-2 px-3 min-h-[40px] max-h-[120px]\" placeholder=\"Write a message...\" rows=\"1\"></textarea>\n<div class=\"flex items-center gap-2 px-2 pb-1\">\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"attach_file\">attach_file</span>\n</button>\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"mood\">mood</span>\n</button>\n<button class=\"text-on-surface-variant hover:text-primary p-1 rounded-full hover:bg-surface-variant transition-all\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"image\">image</span>\n</button>\n</div>\n</div>\n<button class=\"bg-primary text-white w-10 h-10 rounded-lg flex items-center justify-center hover:bg-primary-container transition-colors shadow-sm\">\n<span class=\"material-symbols-outlined\" data-icon=\"send\">send</span>\n</button>\n</div>\n</div>\n</section><section class=\"w-72 bg-surface-container-low border-l border-outline-variant flex flex-col p-6 overflow-y-auto\">\n<h3 class=\"text-label-md font-bold mb-6 text-on-surface-variant uppercase tracking-wider\">Message Categories</h3>\n<div class=\"space-y-2\">\n<!-- System Notifications -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"notifications_active\">notifications_active</span>\n<span class=\"text-body-sm font-medium\">System Notifications</span>\n</div>\n<span class=\"bg-error text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full\">3</span>\n</button>\n<!-- RFQ Notifications -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg bg-primary/5 border border-primary/20 transition-colors group\">\n<div class=\"flex items-center gap-3 text-primary\">\n<span class=\"material-symbols-outlined\" data-icon=\"request_quote\">request_quote</span>\n<span class=\"text-body-sm font-bold\">RFQ Notifications</span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant font-medium\">12</span>\n</button>\n<!-- Order Messages -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"shopping_bag\">shopping_bag</span>\n<span class=\"text-body-sm font-medium\">Order Messages</span>\n</div>\n<span class=\"text-[10px] text-on-surface-variant font-medium\">5</span>\n</button>\n<!-- Finance Notifications -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"payments\">payments</span>\n<span class=\"text-body-sm font-medium\">Financial Notices</span>\n</div>\n</button>\n<!-- Platform Announcements -->\n<button class=\"w-full flex items-center justify-between p-3 rounded-lg hover:bg-surface-variant transition-colors group\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"campaign\">campaign</span>\n<span class=\"text-body-sm font-medium\">Platform Announcements</span>\n</div>\n<span class=\"w-2 h-2 bg-primary rounded-full\"></span>\n</button>\n</div>\n<div class=\"mt-10 border-t border-outline-variant pt-8\">\n<h3 class=\"text-label-md font-bold mb-4 text-on-surface-variant uppercase tracking-wider\">Quick Actions</h3>\n<div class=\"grid grid-cols-2 gap-3\">\n<button class=\"flex flex-col items-center justify-center p-4 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary hover:text-primary transition-all gap-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"history\">history</span>\n<span class=\"text-[10px] font-bold\">History</span>\n</button>\n<button class=\"flex flex-col items-center justify-center p-4 bg-surface-container-lowest border border-outline-variant rounded-xl hover:border-primary hover:text-primary transition-all gap-2\">\n<span class=\"material-symbols-outlined\" data-icon=\"star\">star</span>\n<span class=\"text-[10px] font-bold\">Star</span>\n</button>\n</div>\n</div>\n<div class=\"mt-auto pt-8\">\n<div class=\"bg-primary/5 p-4 rounded-xl border border-primary/10\">\n<p class=\"text-[11px] font-bold text-primary mb-2\">PRO TIP</p>\n<p class=\"text-[11px] text-on-surface-variant leading-relaxed\">Turn on desktop notifications to never miss an RFQ update or order status change.</p>\n<button class=\"mt-3 text-[11px] font-bold text-primary hover:underline\">Enable Now</button>\n</div>\n</div>\n</section>"
}
