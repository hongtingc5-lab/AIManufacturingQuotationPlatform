  "mainClass": "min-h-screen bg-surface",
  "mainHtml": "<div class=\"max-w-[1400px] mx-auto px-margin pt-6 pb-xl\">\n<!-- Breadcrumbs & Actions -->\n<div class=\"flex justify-between items-center mb-6\">\n<div class=\"flex items-center gap-sm text-sm text-on-surface-variant\">\n<span class=\"\">Home</span>\n<span class=\"material-symbols-outlined text-[16px]\">chevron_right</span>\n<span class=\"text-primary font-medium\">Enterprise Onboarding</span>\n</div>\n<div class=\"flex gap-md\">\n<button class=\"px-lg py-sm border border-outline text-on-surface font-label-md text-label-md rounded-lg hover:bg-surface-container-highest transition-all\">Save Draft</button>\n<button class=\"px-lg py-sm bg-primary text-on-primary font-label-md text-label-md rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all flex items-center gap-sm\">\n<span class=\"\">Submit for Review</span>\n<span class=\"material-symbols-outlined text-[18px]\">send</span>\n</button>\n</div>\n</div>\n<div class=\"grid grid-cols-12 gap-lg items-start\">\n<!-- Left: Navigation Stepper -->\n<aside class=\"col-span-3 sticky top-[88px]\">\n<div class=\"bg-surface-container-lowest p-lg rounded-xl border border-outline-variant shadow-sm\">\n<h3 class=\"font-headline-sm text-headline-sm mb-lg border-b border-outline-variant pb-sm\">Onboarding Process</h3>\n<div class=\"space-y-0 relative\">\n<!-- Step 1: Active -->\n<div class=\"relative pl-10 pb-10\">\n<div class=\"stepper-line\"></div>\n<div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-primary flex items-center justify-center z-10 shadow-lg shadow-primary/30\">\n<span class=\"text-on-primary text-sm font-bold\">01</span>\n</div>\n<div>\n<h4 class=\"font-label-md text-label-md font-bold text-primary\">Company Profile</h4>\n<p class=\"text-body-sm text-label-sm text-on-surface-variant mt-1\">Basic information and legal entity verification</p>\n<div class=\"mt-sm flex gap-xs\">\n<span class=\"px-xs py-[2px] bg-primary/10 text-primary rounded text-[10px] font-bold\">In Progress</span>\n</div>\n</div>\n</div>\n<!-- Step 2 -->\n<div class=\"relative pl-10 pb-10\">\n<div class=\"stepper-line\"></div>\n<div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-surface-container-high border-2 border-outline-variant flex items-center justify-center z-10 text-on-surface-variant\">\n<span class=\"text-sm font-bold\">02</span>\n</div>\n<div>\n<h4 class=\"font-label-md text-label-md font-bold\">Company Certification</h4>\n<p class=\"text-body-sm text-label-sm text-on-surface-variant mt-1\">ISO certification, material certification, and industry qualifications</p>\n</div>\n</div>\n<!-- Step 3 -->\n<div class=\"relative pl-10 pb-10\">\n<div class=\"stepper-line\"></div>\n<div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-surface-container-high border-2 border-outline-variant flex items-center justify-center z-10 text-on-surface-variant\">\n<span class=\"text-sm font-bold\">03</span>\n</div>\n<div>\n<h4 class=\"font-label-md text-label-md font-bold\">Capabilities and Equipment</h4>\n<p class=\"text-body-sm text-label-sm text-on-surface-variant mt-1\">CNC, sheet metal, and production line details</p>\n</div>\n</div>\n<!-- Step 4 -->\n<div class=\"relative pl-10 pb-10\">\n<div class=\"stepper-line\"></div>\n<div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-surface-container-high border-2 border-outline-variant flex items-center justify-center z-10 text-on-surface-variant\">\n<span class=\"text-sm font-bold\">04</span>\n</div>\n<div>\n<h4 class=\"font-label-md text-label-md font-bold\">Factory Showcase</h4>\n<p class=\"text-body-sm text-label-sm text-on-surface-variant mt-1\">Workshop photos, warehousing, and logistics</p>\n</div>\n</div>\n<!-- Step 5 -->\n<div class=\"relative pl-10\">\n<div class=\"absolute left-0 top-0 w-8 h-8 rounded-full bg-surface-container-high border-2 border-outline-variant flex items-center justify-center z-10 text-on-surface-variant\">\n<span class=\"text-sm font-bold\">05</span>\n</div>\n<div>\n<h4 class=\"font-label-md text-label-md font-bold\">Review Progress</h4>\n<p class=\"text-body-sm text-label-sm text-on-surface-variant mt-1\">Manual platform review and admission</p>\n</div>\n</div>\n</div>\n</div>\n<!-- Progress Summary Card -->\n<div class=\"mt-lg bg-primary-container/10 p-lg rounded-xl border border-primary/20\">\n<div class=\"flex justify-between items-end mb-sm\">\n<span class=\"text-primary font-bold text-sm\">Profile Completeness</span>\n<span class=\"text-primary font-black text-lg\">35%</span>\n</div>\n<div class=\"w-full h-2 bg-surface-container-high rounded-full overflow-hidden\">\n<div class=\"h-full bg-primary rounded-full transition-all duration-500\" style=\"width: 35%\"></div>\n</div>\n<p class=\"mt-md text-[12px] text-on-surface-variant leading-relaxed italic\">\n                            Tip: Completing on-site photos in the \"Factory Showcase\" step can increase onboarding success by 40%.\n                        </p>\n</div>\n</aside>\n<!-- Right: Main Form Content -->\n<div class=\"col-span-9 space-y-lg\">\n<!-- Section 1: Corporate Identity -->\n<section class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm overflow-hidden\">\n<div class=\"p-lg bg-surface-container-low border-b border-outline-variant flex justify-between items-center\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" data-icon=\"domain\" style=\"font-variation-settings: 'FILL' 1;\">domain</span>\n</div>\n<div>\n<h3 class=\"font-headline-sm text-headline-sm\">Company Profile</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Please provide authentic and valid business registration information</p>\n</div>\n</div>\n</div>\n<div class=\"p-lg\">\n<div class=\"grid grid-cols-2 gap-lg\">\n<div class=\"col-span-2\">\n<label class=\"block font-label-md text-label-md mb-xs\">Company Full Name (must match the business license)</label>\n<input class=\"w-full px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\" type=\"text\" value=\"智造工业科技有限公司\"/>\n</div>\n<div class=\"col-span-1\">\n<label class=\"block font-label-md text-label-md mb-xs\">Unified Social Credit Code</label>\n<input class=\"w-full px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\" placeholder=\"91XXXXXXXXXXXXXXXX\" type=\"text\"/>\n</div>\n<div class=\"col-span-1\">\n<label class=\"block font-label-md text-label-md mb-xs\">Legal Representative</label>\n<input class=\"w-full px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\" type=\"text\" value=\"张永兴\"/>\n</div>\n<div class=\"col-span-2\">\n<label class=\"block font-label-md text-label-md mb-xs\">Registered Address</label>\n<div class=\"flex gap-sm\">\n<select class=\"px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\">\n<option>Guangdong Province</option>\n</select>\n<select class=\"px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\">\n<option>Shenzhen City</option>\n</select>\n<input class=\"flex-1 px-md py-sm border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all\" placeholder=\"Detailed Address\" type=\"text\"/>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section 2: Certifications -->\n<section class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm overflow-hidden\">\n<div class=\"p-lg bg-surface-container-low border-b border-outline-variant flex justify-between items-center\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-10 h-10 rounded-lg bg-tertiary/10 text-tertiary flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" data-icon=\"verified_user\" style=\"font-variation-settings: 'FILL' 1;\">verified_user</span>\n</div>\n<div>\n<h3 class=\"font-headline-sm text-headline-sm\">Certifications and Qualifications</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Upload high-quality scans to ensure all information is clear and readable</p>\n</div>\n</div>\n</div>\n<div class=\"p-lg\">\n<div class=\"grid grid-cols-3 gap-lg\">\n<!-- Cert Card 1 -->\n<div class=\"border border-outline-variant rounded-xl p-md group hover:border-primary transition-all cursor-pointer relative overflow-hidden\">\n<div class=\"flex flex-col h-full\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"description\">description</span>\n<span class=\"px-sm py-xs bg-surface-container-highest text-on-surface-variant text-[10px] rounded font-bold\">Not Uploaded</span>\n</div>\n<h4 class=\"font-label-md text-label-md font-bold mb-xs\">Business License</h4>\n<p class=\"text-xs text-on-surface-variant mb-md\">Color scan of the original or duplicate certificate</p>\n<div class=\"mt-auto pt-md flex items-center justify-center border-t border-dashed border-outline-variant group-hover:bg-primary/5 transition-colors\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">add_a_photo</span>\n</div>\n</div>\n</div>\n<!-- Cert Card 2 -->\n<div class=\"border border-primary bg-primary/5 rounded-xl p-md group transition-all relative\">\n<div class=\"flex flex-col h-full\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"verified\" style=\"font-variation-settings: 'FILL' 1;\">verified</span>\n<span class=\"px-sm py-xs bg-primary/10 text-primary text-[10px] rounded font-bold\">Uploaded</span>\n</div>\n<h4 class=\"font-label-md text-label-md font-bold mb-xs\">ISO 9001 Quality Certification</h4>\n<p class=\"text-xs text-on-surface-variant mb-md\">Valid until: 2026-12-01</p>\n<div class=\"mt-auto flex items-center justify-between\">\n<span class=\"text-xs text-primary font-medium truncate\">ISO_Cert_v1.pdf</span>\n<button class=\"text-on-surface-variant hover:text-error\"><span class=\"material-symbols-outlined text-[18px]\">delete</span></button>\n</div>\n</div>\n</div>\n<!-- Cert Card 3 -->\n<div class=\"border border-outline-variant rounded-xl p-md group hover:border-primary transition-all cursor-pointer\">\n<div class=\"flex flex-col h-full\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:text-primary\" data-icon=\"shield_with_heart\">shield_with_heart</span>\n<span class=\"px-sm py-xs bg-surface-container-highest text-on-surface-variant text-[10px] rounded font-bold\">Optional</span>\n</div>\n<h4 class=\"font-label-md text-label-md font-bold mb-xs\">Industry Entry Permit</h4>\n<p class=\"text-xs text-on-surface-variant mb-md\">Such as medical, military, or aerospace qualifications</p>\n<div class=\"mt-auto pt-md flex items-center justify-center border-t border-dashed border-outline-variant group-hover:bg-primary/5 transition-colors\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">add_a_photo</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section 3: Capabilities & Equipment -->\n<section class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm overflow-hidden\">\n<div class=\"p-lg bg-surface-container-low border-b border-outline-variant flex justify-between items-center\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-10 h-10 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" data-icon=\"precision_manufacturing\" style=\"font-variation-settings: 'FILL' 1;\">precision_manufacturing</span>\n</div>\n<div>\n<h3 class=\"font-headline-sm text-headline-sm\">Capabilities and Equipment</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Detailed manufacturing capabilities help match orders more accurately</p>\n</div>\n</div>\n<button class=\"text-primary font-label-md text-label-md flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-[18px]\">add_circle</span>\n<span class=\"\">Add Equipment</span>\n</button>\n</div>\n<div class=\"p-lg\">\n<div class=\"mb-lg\">\n<label class=\"block font-label-md text-label-md mb-md\">Core Manufacturing Capabilities (multiple choice)</label>\n<div class=\"flex flex-wrap gap-sm\">\n<span class=\"px-lg py-sm bg-primary text-on-primary rounded-lg font-label-md text-label-md cursor-pointer transition-all\">CNC Milling</span>\n<span class=\"px-lg py-sm bg-primary text-on-primary rounded-lg font-label-md text-label-md cursor-pointer transition-all\">CNC Turning</span>\n<span class=\"px-lg py-sm bg-surface-container-high text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-highest cursor-pointer transition-all\">Sheet Metal Fabrication</span>\n<span class=\"px-lg py-sm bg-surface-container-high text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-highest cursor-pointer transition-all\">3D Printing</span>\n<span class=\"px-lg py-sm bg-surface-container-high text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-highest cursor-pointer transition-all\">Die Casting</span>\n<span class=\"px-lg py-sm bg-surface-container-high text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-highest cursor-pointer transition-all\">Injection Molding</span>\n</div>\n</div>\n<div class=\"overflow-hidden border border-outline-variant rounded-lg\">\n<table class=\"w-full text-left border-collapse\">\n<thead>\n<tr class=\"bg-surface-container-low\">\n<th class=\"px-md py-sm font-label-md text-label-md text-on-surface-variant border-b border-outline-variant\">Equipment Name</th>\n<th class=\"px-md py-sm font-label-md text-label-md text-on-surface-variant border-b border-outline-variant\">Brand / Model</th>\n<th class=\"px-md py-sm font-label-md text-label-md text-on-surface-variant border-b border-outline-variant\">Machining Accuracy</th>\n<th class=\"px-md py-sm font-label-md text-label-md text-on-surface-variant border-b border-outline-variant text-right\">Actions</th>\n</tr>\n</thead>\n<tbody class=\"divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-container-lowest transition-colors group\">\n<td class=\"px-md py-md flex items-center gap-md\">\n<div class=\"w-12 h-12 rounded border border-outline-variant overflow-hidden shrink-0\">\n<img class=\"w-full h-full object-cover\" data-alt=\"A high-definition macro photograph of a modern 5-axis CNC machining center, featuring its metallic spindle and precision tool bits. The background is a clean, well-lit manufacturing facility with professional blue and white industrial lighting. The machine looks robust, clean, and technologically advanced.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCFqL2WVbcYSzOfDcsRAXdaMi5D04tCPqopiIL7SGSPdiPz9mELA35syPQFd4yLw8ILNqSHBQKCbvh0J71KqIUh1mAEXPW_bOce8lUzQ4kFuzCeACHl4J3I-9jxL8pBcS8uJ841YWqG-anqZITf0ZCFXCMRM73NBjHUP7q1gvbGMLz6D9IPqJV60LPiSM_f6qJqZvUq4plv-8sYH7Y49ZVrAClVbxgAg5djgvEPjWjRi-AzqSQC1_VVfx4e3Gkh52rgf_IQ9mgoVwY\"/>\n</div>\n<span class=\"font-label-md text-label-md font-bold\">5-Axis Machining Center</span>\n</td>\n<td class=\"px-md py-md text-sm\">DMG MORI / DMU 50</td>\n<td class=\"px-md py-md text-sm\">±0.005mm</td>\n<td class=\"px-md py-md text-right\">\n<button class=\"text-primary hover:underline text-sm font-medium mr-md\">Edit</button>\n<button class=\"text-error hover:underline text-sm font-medium\">Delete</button>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-lowest transition-colors group\">\n<td class=\"px-md py-md flex items-center gap-md\">\n<div class=\"w-12 h-12 rounded border border-outline-variant overflow-hidden shrink-0\">\n<img class=\"w-full h-full object-cover\" data-alt=\"A close-up of an industrial precision laser cutting machine in operation, with orange and white sparks illuminating a clean workshop environment. The lighting is focused and professional, highlighting the high-tech machinery and metallic surfaces. The atmosphere is one of high efficiency and precision manufacturing.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD_2rBFCKDSnx3WzYdUWa9tqmuL9SUESldj-Wovr-ZHXY__wt_Q6gMjpMG2SSxiZMLLolSPTFebTeztWEw_6yBlp3w-B-xXI9-HGZh9Gwhr_nRvx1g0IQ53BlLn3eoA53A8h8BN7gqVQQYaGN-vA65wrj7fb_qlRhrhzwrwLzPZpYLXkQf_RlQK-g76SY4p3HpcY2mc9W0HMrFr9fAACRurCLibHK4pFG6BtdHjf7MA3QdfSfnWN7vuQbzzzBm8m8LEymStWa9yQEY\"/>\n</div>\n<span class=\"font-label-md text-label-md font-bold\">High-Precision Laser Cutting Machine</span>\n</td>\n<td class=\"px-md py-md text-sm\">Mazak / Optiplex 3015</td>\n<td class=\"px-md py-md text-sm\">±0.1mm</td>\n<td class=\"px-md py-md text-right\">\n<button class=\"text-primary hover:underline text-sm font-medium mr-md\">Edit</button>\n<button class=\"text-error hover:underline text-sm font-medium\">Delete</button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</section>\n<!-- Section 4: Factory Display -->\n<section class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm overflow-hidden\">\n<div class=\"p-lg bg-surface-container-low border-b border-outline-variant flex justify-between items-center\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-10 h-10 rounded-lg bg-tertiary-container/10 text-tertiary flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" data-icon=\"photo_camera\" style=\"font-variation-settings: 'FILL' 1;\">photo_camera</span>\n</div>\n<div>\n<h3 class=\"font-headline-sm text-headline-sm\">Factory Showcase</h3>\n<p class=\"text-body-sm text-on-surface-variant\">Showcase your real office environment and production site</p>\n</div>\n</div>\n<button class=\"px-md py-sm bg-primary-container text-on-primary-container rounded-lg font-label-sm text-label-sm hover:opacity-90 transition-all\">Batch Upload</button>\n</div>\n<div class=\"p-lg\">\n<div class=\"grid grid-cols-4 gap-md\">\n<div class=\"col-span-2 row-span-2 group relative overflow-hidden rounded-xl aspect-[4/3] border border-outline-variant\">\n<img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" data-alt=\"A wide-angle, panoramic shot of a vast, modern industrial manufacturing plant floor. The space is organized with rows of high-end CNC machines, perfectly clean walkways, and advanced robotic arms. The lighting is a mix of natural skylights and bright LED panels, creating a professional, efficient, and high-tech corporate atmosphere.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDvKQLTI813GncBhNsW1c7zyK2DnjlsDJ0gNYHxttaqLdH2n0ej2EYIJ1yT6PD74hpWL4NVNqM9CDknXbNDFHUa22cD50WSYR2aZf5ywlY9lPZRRj2LTNw6Mksdm2JNQF51-JrRElby4jt7qlvKVjr_a5ZWV_lx7_clokYtXI8FkvoS83Pjz7QpiLASo6Op3mznxKZAgY1AT0lAchMy3iz5QlYPwFUgpC4dap7SXEqJu483St_CCGzZJX3JPlPkrNNm9Kr49UmG6jE\"/>\n<div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-md\">\n<p class=\"text-white text-sm font-bold\">Main Workshop Panorama (recommended)</p>\n</div>\n<button class=\"absolute top-2 right-2 w-8 h-8 rounded-full bg-white/20 backdrop-blur-md text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\">\n<span class=\"material-symbols-outlined text-[18px]\">close</span>\n</button>\n</div>\n<div class=\"col-span-1 aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-on-surface-variant hover:bg-surface-container-low hover:border-primary cursor-pointer transition-all group\">\n<span class=\"material-symbols-outlined text-[32px] group-hover:text-primary transition-colors\">add_photo_alternate</span>\n<span class=\"text-[10px] mt-xs font-bold\">Add Finished Product Display Area</span>\n</div>\n<div class=\"col-span-1 aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-on-surface-variant hover:bg-surface-container-low hover:border-primary cursor-pointer transition-all group\">\n<span class=\"material-symbols-outlined text-[32px] group-hover:text-primary transition-colors\">add_photo_alternate</span>\n<span class=\"text-[10px] mt-xs font-bold\">Add Quality Inspection Room</span>\n</div>\n<div class=\"col-span-1 aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-on-surface-variant hover:bg-surface-container-low hover:border-primary cursor-pointer transition-all group\">\n<span class=\"material-symbols-outlined text-[32px] group-hover:text-primary transition-colors\">add_photo_alternate</span>\n<span class=\"text-[10px] mt-xs font-bold\">Add Office Building Exterior</span>\n</div>\n<div class=\"col-span-1 aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-on-surface-variant hover:bg-surface-container-low hover:border-primary cursor-pointer transition-all group\">\n<span class=\"material-symbols-outlined text-[32px] group-hover:text-primary transition-colors\">add_photo_alternate</span>\n<span class=\"text-[10px] mt-xs font-bold\">Add Warehouse Area</span>\n</div>\n</div>\n</div>\n</section>\n</div>\n</div>\n</div>"
}
