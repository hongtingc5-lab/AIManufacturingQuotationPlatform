  "mainHtml": "<div class=\"flex-1 flex flex-col bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden flex-shrink-0 min-w-[300px] max-w-[500px]\">\n<!-- Chat Header -->\n<div class=\"p-md border-b border-outline-variant bg-surface-container-low flex justify-between items-center\">\n<div class=\"flex items-center gap-sm\">\n<div class=\"w-10 h-10 rounded bg-primary-container text-on-primary flex items-center justify-center\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">psychology</span>\n</div>\n<div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">AgileMakeAI Nexus</h3>\n<p class=\"text-label-md font-label-md text-on-surface-variant flex items-center gap-xs\">\n<span class=\"w-2 h-2 rounded-full bg-[#10B991]\"></span> Online &amp; Analyzing\n                        </p>\n</div>\n</div>\n</div>\n<!-- Chat History -->\n<div class=\"flex-1 overflow-y-auto p-md flex flex-col gap-md bg-surface-bright\">\n<!-- AI Message Center -->\n<div class=\"flex gap-sm\">\n<div class=\"w-8 h-8 rounded bg-primary-container text-on-primary flex items-center justify-center flex-shrink-0 mt-1\">\n<span class=\"material-symbols-outlined text-sm\">psychology</span>\n</div>\n<div class=\"bg-surface-container p-sm rounded-lg rounded-tl-none border border-outline-variant max-w-[85%]\">\n<p class=\"text-body-md font-body-md text-on-surface\">System active. I am monitoring Line A operations. How can I assist you with production analysis today?</p>\n</div>\n</div>\n<!-- User Message Center -->\n<div class=\"flex gap-sm justify-end\">\n<div class=\"bg-primary text-on-primary p-sm rounded-lg rounded-tr-none max-w-[85%]\">\n<p class=\"text-body-md font-body-md\">Analyze the vibration anomaly detected on CNC Unit 04 during the last shift.</p>\n</div>\n<div class=\"w-8 h-8 rounded overflow-hidden flex-shrink-0 mt-1 border border-outline-variant\">\n<img class=\"w-full h-full object-cover\" data-alt=\"A professional headshot of an industrial engineer in a modern manufacturing setting, clean bright lighting, corporate style, high quality.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCzE0_AmgWJBdXWgc3cz3rUfcto8tFiqxJxt_4KRwA9vSSUCwIW_I4MOo0B_SaKjVHMjXgRiX9SpGJLLOyq9fGvY9tG36Pbmm3wPMkW4XPG2HJS4q7I1HERYdzBzw5B0Y5LrVt3x_3VShXUvpndMfLctJugvBCfHxl4y9-6pCFli0sqCWeqSqhEv0lt95MtXVMGn2bMoVf8YXclLaqrvXA8vO0-xbS-21qgTQ87__jhStneakVMN-MSNGVcNEqzqkrVUAc6nIRbCNU\"/>\n</div>\n</div>\n<!-- AI Message Center with Actions -->\n<div class=\"flex gap-sm\">\n<div class=\"w-8 h-8 rounded bg-primary-container text-on-primary flex items-center justify-center flex-shrink-0 mt-1\">\n<span class=\"material-symbols-outlined text-sm\">psychology</span>\n</div>\n<div class=\"bg-surface-container p-sm rounded-lg rounded-tl-none border border-outline-variant max-w-[90%]\">\n<p class=\"text-body-md font-body-md text-on-surface mb-sm\">Analyzing telemetry for CNC Unit 04. I have correlated the vibration spike (2.4mm/s RMS) with the roughing cycle of Part #882-B.</p>\n<p class=\"text-body-md font-body-md text-on-surface mb-sm\">Probability of spindle bearing wear is 87%. I have loaded the 3D telemetry model on the visualizer for your review.</p>\n<div class=\"flex flex-wrap gap-sm mt-md\">\n<button class=\"flex items-center gap-xs px-sm py-xs rounded border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-primary\">\n<span class=\"material-symbols-outlined text-[16px]\">summarize</span> Generate Report\n                            </button>\n<button class=\"flex items-center gap-xs px-sm py-xs rounded border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-primary\">\n<span class=\"material-symbols-outlined text-[16px]\">build</span> Schedule Maintenance\n                            </button>\n<button class=\"flex items-center gap-xs px-sm py-xs rounded border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-primary\">\n<span class=\"material-symbols-outlined text-[16px]\">inventory_2</span> Check Spare Parts\n                            </button>\n</div>\n</div>\n</div>\n</div>\n<!-- Quick Prompts -->\n<div class=\"p-sm bg-surface-container-low border-t border-outline-variant overflow-x-auto whitespace-nowrap hide-scrollbar flex gap-sm\">\n<button class=\"inline-flex items-center gap-xs px-sm py-xs rounded-full border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-on-surface-variant whitespace-nowrap\">\n<span class=\"material-symbols-outlined text-[14px]\">query_stats</span> AI KPI Analysis\n                </button>\n<button class=\"inline-flex items-center gap-xs px-sm py-xs rounded-full border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-on-surface-variant whitespace-nowrap\">\n<span class=\"material-symbols-outlined text-[14px]\">receipt_long</span> AI Order Query\n                </button>\n<button class=\"inline-flex items-center gap-xs px-sm py-xs rounded-full border border-outline-variant bg-surface hover:bg-surface-container transition-colors text-label-md font-label-md text-on-surface-variant whitespace-nowrap\">\n<span class=\"material-symbols-outlined text-[14px]\">precision_manufacturing</span> AI Equipment Check\n                </button>\n</div>\n<!-- Input Area -->\n<div class=\"p-md bg-surface-container-lowest border-t border-outline-variant\">\n<div class=\"relative flex items-center\">\n<button class=\"absolute left-sm text-on-surface-variant hover:text-primary transition-colors p-xs\">\n<span class=\"material-symbols-outlined\">attach_file</span>\n</button>\n<input class=\"w-full pl-xl pr-xl py-sm rounded border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary bg-surface outline-none text-body-md font-body-md transition-colors\" placeholder=\"Ask the AI production assistant...\" type=\"text\"/>\n<button class=\"absolute right-sm text-on-surface-variant hover:text-primary transition-colors p-xs\">\n<span class=\"material-symbols-outlined\">mic</span>\n</button>\n<button class=\"absolute right-10 text-primary hover:text-primary-container transition-colors p-xs\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">send</span>\n</button>\n</div>\n</div>\n</div><div class=\"flex-1 flex flex-col gap-md overflow-y-auto min-w-[300px]\">\n<!-- Top Visualization Area (Large) -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-md flex-1 relative flex flex-col min-h-[400px]\">\n<div class=\"flex justify-between items-center mb-sm border-b border-outline-variant pb-sm\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface flex items-center gap-sm\">\n<span class=\"material-symbols-outlined text-primary\">view_in_ar</span>\n                        CNC Unit 04 - Live Telemetry\n                    </h3>\n<div class=\"flex gap-sm\">\n<span class=\"px-sm py-xs bg-error-container text-on-error-container text-label-md font-label-md rounded border border-[#ffb4ab]\">Anomaly Detected</span>\n<button class=\"text-on-surface-variant hover:text-primary\"><span class=\"material-symbols-outlined text-sm\">fullscreen</span></button>\n</div>\n</div>\n<!-- 3D Visualization Container Placeholder -->\n<div class=\"flex-1 bg-surface-container rounded-lg border border-outline-variant relative overflow-hidden group\">\n<div class=\"absolute inset-0 bg-gradient-to-br from-surface-variant to-surface-dim opacity-50\"></div>\n<!-- Mock 3D Wireframe / Data Vis -->\n<div class=\"absolute inset-0 flex items-center justify-center\">\n<div class=\"w-64 h-64 border border-primary/30 rounded-full animate-[spin_20s_linear_infinite] relative\">\n<div class=\"absolute inset-4 border border-secondary/20 rounded-full animate-[spin_15s_linear_infinite_reverse]\"></div>\n<div class=\"absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-32 h-48 bg-primary/10 border border-primary/50 skew-x-12 skew-y-12\"></div>\n<!-- Highlighted Anomaly Point -->\n<div class=\"absolute top-1/4 right-1/4 w-4 h-4 bg-error rounded-full animate-pulse shadow-[0_0_15px_rgba(186,26,26,0.8)]\">\n<div class=\"absolute top-0 right-0 transform translate-x-full -translate-y-full bg-surface-container-lowest border border-error text-error text-label-md font-label-md px-xs py-[2px] rounded whitespace-nowrap z-10\">\n                                    Vibration: 2.4mm/s\n                                </div>\n</div>\n</div>\n</div>\n<!-- Overlays -->\n<div class=\"absolute top-sm left-sm bg-surface-container-lowest/80 backdrop-blur border border-outline-variant p-sm rounded\">\n<p class=\"text-mono-data font-mono-data text-on-surface text-xs\">Spindle RPM: 12,500</p>\n<p class=\"text-mono-data font-mono-data text-on-surface text-xs\">Temp: 68°C</p>\n<p class=\"text-mono-data font-mono-data text-error font-bold text-xs\">Z-Axis VIB: High</p>\n</div>\n</div>\n</div>\n<!-- Bottom Row Bento -->\n<div class=\"flex gap-md h-48\">\n<!-- KPI Card -->\n<div class=\"flex-1 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-md flex flex-col\">\n<h4 class=\"text-label-md font-label-md text-on-surface-variant mb-sm uppercase tracking-wider\">Line A Efficiency</h4>\n<div class=\"flex items-end gap-sm mb-xs\">\n<span class=\"text-headline-lg font-headline-lg text-on-surface leading-none\">84.2%</span>\n<span class=\"text-label-md font-label-md text-error flex items-center\"><span class=\"material-symbols-outlined text-[16px]\">arrow_downward</span> 2.1%</span>\n</div>\n<p class=\"text-body-sm font-body-sm text-secondary mt-auto\">Impacted by CNC Unit 04 slowdown.</p>\n</div>\n<!-- Analysis Summary -->\n<div class=\"flex-[2] bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-md flex flex-col\">\n<h4 class=\"text-label-md font-label-md text-on-surface-variant mb-sm uppercase tracking-wider\">AI Insight</h4>\n<p class=\"text-body-md font-body-md text-on-surface\">Immediate maintenance on CNC Unit 04 spindle bearing is recommended to prevent critical failure. Estimated downtime: 4 hours. Spare part Bearing SKF-892 is currently in inventory (Qty: 3).</p>\n<div class=\"mt-auto flex justify-end\">\n<button class=\"bg-primary text-on-primary px-md py-sm rounded hover:bg-primary-container transition-colors text-label-md font-label-md h-[40px]\">\n                            Initiate Work Order\n                        </button>\n</div>\n</div>\n</div>\n</div>"
