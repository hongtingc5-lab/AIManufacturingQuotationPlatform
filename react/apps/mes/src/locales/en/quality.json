text-[11px] font-bold uppercase tracking-wider\">\n                                            Passed\n                                        </span>\n</td>\n<td class=\"py-[12px] px-lg text-right\">\n<button class=\"text-secondary hover:text-on-background transition-colors\"><span class=\"material-symbols-outlined text-[20px]\">visibility</span></button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n<!-- Right Actions & Rework Panel -->\n<div class=\"col-span-4 flex flex-col space-y-gutter\">\n<!-- Quick Actions -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-background mb-md border-b border-outline-variant pb-xs\">QMS Operations</h3>\n<div class=\"space-y-sm\">\n<button class=\"w-full text-left px-md py-sm bg-surface-container-low border border-transparent hover:border-outline-variant rounded-DEFAULT transition-all flex items-center justify-between group\">\n<div class=\"flex items-center\">\n<span class=\"material-symbols-outlined text-primary mr-md\">assignment_add</span>\n<span class=\"text-body-sm font-body-sm text-on-background font-medium\">Log NCMR</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-[18px]\">chevron_right</span>\n</button>\n<button class=\"w-full text-left px-md py-sm bg-surface-container-low border border-transparent hover:border-outline-variant rounded-DEFAULT transition-all flex items-center justify-between group\">\n<div class=\"flex items-center\">\n<span class=\"material-symbols-outlined text-secondary mr-md\">build</span>\n<span class=\"text-body-sm font-body-sm text-on-background font-medium\">Initiate Rework</span>\n</div>\n<span class=\"material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-[18px]\">chevron_right</span>\n</button>\n<button class=\"w-full text-left px-md py-sm bg-surface-container-low border border