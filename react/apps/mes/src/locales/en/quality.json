  "mainHtml": "<div class=\"flex justify-between items-end mb-gutter\">\n<div>\n<h2 class=\"text-headline-lg font-headline-lg text-on-background\">Quality Control Center</h2>\n<p class=\"text-body-md font-body-md text-on-surface-variant mt-xs\">Manage inspections, alert handling, and yield tracking.</p>\n</div>\n<div class=\"flex space-x-md\">\n<button class=\"h-[40px] px-lg border border-outline-variant text-on-surface rounded-DEFAULT hover:bg-surface-container-low transition-colors text-label-md font-label-md flex items-center shadow-sm\">\n<span class=\"material-symbols-outlined mr-sm text-[18px]\">history</span> Traceability Log\n                    </button>\n<button class=\"h-[40px] px-lg bg-primary text-on-primary rounded-DEFAULT hover:opacity-90 transition-opacity text-label-md font-label-md flex items-center shadow-sm\">\n<span class=\"material-symbols-outlined mr-sm text-[18px]\">add</span> New Inspection\n                    </button>\n</div>\n</div><div class=\"grid grid-cols-12 gap-gutter\">\n<!-- KPI: First Pass Yield -->\n<div class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase\">First Pass Yield (FPY)</span>\n<span class=\"material-symbols-outlined text-primary text-[24px]\">donut_large</span>\n</div>\n<div class=\"mt-md\">\n<div class=\"text-display-lg font-display-lg text-on-background\">98.4%</div>\n<div class=\"flex items-center mt-xs text-body-sm font-body-sm text-[#10B991]\">\n<span class=\"material-symbols-outlined text-[16px] mr-[2px]\">trending_up</span> +0.2% from last shift\n                        </div>\n</div>\n</div>\n<!-- KPI: Open NCMRs -->\n<div class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase\">Open NCMRs</span>\n<span class=\"material-symbols-outlined text-error text-[24px]\">warning</span>\n</div>\n<div class=\"mt-md\">\n<div class=\"text-display-lg font-display-lg text-on-background\">12</div>\n<div class=\"flex items-center mt-xs text-body-sm font-body-sm text-error\">\n<span class=\"material-symbols-outlined text-[16px] mr-[2px]\">priority_high</span> 3 require immediate action\n                        </div>\n</div>\n</div>\n<!-- KPI: Rework Rate -->\n<div class=\"col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase\">Rework Rate</span>\n<span class=\"material-symbols-outlined text-secondary text-[24px]\">build_circle</span>\n</div>\n<div class=\"mt-md\">\n<div class=\"text-display-lg font-display-lg text-on-background\">1.2%</div>\n<div class=\"flex items-center mt-xs text-body-sm font-body-sm text-on-surface-variant\">\n<span class=\"material-symbols-outlined text-[16px] mr-[2px]\">trending_flat</span> Stable against target &lt; 1.5%\n                        </div>\n</div>\n</div>\n<!-- Active Inspections Queue (Left large area) -->\n<div class=\"col-span-8 bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden flex flex-col\">\n<div class=\"p-lg border-b border-outline-variant flex justify-between items-center bg-surface-bright\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-background\">Active Inspections Queue</h3>\n<div class=\"flex space-x-sm\">\n<button class=\"text-label-md font-label-md text-secondary border border-outline-variant px-sm py-[4px] rounded-DEFAULT