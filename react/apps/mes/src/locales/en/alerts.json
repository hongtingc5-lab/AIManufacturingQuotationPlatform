e-variant rounded-full h-2\">\n<div class=\"bg-[#f59e0b] h-2 rounded-full\" style=\"width: 15%\"></div>\n</div>\n</div>\n<!-- Process -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">settings_suggest</span> Process</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">10%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-[#10b981] h-2 rounded-full\" style=\"width: 10%\"></div>\n</div>\n</div>\n<!-- System -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">admin_panel_settings</span> System</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">5%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-secondary h-2 rounded-full\" style=\"width: 5%\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- AI Insights (Spans 4) -->\n<div class=\"lg:col-span-4 bg-surface-container-lowest border border-outline-variant rounded flex flex-col relative overflow-hidden\">\n<div class=\"absolute inset-0 opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary via-transparent to-transparent\"></div>\n<div class=\"p-lg border-b border-surface-variant flex items-center gap-sm relative z-10\">\n<span class=\"material-symbols-outlined text-primary\">psychology</span>\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">AI Production Assistant</h3>\n</div>\n<div class=\"p-lg flex-1 relative z-10\">\n<p class=\"font-body-md text-body-md text-on-surface mb-md\">Anomaly detected in <strong>Line B Spindle Vibration</strong> patterns.</p>\n<div class=\"bg-surface-container-low p-md rounded border border-outline-variant mb-md\">\n<p class=\"font-body-sm text-body-sm text-on-surface-variant mb-sm\">The predictive model indicates an 87% probability of bearing failure within 4 hours if the current RPM is maintained.</p>\n<div class=\"flex items-center justify-between\">\n<span class=\"font-label-md text-label-md text-tertiary bg-tertiary-fixed px-sm py-xs rounded\">High Confidence</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">Model v4.2</span>\n</div>\n</div>\n<button class=\"w-full border border-primary text-primary hover:bg-primary-fixed transition-colors py-sm rounded font-label-md text-label-md flex justify-center items-center gap-xs h-10\">\n<span class=\"material-symbols-outlined text-[18px]\">auto_fix_high</span>\n                        Apply Suggested Compensation\n                    </button>\n</div>\n</div>\n</div><div class=\"bg-surface-container-lowest border border-outline-variant rounded overflow-hidden\">\n<div class=\"p-lg border-b border-surface-variant flex justify-between items-center bg-surface-container-low\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">Actions Required: Critical &amp; Warnings</h3>\n<div class=\"flex gap-sm\">\n<button class=\"flex items-center gap-xs px-sm py-xs border border-outline-variant rounded text-on-surface-variant hover:bg-surface-container transition-colors font-label-md text-label-md\">\n<span class=\"material-symbols-outlined text-[16px]\">filter_list</span> Filter\n                    </button>\n</div>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left border-collapse\">\n<thead>\n<tr class=\"border-b border-surface-variant\">\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">Severity</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">Time</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\"