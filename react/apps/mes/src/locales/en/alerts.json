nt-display-lg text-display-lg text-tertiary\">34</div>\n<div class=\"mt-sm font-body-sm text-body-sm text-on-surface-variant flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[16px]\">horizontal_rule</span> Steady rate\n                </div>\n</div>\n<!-- Handled -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">Resolved Today</span>\n<span class=\"material-symbols-outlined text-primary bg-primary-fixed p-xs rounded\">check_circle</span>\n</div>\n<div class=\"font-display-lg text-display-lg text-primary\">128</div>\n<div class=\"mt-sm font-body-sm text-body-sm text-on-surface-variant flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-primary text-[16px]\">trending_up</span> 94% resolution rate\n                </div>\n</div>\n<!-- System Health -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow flex flex-col justify-between\">\n<div class=\"flex justify-between items-start\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">Overall Status</span>\n<span class=\"material-symbols-outlined text-secondary text-[20px]\">router</span>\n</div>\n<div class=\"mt-auto\">\n<div class=\"flex items-center gap-sm mb-xs\">\n<div class=\"w-3 h-3 rounded-full bg-[#10B991] animate-pulse\"></div>\n<span class=\"font-headline-sm text-headline-sm text-on-surface\">Operational</span>\n</div>\n<div class=\"font-body-sm text-body-sm text-on-surface-variant\">Connectivity stable across all sectors.</div>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-gutter mb-xl\">\n<!-- Distributi