  "mainHtml": "<div class=\"flex flex-col md:flex-row md:items-end justify-between gap-md mb-lg pt-sm\">\n<div>\n<h2 class=\"text-headline-lg font-headline-lg text-on-surface\">Material Inventory</h2>\n<p class=\"text-body-md font-body-md text-on-surface-variant mt-xs\">Real-time tracking of raw materials and warehouse operations.</p>\n</div>\n<div class=\"flex gap-sm\">\n<button class=\"h-10 px-md rounded border border-outline-variant text-on-surface hover:bg-surface-container-low transition-colors flex items-center gap-xs text-label-md font-label-md bg-surface-container-lowest\">\n<span class=\"material-symbols-outlined text-[18px]\">download</span>\n                    Export Ledger\n                </button>\n<button class=\"h-10 px-md rounded bg-primary text-on-primary hover:bg-primary-container transition-colors flex items-center gap-xs text-label-md font-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">add</span>\n                    New Requisition\n                </button>\n</div>\n</div><div class=\"grid grid-cols-1 md:grid-cols-12 gap-gutter\">\n<!-- Quick Stats Row (Spans full 12 cols, grid inside) -->\n<div class=\"col-span-1 md:col-span-12 grid grid-cols-1 md:grid-cols-4 gap-gutter\">\n<!-- Stat Card 1 -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant\">Inventory Value</span>\n<span class=\"material-symbols-outlined text-primary\">account_balance_wallet</span>\n</div>\n<div>\n<div class=\"text-headline-md font-headline-md text-on-surface\">$1.24M</div>\n<div class=\"flex items-center gap-xs mt-xs text-label-md font-label-md text-primary\">\n<span class=\"material-symbols-outlined text-[14px]\">trending_up</span>\n<span>+2.4% this month</span>\n</div>\n</div>\n</div>\n<!-- Stat Card 2 -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant\">Low Inventory Alerts</span>\n<span class=\"material-symbols-outlined text-error\">warning</span>\n</div>\n<div>\n<div class=\"text-headline-md font-headline-md text-error\">12 Items</div>\n<div class=\"flex items-center gap-xs mt-xs text-label-md font-label-md text-error\">\n<span class=\"material-symbols-outlined text-[14px]\">arrow_right_alt</span>\n<span>Action required</span>\n</div>\n</div>\n</div>\n<!-- Stat Card 3 -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant\">Pending Requisitions</span>\n<span class=\"material-symbols-outlined text-secondary\">assignment</span>\n</div>\n<div>\n<div class=\"text-headline-md font-headline-md text-on-surface\">45</div>\n<div class=\"flex items-center gap-xs mt-xs text-label-md font-label-md text-secondary\">\n<span>15 urgent</span>\n</div>\n</div>\n</div>\n<!-- Stat Card 4 -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant\">Inbound Deliveries</span>\n<span class=\"material-symbols-outlined text-primary\">local_shipping</span>\n</div>\n<div>\n<div class=\"text-headline-md font-headline-md text-on-surface\">8 Expected</div>\n<div class=\"flex items-center gap-xs mt-xs text-label-md font-label-md text-secondary\">\n<span>Today</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Left Column: Key Materials & Ledger (8 cols) -->\n<div class=\"col-span-1 md:col-span-8 flex flex-col gap-gutter\">\n<!-- Stock Levels Table -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden flex flex-col\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center bg-surface-container-lowest\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Key Material Stock</h3>\n<button class=\"text-primary text-label-md font-label-md hover:underline\">View All</button>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left border-collapse\">\n<thead>\n<tr class=\"bg-surface-container text-label-md font-label-md text-on-surface-variant border-b border-outline-variant\">\n<th class=\"p-sm font-normal\">Material ID</th>\n<th class=\"p-sm font-normal\">Description</th>\n<th class=\"p-sm font-normal text-right\">Current Inventory</th>\n<th class=\"p-sm font-normal text-right\">Safety Inventory</th>\n<th class=\"p-sm font-normal text-center\">Status</th>\n</tr>\n</thead>\n<tbody class=\"text-body-sm font-body-sm text-on-surface divide-y divide-outline-variant\">\n<tr class=\"hover:bg-surface-container-low transition-colors group\">\n<td class=\"p-sm font-mono-data\">RM-AL-6061</td>\n<td class=\"p-sm\">Aluminum Extrusion 6061</td>\n<td class=\"p-sm text-right\">4,520 kg</td>\n<td class=\"p-sm text-right\">1,200 kg</td>\n<td class=\"p-sm text-center\">\n<span class=\"inline-flex items-center px-2 py-1 rounded bg-secondary-fixed text-on-primary-fixed-variant text-[10px] uppercase font-bold tracking-wider\">Optimal</span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors bg-surface-container-lowest\">\n<td class=\"p-sm font-mono-data\">RM-ST-304</td>\n<td class=\"p-sm\">Stainless Steel Beams 304</td>\n<td class=\"p-sm text-right\">850 kg</td>\n<td class=\"p-sm text-right\">1,000 kg</td>\n<td class=\"p-sm text-center\">\n<span class=\"inline-flex items-center px-2 py-1 rounded bg-error-container text-error text-[10px] uppercase font-bold tracking-wider\">Low Inventory</span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors\">\n<td class=\"p-sm font-mono-data\">RM-CU-99</td>\n<td class=\"p-sm\">Copper Wiring 99%</td>\n<td class=\"p-sm text-right\">12,400 m</td>\n<td class=\"p-sm text-right\">5,000 m</td>\n<td class=\"p-sm text-center\">\n<span class=\"inline-flex items-center px-2 py-1 rounded bg-secondary-fixed text-on-primary-fixed-variant text-[10px] uppercase font-bold tracking-wider\">Optimal</span>\n</td>\n</tr>\n<tr class=\"hover:bg-surface-container-low transition-colors bg-surface-container-lowest\">\n<td class=\"p-sm font-mono-data\">CH-RS-Epoxy</td>\n<td class=\"p-sm\">Industrial Epoxy Resin</td>\n<td class=\"p-sm text-right\">120 gal</td>\n<td class=\"p-sm text-right\">100 gal</td>\n<td class=\"p-sm text-center\">\n<span class=\"inline-flex items-center px-2 py-1 rounded bg-tertiary-fixed text-tertiary text-[10px] uppercase font-bold tracking-wider\">Warning</span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n<!-- Recent Requisitions -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md\">\n<div class=\"border-b border-outline-variant pb-sm mb-sm flex justify-between items-center\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Recent Requisitions</h3>\n<span class=\"material-symbols-outlined text-secondary cursor-pointer hover:text-primary transition-colors\">filter_list</span>\n</div>\n<ul class=\"space-y-sm\">\n<li class=\"flex justify-between items-center py-xs border-b border-surface-variant last:border-0 hover:bg-surface-container-low p-2 rounded transition-colors\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-8 h-8 rounded bg-surface-container-high flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined text-[18px]\">build</span>\n</div>\n<div>\n<div class=\"text-body-sm font-body-sm text-on-surface font-semibold\">REQ-2023-1142</div>\n<div class=\"text-label-md font-label-md text-on-surface-variant\">Line A Maintenance • RM-AL-6061 (50kg)</div>\n</div>\n</div>\n<span class=\"text-label-md font-label-md text-secondary\">2 hrs ago</span>\n</li>\n<li class=\"flex justify-between items-center py-xs border-b border-surface-variant last:border-0 hover:bg-surface-container-low p-2 rounded transition-colors\">\n<div class=\"flex items-center gap-md\">\n<div class=\"w-8 h-8 rounded bg-surface-container-high flex items-center justify-center text-secondary\">\n<span class=\"material-symbols-outlined text-[18px]\">precision_manufacturing</span>\n</div>\n<div>\n<div class=\"text-body-sm font-body-sm text-on-surface font-semibold\">REQ-2023-1141</div>\n<div class=\"text-label-md font-label-md text-on-surface-variant\">Assembly B • RM-CU-99 (200m)</div>\n</div>\n</div>\n<span class=\"text-label-md font-label-md text-secondary\">5 hrs ago</span>\n</li>\n</ul>\n</div>\n</div>\n<!-- Right Column: Warehouse Zone & Alerts (4 cols) -->\n<div class=\"col-span-1 md:col-span-4 flex flex-col gap-gutter\">\n<!-- Warehouse Layout Minimized -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant flex flex-col h-64 overflow-hidden relative\">\n<div class=\"absolute top-0 left-0 right-0 p-md z-10 flex justify-between items-start bg-gradient-to-b from-surface-container-lowest/90 to-transparent\">\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface shadow-sm\">Warehouse Layout</h3>\n<button class=\"bg-surface-container-lowest border border-outline-variant rounded px-2 py-1 text-label-md font-label-md shadow-sm\">Expand</button>\n</div>\n<!-- Placeholder for interactive warehouse map -->\n<div class=\"w-full h-full bg-surface-container relative\" data-alt=\"A clean, minimalist 2D architectural blueprint map of a modern industrial warehouse layout, top-down view, showing distinct storage zones, aisles, and loading docks. Rendered in a high-tech UI style with stark white background, crisp light gray grid lines, and subtle blue and orange zone highlights. The aesthetic is precise, corporate, and data-driven.\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBH9YxEat45b0xO1g26ozpThCh-TxsAUtN-pSs6VHYM3jhA0VMuB_EXwhQ0mF2Xy9sVTazQxPmTCuOVoT7dLdEtVpJKJbVW3G7ZJ0rU6MZN_drLdxF_RHJN64fvnhrrLq_nPjLwxz69ewQaFjy8aNbA1FY6ZGDdBStz4kJ_zFkA9Smi4VGgN3lFLvFRFiuQf3VZ0_3x1fnupFPc1uMJQjkzO-0voBuPoQ8jibyTZ0bhiGxYK7IYodH1q6DoFZFnn4aOKKa0KJw6xow'); background-size: cover; background-position: center;\">\n<!-- Simulated heat map overlays -->\n<div class=\"absolute top-1/4 left-1/4 w-12 h-12 bg-primary/20 border border-primary/50 rounded animate-pulse\"></div>\n<div class=\"absolute bottom-1/3 right-1/3 w-16 h-8 bg-error/20 border border-error/50 rounded\"></div>\n</div>\n</div>\n<!-- Inventory Alerts -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-md flex-1\">\n<div class=\"border-b border-outline-variant pb-sm mb-sm flex items-center gap-sm\">\n<span class=\"material-symbols-outlined text-error\">notifications_active</span>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Critical Alerts</h3>\n</div>\n<div class=\"space-y-sm mt-md\">\n<div class=\"p-sm bg-error-container border border-error/20 rounded-lg flex items-start gap-sm\">\n<span class=\"material-symbols-outlined text-error text-[20px] mt-0.5\">warning</span>\n<div>\n<div class=\"text-body-sm font-body-sm font-semibold text-on-error-container\">Stockout Risk: RM-ST-304</div>\n<div class=\"text-label-md font-label-md text-on-error-container/80 mt-1\">Stainless Steel Beams 304 are below safety stock. Production Line C may be impacted in 48 hours.</div>\n</div>\n</div>\n<div class=\"p-sm bg-tertiary-fixed border border-tertiary/20 rounded-lg flex items-start gap-sm\">\n<span class=\"material-symbols-outlined text-tertiary text-[20px] mt-0.5\">info</span>\n<div>\n<div class=\"text-body-sm font-body-sm font-semibold text-on-tertiary-fixed\">Delivery Delay: Inbound-882</div>\n<div class=\"text-label-md font-label-md text-on-tertiary-fixed/80 mt-1\">Supplier notified 2-day delay for Industrial Epoxy Resin delivery.</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>"
