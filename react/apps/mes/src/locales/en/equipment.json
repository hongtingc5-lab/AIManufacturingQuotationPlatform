  "mainHtml": "<div class=\"flex flex-col md:flex-row md:items-end justify-between gap-md mb-gutter\">\n<div>\n<h1 class=\"text-headline-lg font-headline-lg text-on-surface mb-xs\">Equipment Operations Overview</h1>\n<p class=\"text-body-md font-body-md text-on-surface-variant\">Unified visibility into equipment status, telemetry, maintenance plans, and failure logs.</p>\n</div>\n<div class=\"flex flex-wrap gap-sm\">\n<button class=\"h-10 px-md flex items-center gap-xs rounded-lg border border-outline-variant text-on-surface bg-surface-container-lowest hover:bg-surface-container-low transition-colors text-label-md font-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">filter_list</span>\n                    Filter View\n                </button>\n<button class=\"h-10 px-md flex items-center gap-xs rounded-lg bg-primary text-on-primary hover:opacity-90 transition-opacity shadow-sm text-label-md font-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">add</span>\n                    Register Equipment\n                </button>\n</div>\n</div><div class=\"grid grid-cols-1 md:grid-cols-4 gap-gutter mb-gutter\">\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">Average OEE</span>\n<span class=\"material-symbols-outlined text-primary\">analytics</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">87.4%</span>\n<span class=\"text-body-sm font-body-sm text-[#10B991] flex items-center\"><span class=\"material-symbols-outlined text-[14px]\">arrow_upward</span> 2.1%</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">Online Equipment</span>\n<span class=\"material-symbols-outlined text-primary\">precision_manufacturing</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">42</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">/ 45 Total</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">Critical Alerts</span>\n<span class=\"material-symbols-outlined text-error\">warning</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-error\">2</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">Requires attention</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">Scheduled Maintenance</span>\n<span class=\"material-symbols-outlined text-primary\">build</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">14</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">Next 48 Hours</span>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 xl:grid-cols-12 gap-gutter\">\n<!-- Left Panel: Live Asset Status (Bento Grid) -->\n<div class=\"xl:col-span-8 space-y-gutter\">\n<h2 class=\"text-headline-sm font-headline-sm text-on-surface border-b border-outline-variant pb-xs\">Equipment Live Grid</h2>\n<div class=\"grid grid-cols-1 lg:grid-cols-2 gap-md\">\n<!-- Machine Card