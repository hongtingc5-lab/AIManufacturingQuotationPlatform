  "mainHtml": "<div class=\"flex justify-between items-end mb-lg\">\n<div>\n<h2 class=\"font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface\">数据分析</h2>\n<p class=\"font-body-md text-body-md text-on-surface-variant mt-xs\">实时工业绩效指标总览。</p>\n</div>\n<div class=\"flex gap-sm\">\n<select class=\"border border-outline-variant rounded-DEFAULT bg-surface-container-lowest px-md py-sm font-body-sm text-body-sm h-10\">\n<option>近 7 天</option>\n<option>近 30 天</option>\n<option>本季度</option>\n</select>\n<button class=\"bg-primary-container text-on-primary-container px-md py-sm rounded-DEFAULT font-label-md text-label-md h-10 flex items-center gap-xs hover:opacity-90 transition-opacity\">\n<span class=\"material-symbols-outlined text-[18px]\">download</span> 导出报表\n                    </button>\n</div>\n</div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-gutter\">\n<!-- Top KPIs - Span 12 -->\n<div class=\"col-span-1 md:col-span-2 lg:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-md\">\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-lg p-md flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex justify-between items-start text-on-surface-variant mb-sm\">\n<span class=\"font-label-md text-label-md\">OEE 综合效率</span>\n<span class=\"material-symbols-outlined text-primary\">speed</span>\n</div>\n<div>\n<div class=\"font-headline-lg text-headline-lg text-on-surface\">82.4%</div>\n<div class=\"font-body-sm text-body-sm text-[var(--tw-colors-success, #10B991)] flex items-center mt-xs\">\n<span class=\"material-symbols-outlined text-[16px]\">trending_up</span> +1.2%\n                            </div>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-lg p-md flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex justify-between items-start text-on-surface-variant