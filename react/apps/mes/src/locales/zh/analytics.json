ded-lg flex flex-col h-[400px]\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">生产趋势 (生产制造 Trends)</h3>\n<span class=\"material-symbols-outlined text-on-surface-variant\">more_vert</span>\n</div>\n<div class=\"flex-1 p-md relative\">\n<canvas id=\"productionTrendChart\"></canvas>\n</div>\n</div>\n<!-- OEE分析 - Gauge/Doughnut (Span 4) -->\n<div class=\"col-span-1 md:col-span-2 lg:col-span-4 bg-surface-container-lowest border border-outline-variant rounded-lg flex flex-col h-[400px]\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">OEE分析 (OEE分析)</h3>\n<span class=\"material-symbols-outlined text-on-surface-variant\">more_vert</span>\n</div>\n<div class=\"flex-1 p-md relative flex flex-col items-center justify-center\">\n<div class=\"w-[200px] h-[200px] relative\">\n<canvas id=\"oeeChart\"></canvas>\n<div class=\"absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-4\">\n<span class=\"font-headline-lg text-headline-lg text-on-surface\">82%</span>\n<span class=\"font-label-md text-label-md text-on-surface-variant\">整体</span>\n</div>\n</div>\n<div class=\"flex w-full justify-between mt-lg px-md font-mono-data text-mono-data\">\n<div class=\"text-center\"><div class=\"text-primary font-bold\">88%</div><div class=\"text-[10px] text-on-surface-variant\">可动率</div></div>\n<div class=\"text-center\"><div class=\"text-tertiary-container font-bold\">75%</div><div class=\"text-[10px] text-on-surface-variant\">性能</div></div>\n<div class=\"text-center\"><div class=\"text-surface-tint font-bold\">96%</div><div class=\"text-[10px] text-on-surface-variant\">质量</div></div>\n</div>\n</div>\n</div>\n<!-- 良率分析 - Bar/Pareto (Span 6) -->\n<div class=\"col-span-1 md:col-span-1 lg:col-span-6 bg-surface-container-lowest border border-outline-variant rounded-lg flex flex-col h-[350px]\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">良率分析 (良率分析)</h3>\n<span class=\"material-symbols-outlined text-on-surface-variant\">filter_list</span>\n</div>\n<div class=\"flex-1 p-md relative\">\n<canvas id=\"yieldChart\"></canvas>\n</div>\n</div>\n<!-- 设备 Utilization (Span 6) -->\n<div class=\"col-span-1 md:col-span-1 lg:col-span-6 bg-surface-container-lowest border border-outline-variant rounded-lg flex flex-col h-[350px]\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">设备利用率 (设备 Utilization)</h3>\n<span class=\"material-symbols-outlined text-on-surface-variant\">precision_manufacturing</span>\n</div>\n<div class=\"flex-1 p-md relative\">\n<canvas id=\"utilizationChart\"></canvas>\n</div>\n</div>\n</div>"
