  "mainHtml": "<div class=\"flex flex-col md:flex-row md:items-end justify-between gap-md mb-gutter\">\n<div>\n<h1 class=\"text-headline-lg font-headline-lg text-on-surface mb-xs\">设备运行总览</h1>\n<p class=\"text-body-md font-body-md text-on-surface-variant\">统一查看设备状态、遥测指标、保养计划与故障记录。</p>\n</div>\n<div class=\"flex flex-wrap gap-sm\">\n<button class=\"h-10 px-md flex items-center gap-xs rounded-lg border border-outline-variant text-on-surface bg-surface-container-lowest hover:bg-surface-container-low transition-colors text-label-md font-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">filter_list</span>\n                    筛选视图\n                </button>\n<button class=\"h-10 px-md flex items-center gap-xs rounded-lg bg-primary text-on-primary hover:opacity-90 transition-opacity shadow-sm text-label-md font-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">add</span>\n                    新增设备\n                </button>\n</div>\n</div><div class=\"grid grid-cols-1 md:grid-cols-4 gap-gutter mb-gutter\">\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">设备 OEE 均值</span>\n<span class=\"material-symbols-outlined text-primary\">analytics</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">87.4%</span>\n<span class=\"text-body-sm font-body-sm text-[#10B991] flex items-center\"><span class=\"material-symbols-outlined text-[14px]\">arrow_upward</span> 2.1%</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">在线设备</span>\n<span class=\"material-symbols-outlined text-primary\">precision_manufacturing</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">42</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">/ 45 台</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">关键告警</span>\n<span class=\"material-symbols-outlined text-error\">warning</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-error\">2</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">需立即处理</span>\n</div>\n</div>\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-lg flex flex-col justify-between\">\n<div class=\"flex justify-between items-start mb-sm\">\n<span class=\"text-label-md font-label-md text-on-surface-variant uppercase tracking-wider\">计划保养</span>\n<span class=\"material-symbols-outlined text-primary\">build</span>\n</div>\n<div class=\"flex items-baseline gap-sm\">\n<span class=\"text-display-lg font-display-lg text-on-surface\">14</span>\n<span class=\"text-body-md font-body-md text-on-surface-variant\">未来 48 小时</span>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 xl:grid-cols-12 gap-gutter\">\n<!-- Left Panel: Live Asset 状态 (Bento Grid) -->\n<div class=\"xl:col-span-8 space-y-gutter\">\n<h2 class=\"text-headline-sm font-headline-sm text-on-surface border-b border-outline-variant pb-xs\">设备实时看板</h2>\n<div class=\"grid grid-cols-1 lg:grid-cols-2 gap-md\">\n<!-- Machine Card 1: 运行中 -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-md hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">CNC-Milling-01</h3>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">A区 · 重型加工</p>\n</div>\n<span class=\"px-2 py-1 rounded bg-[#E6F4EA] text-[#137333] text-label-md font-label-md flex items-center gap-xs\">\n<span class=\"w-2 h-2 rounded-full bg-[#137333]\"></span> 运行中\n                            </span>\n</div>\n<div class=\"grid grid-cols-2 gap-sm mb-md\">\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">主轴温度</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface\">62.4 °C</span>\n</div>\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">电机负载</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface\">78%</span>\n</div>\n</div>\n<div class=\"w-full h-1 bg-surface-variant rounded-full overflow-hidden\">\n<div class=\"h-full bg-primary w-[78%]\"></div>\n</div>\n</div>\n<!-- Machine Card 2: Warning -->\n<div class=\"bg-surface-container-lowest border border-[#F59E0B] rounded-xl p-md shadow-[0px_0px_10px_-2px_rgba(245,158,11,0.2)]\">\n<div class=\"flex justify-between items-start mb-md\">\n<div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Laser-Cutter-04</h3>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">C区 · 精密加工</p>\n</div>\n<span class=\"px-2 py-1 rounded bg-[#FEF3C7] text-[#B45309] text-label-md font-label-md flex items-center gap-xs\">\n<span class=\"w-2 h-2 rounded-full bg-[#B45309] animate-pulse\"></span> 预警\n                            </span>\n</div>\n<div class=\"grid grid-cols-2 gap-sm mb-md\">\n<div class=\"bg-[#FEF3C7]/30 p-sm rounded-lg border border-[#F59E0B]/30\">\n<span class=\"text-label-md font-label-md text-[#B45309] block mb-1\">冷却压力</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-[#B45309]\">2.1 bar <span class=\"material-symbols-outlined text-[14px] align-middle\">arrow_downward</span></span>\n</div>\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">振动值</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface\">0.4 mm/s</span>\n</div>\n</div>\n<div class=\"text-label-md font-label-md text-error flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-[16px]\">info</span>\n                            冷却压力持续低于标准阈值，请尽快检修。\n                        </div>\n</div>\n<!-- Machine Card 3: 待机 -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-md opacity-80 hover:opacity-100 transition-opacity\">\n<div class=\"flex justify-between items-start mb-md\">\n<div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Robotic-Arm-Assembly-2</h3>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">B线 · 装配单元</p>\n</div>\n<span class=\"px-2 py-1 rounded bg-surface-container text-on-surface-variant text-label-md font-label-md flex items-center gap-xs\">\n<span class=\"w-2 h-2 rounded-full bg-outline\"></span> 待机\n                            </span>\n</div>\n<div class=\"grid grid-cols-2 gap-sm mb-md\">\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">关节平均温度</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface-variant\">31.0 °C</span>\n</div>\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">瞬时功耗</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface-variant\">0.5 kW</span>\n</div>\n</div>\n<p class=\"text-label-md font-label-md text-on-surface-variant italic\">等待物料上料。</p>\n</div>\n<!-- Machine Card 4: 运行中 -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl p-md hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Stamp-Press-09</h3>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">D区 · 成形压制</p>\n</div>\n<span class=\"px-2 py-1 rounded bg-[#E6F4EA] text-[#137333] text-label-md font-label-md flex items-center gap-xs\">\n<span class=\"w-2 h-2 rounded-full bg-[#137333]\"></span> 运行中\n                            </span>\n</div>\n<div class=\"grid grid-cols-2 gap-sm mb-md\">\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">循环次数</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface\">12,450</span>\n</div>\n<div class=\"bg-surface-container-low p-sm rounded-lg border border-outline-variant/50\">\n<span class=\"text-label-md font-label-md text-on-surface-variant block mb-1\">冲压力</span>\n<span class=\"text-headline-sm font-headline-sm font-mono-data text-on-surface\">240 kN</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- Right Panel: 设备维护 & Logs -->\n<div class=\"xl:col-span-4 space-y-gutter\">\n<!-- 设备维护 Plan Card -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded-xl flex flex-col h-fit\">\n<div class=\"p-md border-b border-outline-variant flex justify-between items-center bg-surface-container-low/50 rounded-t-xl\">\n<h2 class=\"text-headline-sm font-headline-sm text-on-surface flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-primary\">calendar_clock</span>\n                     