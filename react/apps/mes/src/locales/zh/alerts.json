  "mainHtml": "<div class=\"flex justify-between items-end mb-lg\">\n<div>\n<h2 class=\"font-headline-lg text-headline-lg text-on-surface\">系统告警总览</h2>\n<p class=\"font-body-md text-body-md text-on-surface-variant mt-xs\">实时监控制造域内的全部业务状态。</p>\n</div>\n<button class=\"bg-primary-container text-on-primary flex items-center gap-sm px-md py-sm rounded hover:bg-primary transition-colors h-10 font-label-md text-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">rule</span>\n                Acknowledge All\n            </button>\n</div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-xl\">\n<!-- Critical -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">关键告警</span>\n<span class=\"material-symbols-outlined text-error bg-error-container p-xs rounded\">error</span>\n</div>\n<div class=\"font-display-lg text-display-lg text-error\">12</div>\n<div class=\"mt-sm font-body-sm text-body-sm text-on-surface-variant flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-error text-[16px]\">trending_up</span> +3 since last shift\n                </div>\n<div class=\"absolute bottom-0 left-0 h-1 bg-error w-full\"></div>\n</div>\n<!-- Warnings -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">活跃告警</span>\n<span class=\"material-symbols-outlined text-tertiary bg-tertiary-container p-xs rounded\">warning</span>\n</div>\n<div class=\"font-display-lg text-display-lg text-tertiary\">34</div>\n<div class=\"mt-sm font-body-sm text-body-sm text-on-surface-variant flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[16px]\">horizontal_rule</span> Steady rate\n                </div>\n</div>\n<!-- Handled -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow\">\n<div class=\"flex justify-between items-start mb-md\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">今日已关闭</span>\n<span class=\"material-symbols-outlined text-primary bg-primary-fixed p-xs rounded\">check_circle</span>\n</div>\n<div class=\"font-display-lg text-display-lg text-primary\">128</div>\n<div class=\"mt-sm font-body-sm text-body-sm text-on-surface-variant flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-primary text-[16px]\">trending_up</span> 94% resolution rate\n                </div>\n</div>\n<!-- 系统 Health -->\n<div class=\"bg-surface-container-lowest border border-outline-variant rounded p-lg relative overflow-hidden group hover:shadow-[0px_4px_6px_-1px_rgba(0,0,0,0.05)] transition-shadow flex flex-col justify-between\">\n<div class=\"flex justify-between items-start\">\n<span class=\"font-label-md text-label-md text-on-surface-variant\">整体 状态</span>\n<span class=\"material-symbols-outlined text-secondary text-[20px]\">router</span>\n</div>\n<div class=\"mt-auto\">\n<div class=\"flex items-center gap-sm mb-xs\">\n<div class=\"w-3 h-3 rounded-full bg-[#10B991] animate-pulse\"></div>\n<span class=\"font-headline-sm text-headline-sm text-on-surface\">运行正常</span>\n</div>\n<div class=\"font-body-sm text-body-sm text-on-surface-variant\">Connectivity stable across all sectors.</div>\n</div>\n</div>\n</div><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-gutter mb-xl\">\n<!-- Distribution Chart (Spans 8) -->\n<div class=\"lg:col-span-8 bg-surface-container-lowest border border-outline-variant rounded flex flex-col\">\n<div class=\"p-lg border-b border-surface-variant flex justify-between items-center\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">按业务域划分的告警分布</h3>\n<button class=\"text-secondary hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-[20px]\">more_vert</span>\n</button>\n</div>\n<div class=\"p-lg flex-1 flex flex-col justify-center\">\n<!-- Pure CSS Horizontal Bar Chart -->\n<div class=\"space-y-md\">\n<!-- 设备 -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">home_repair_service</span> 设备</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">42%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-primary h-2 rounded-full\" style=\"width: 42%\"></div>\n</div>\n</div>\n<!-- 质量 -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">verified_user</span> 质量</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">28%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-[#8b5cf6] h-2 rounded-full\" style=\"width: 28%\"></div>\n</div>\n</div>\n<!-- 库存 -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">inventory_2</span> 库存</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">15%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-[#f59e0b] h-2 rounded-full\" style=\"width: 15%\"></div>\n</div>\n</div>\n<!-- Process -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">settings_suggest</span> Process</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">10%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-[#10b981] h-2 rounded-full\" style=\"width: 10%\"></div>\n</div>\n</div>\n<!-- 系统 -->\n<div>\n<div class=\"flex justify-between mb-xs\">\n<span class=\"font-label-md text-label-md text-on-surface flex items-center gap-xs\"><span class=\"material-symbols-outlined text-[16px] text-secondary\">admin_panel_settings</span> 系统</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">5%</span>\n</div>\n<div class=\"w-full bg-surface-variant rounded-full h-2\">\n<div class=\"bg-secondary h-2 rounded-full\" style=\"width: 5%\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!-- AI洞察s (Spans 4) -->\n<div class=\"lg:col-span-4 bg-surface-container-lowest border border-outline-variant rounded flex flex-col relative overflow-hidden\">\n<div class=\"absolute inset-0 opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary via-transparent to-transparent\"></div>\n<div class=\"p-lg border-b border-surface-variant flex items-center gap-sm relative z-10\">\n<span class=\"material-symbols-outlined text-primary\">psychology</span>\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">AI生产助手</h3>\n</div>\n<div class=\"p-lg flex-1 relative z-10\">\n<p class=\"font-body-md text-body-md text-on-surface mb-md\">Anomaly detected in <strong>Line B Spindle Vibration</strong> patterns.</p>\n<div class=\"bg-surface-container-low p-md rounded border border-outline-variant mb-md\">\n<p class=\"font-body-sm text-body-sm text-on-surface-variant mb-sm\">预测模型显示：若当前转速维持不变，4 小时内发生轴承故障的概率为 87%。</p>\n<div class=\"flex items-center justify-between\">\n<span class=\"font-label-md text-label-md text-tertiary bg-tertiary-fixed px-sm py-xs rounded\">高 置信度</span>\n<span class=\"font-mono-data text-mono-data text-on-surface-variant\">模型 v4.2</span>\n</div>\n</div>\n<button class=\"w-full border border-primary text-primary hover:bg-primary-fixed transition-colors py-sm rounded font-label-md text-label-md flex justify-center items-center gap-xs h-10\">\n<span class=\"material-symbols-outlined text-[18px]\">auto_fix_high</span>\n                        Apply Suggested Compensation\n                    </button>\n</div>\n</div>\n</div><div class=\"bg-surface-container-lowest border border-outline-variant rounded overflow-hidden\">\n<div class=\"p-lg border-b border-surface-variant flex justify-between items-center bg-surface-container-low\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">操作 Required: Critical &amp; Warnings</h3>\n<div class=\"flex gap-sm\">\n<button class=\"flex items-center gap-xs px-sm py-xs border border-outline-variant rounded text-on-surface-variant hover:bg-surface-container transition-colors font-label-md text-label-md\">\n<span class=\"material-symbols-outlined text-[16px]\">filter_list</span> Filter\n                    </button>\n</div>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left border-collapse\">\n<thead>\n<tr class=\"border-b border-surface-variant\">\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">严重级别</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">时间</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">业务域 / 来源</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold\">描述</th>\n<th class=\"px-lg py-md font-label-md text-label-md text-on-surface-variant font-semibold text-right\">操作</th>\n</tr>\n</thead>\n<tbody class=\"font-body-sm text-body-sm\">\n<!--