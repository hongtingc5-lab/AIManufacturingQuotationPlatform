pacity-100 transition-opacity\">\n<button class=\"p-2 text-on-surface-variant hover:text-primary\"><span class=\"material-symbols-outlined text-[20px]\">edit</span></button>\n<button class=\"p-2 text-on-surface-variant hover:text-error\"><span class=\"material-symbols-outlined text-[20px]\">delete</span></button>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Shipping Address -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"shipping\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">Shipping Addresses</h3>\n<button class=\"flex items-center gap-1.5 px-3 py-1.5 text-primary font-label-md hover:bg-surface transition-colors rounded-lg\">\n<span class=\"material-symbols-outlined text-[18px]\">location_on</span>\n                                Add New\n                            </button>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"p-5 border border-primary-fixed bg-surface-container-low rounded-xl relative\">\n<span class=\"absolute top-4 right-4 bg-primary-container text-white text-[10px] px-2 py-0.5 rounded font-bold\">DEFAULT</span>\n<div class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-primary mt-1\">home_pin</span>\n<div>\n<p class=\"font-label-md text-on-surface\">Precision Manufacturing Park, No. 888 Innovation Drive</p>\n<p class=\"text-on-surface-variant body-sm\">Pudong New Area, Shanghai, China</p>\n<p class=\"mt-2 text-on-surface font-label-md\">Zhang Wei | +86 138-xxxx-8888</p>\n</div>\n</div>\n<div class=\"mt-4 pt-4 border-t border-outline-variant flex gap-4\">\n<button class=\"text-[12px] font-bold text-primary hover:underline\">Edit Address</button>\n<button class=\"text-[12px] font-bold text-error hover:underline\">Delete</button>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Invoice Management -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"invoice\">\n<div class=\"p-6 border-b border-outline-variant\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">Invoice Management</h3>\n</div>\n<div class=\"p-8 grid grid-cols-1 md:grid-cols-2 gap-6\">\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">Company Name</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none\" type=\"text\" value=\"Industrial Automation Solutions Ltd.\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">Tax Identification Number</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none\" type=\"text\" value=\"91310115MA1Kxxxxxx\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">Invoice Type</label>\n<select class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none bg-white\">\n<option>VAT Special Invoice</option>\n<option>VAT Ordinary Invoice</option>\n<option>Electronic Invoice</option>\n</select>\n</div>\n<div class=\"md:col-span-2 mt-4 flex justify-end\">\n<button class=\"px-8 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-colors shadow-sm\">Update Invoice Details</button>\n</div>\n</div>\n</section>\n<!-- Section: Enterprise Certification -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"certification\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">Enterprise Certification</h3>\n<div class=\"flex items-center gap-2 px-3 py-1 bg-green-100 text-green-700 rounded-full\">\n<span class=\"material-symbols-outlined text-[18px]\" style=\"font-variation-settings: 'FILL' 1;\">verified</span>\n<span class=\"text-[12px] font-bold\">Certified</span>\n</div>\n</div>\n<div class=\"p-8\">\n<div class=\"bg-surface-container-low p-6 rounded-xl border-l-4 border-green-500\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">Company Entity</p>\n<p class=\"font-headline-sm text-on-surface\">Industrial Automation Solutions Ltd.</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">Social Credit Code</p>\n<p class=\"font-label-md text-on-surface\">91310115MA1K7Y7G09</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">Verification Date</p>\n<p class=\"font-label-md text-on-surface\">2023-11-15</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">Account Tier</p>\n<p class=\"font-label-md text-primary font-bold\">Enterprise Platinum</p>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Security Settings -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"security\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">Security Settings</h3>\n<span class=\"material-symbols-outlined text-outline\">security</span>\n</div>\n<div class=\"p-8\">\n<div class=\"space-y-6\">\n<div class=\"flex items-center justify-between p-4 bg-surface rounded-xl border border-outline-variant\">\n<div class=\"flex items-center gap-4\">\n<div class=\"p-2 bg-primary-fixed rounded-lg\"><span class=\"material-symbols-outlined text-primary\">lock</span></div>\n<div>\n<p class=\"font-label-md text-on-surface\">Login Password</p>\n<p class=\"text-[12px] text-on-surface-variant\">Last changed 45 days ago</p>\n</div>\n</div>\n<button cla