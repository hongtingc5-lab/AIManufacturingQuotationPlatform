  "mainHtml": "<nav class=\"flex items-center space-x-2 mb-4 text-on-surface-variant\">\n<a class=\"font-label-md text-label-md hover:text-primary transition-colors\" href=\"/orders\">Order Center</a>\n<span class=\"material-symbols-outlined text-sm\">chevron_right</span>\n<a class=\"font-label-md text-label-md hover:text-primary transition-colors\" href=\"/quotes/detail\">Quotation Details</a>\n<span class=\"material-symbols-outlined text-sm\">chevron_right</span>\n<span class=\"font-label-md text-label-md text-primary font-semibold\">Edit Quote Requirements</span>\n</nav><div class=\"mb-6\">\n<h1 class=\"font-headline-lg text-headline-lg text-on-surface\">Edit Quote Requirements</h1>\n<p class=\"text-body-sm text-on-surface-variant mt-1\">housing_v4_final.step • Quote PRJ-20240519-0042 • Last updated: 10 minutes ago</p>\n</div><div class=\"grid grid-cols-12 gap-6 items-start\">\n<!-- Left Column: Config -->\n<div class=\"col-span-12 lg:col-span-8 flex flex-col gap-6\">\n<!-- 3D Visualization Area -->\n<div class=\"token-card overflow-hidden shadow-sm flex flex-col\">\n<div class=\"p-4 border-b border-outline-variant flex justify-between items-center bg-white\">\n<div class=\"flex items-center gap-3\">\n<span class=\"material-symbols-outlined text-primary\">view_in_ar</span>\n<div>\n<p class=\"text-label-md font-bold\">3D Model Preview</p>\n<p class=\"text-[12px] text-on-surface-variant\">Housing_Bracket_V2.step (24.5 MB)</p>\n</div>\n</div>\n<div class=\"flex gap-2\">\n<button class=\"p-2 hover:bg-white rounded-lg transition-colors border border-transparent hover:border-outline-variant\">\n<span class=\"material-symbols-outlined text-[20px]\">zoom_in</span>\n</button>\n<button class=\"p-2 hover:bg-white rounded-lg transition-colors border border-transparent hover:border-outline-variant\">\n<span class=\"material-symbols-outlined text-[20px]\">refresh</span>\n</button>\n<button class=\"p-2 hover:bg-white rounded-lg transition-colors border border-transparent hover:border-outline-variant\">\n<span class=\"material-symbols-outlined text-[20px]\">fullscreen</span>\n</button>\n</div>\n</div>\n<div class=\"relative h-[400px] bg-[#f8fafc] flex items-center justify-center\">\n<!-- Simulated 3D View -->\n<div class=\"absolute inset-0 opacity-10 pointer-events-none\" style=\"background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 20px 20px;\"></div>\n<img class=\"w-3/4 max-h-[340px] object-contain drop-shadow-2xl\" data-alt=\"A highly detailed close-up of a complex mechanical aluminum part with multiple holes and smooth CNC machined surfaces. The part is set against a clean, minimalist studio background with soft technical lighting that highlights the metallic texture and precise edges. The style is professional and industrial, emphasizing quality and accuracy.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB33esK9AzJoZF8H-6LhwD0_BYHWoLew1j6PSdHGS6ZtLtLej21Ct_yIlHZ4Ed-qb_foGiR5vvLYXjMyQCeyLOc0HGGt8t4DIiNtLbd9PrcTe82CZsvgwHg0HnYl90guBb93ZvDHod9jlyeTULUhIg7ix6hSG6lAcIiWCtA2alraMZTPjt9jczRtuQirjcojB-y8OCt4cRcxNTVYWSxZ3kHb6RuCudlDUC6JQdkXULP9bWiflk6b9gTBm2RfObZ9XuQYDLt_cHlygI\"/>\n<!-- Metadata Overlay -->\n<div class=\"absolute bottom-4 left-4 glass-panel px-4 py-3 rounded-lg flex flex-col gap-1\">\n<div class=\"flex justify-between gap-8\">\n<span class=\"text-[12px] text-on-surface-variant\">Overall Dimensions</span>\n<span class=\"text-[12px] font-bold\">120 x 85 x 45 mm</span>\n</div>\n<div class=\"flex justify-between gap-8\">\n<span class=\"text-[12px] text-on-surface-variant\">Volume</span>\n<span class=\"text-[12px] font-bold\">142.5 cm³</span>\n</div>\n<div class=\"flex justify-between gap-8\">\n<span class=\"text-[12px] text-on-surface-variant\">Manufacturability Score</span>\n<span class=\"text-[12px] font-bold text-success text-green-600\">98% (Excellent)</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Form Sections -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm p-6 flex flex-col gap-8\">\n<!-- Manufacturing Process -->\n<section class=\"flex flex-col gap-4\">\n<div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-3\">\n<h3 class=\"text-label-md font-bold flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">precision_manufacturing</span>\n                            Manufacturing Process\n                        </h3>\n<button class=\"inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-outline-variant bg-white text-label-md hover:border-primary hover:text-primary transition-all self-start md:self-auto\" id=\"ai-process-recommend\" type=\"button\">\n<span class=\"material-symbols-outlined text-[18px]\">auto_awesome</span>\n<span>AI Recommend</span>\n</button>\n</div>\n<div class=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\n<button class=\"process-option is-active\" data-base-price=\"1850\" data-process-id=\"5axis\" data-process-name=\"CNC 5-Axis Milling\" data-quote-mode=\"standard\" type=\"button\">\n<span class=\"material-symbols-outlined text-primary text-[32px]\">settings_input_component</span>\n<span class=\"text-label-md font-bold\">CNC 5-Axis Milling</span>\n</button>\n<button class=\"process-option\" data-base-price=\"1680\" data-process-id=\"3axis\" data-process-name=\"CNC 3-Axis Milling\" data-quote-mode=\"standard\" type=\"button\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[32px]\">settings_accessibility</span>\n<span class=\"text-label-md\">CNC 3-Axis Milling</span>\n</button>\n<button class=\"process-option\" data-base-price=\"1420\" data-process-id=\"turning\" data-process-name=\"CNC Turning\" data-quote-mode=\"standard\" type=\"button\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[32px]\">rebase_edit</span>\n<span class=\"text-label-md\">CNC Turning</span>\n</button>\n<button class=\"process-option\" data-base-price=\"1570\" data-process-id=\"wirecut\" data-process-name=\"Wire EDM\" data-quote-mode=\"standard\" type=\"button\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[32px]\">layers</span>\n<span class=\"text-label-md\">Wire EDM</span>\n</button>\n<button class=\"process-option\" data-base-price=\"manual\" data-process-id=\"other\" data-process-name=\"Other Process\" data-quote-mode=\"manual\" type=\"button\">\n<span class=\"material-symbols-outlined text-on-surface-variant text-[32px]\">tune</span>\n<span class=\"text-label-md\">Other</span>\n<span class=\"text-[11px] text-on-surface-variant\">Enter a custom process</span>\n</button>\n</div>\n<div class=\"hidden-panel\" id=\"custom-process-panel\">\n<div class=\"section-upload-panel\">\n<label class=\"text-label-md font-bold\" for=\"custom-process-input\">Custom Process Notes</label>\n<input class=\"mt-3 w-full rounded-xl border border-outline-variant bg-white px-4 py-3 text-body-sm text-on-surface focus:border-primary focus:ring-2 focus:ring-primary/15 outline-none\" id=\"custom-process-input\" placeholder=\"For example: Wire EDM + dedicated fixture + secondary straightening\" type=\"text\"/>\n<p class=\"text-[12px] text-on-surface-variant mt-2\">If you select “Other”, the quote panel on the right will switch to “Pending manual review for final quote confirmation”.</p>\n</div>\n</div>\n</section>\n<!-- Material Selection -->\n<section class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n<div class=\"flex flex-col gap-2\">\n<label class=\"text-label-md font-bold\">Material Category</label>\n<div class=\"relative\">\n<select class=\"w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-3 text-body-sm appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none\">\n<option>Aluminum Alloys</option>\n<option>Stainless Steel</option>\n<option>Engineering Plastics</option>\n<option>Titanium Alloys</option>\n</select>\n<span class=\"material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant\">expand_more</span>\n</div>\n</div>\n<div class=\"flex flex-col gap-2\">\n<label class=\"text-label-md font-bold\">Material Grade</label>\n<div class=\"relative\">\n<select class=\"w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-3 text-body-sm appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none\">\n<option>Aluminum 6061-T6</option>\n<option>Aluminum 7075-T6</option>\n<option>Aluminum 5052</option>\n</select>\n<span class=\"material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant\">expand_more</span>\n</div>\n</div>\n</section>\n<!-- Technical Specifications -->\n<section class=\"flex flex-col gap-6\">\n<div class=\"flex flex-col gap-6\">\n<div class=\"flex flex-col gap-4\">\n<label class=\"text-label-md font-bold\">Surface Roughness (Ra)</label>\n<div class=\"flex flex-wrap gap-2\">\n<button class=\"px-4 py-2 rounded-full border border-outline-variant text-[12px] hover:border-primary hover:text-primary transition-all\">Ra 6.3μm</button>\n<button class=\"px-4 py-2 rounded-full border-2 border-primary text-primary bg-primary/5 text-[12px] font-bold\">Ra 3.2μm</button>\n<button class=\"px-4 py-2 rounded-full border border-outline-variant text-[12px] hover:border-primary hover:text-primary transition-all\">Ra 1.6μm</button>\n<button class=\"px-4 py-2 rounded-full border border-outline-variant text-[12px] hover:border-primary hover:text-primary transition-all\">Ra 0.8μm</button>\n</div>\n</div>\n<div class=\"flex flex-col gap-4\">\n<label class=\"text-label-md font-bold\">Tolerance Precision</label>\n<div class=\"flex flex-wrap gap-2\">\n<button class=\"tolerance-option px-4 py-2 rounded-full border border-outline-variant text-[12px] hover:border-primary hover:text-primary transition-all\" data-tolerance=\"0.1\" type=\"button\">±0.1 mm</button>\n<button class=\"tolerance-option px-4 py-2 rounded-full border-2 border-primary text-primary bg-primary/5 text-[12px] font-bold\" data-tolerance=\"0.05\" type=\"button\">±0.05 mm</button>\n<button class=\"tolerance-option px-4 py-2 rounded-full border border-outline-variant text-[12px] hover:border-primary hover:text-primary transition-all\" data-tolerance=\"0.02\" type=\"button\">±0.02 mm</button>\n</div>\n<div class=\"hidden-panel\" id=\"tolerance-drawing-panel\">\n<div class=\"section-upload-panel\">\n<div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-3\">\n<div>\n<p class=\"font-bold text-on-surface\">High-Precision Supplementary 2D Drawing</p>\n<p class=\"text-[12px] text-on-surface-variant mt-1\">When the selected tolerance is tighter than ±0.05 mm, please upload a 2D drawing to define key dimensions, tolerance bands, and inspection datums.</p>\n</div>\n<button class=\"px-4 py-2 rounded-lg border border-outline-variant bg-white text-label-md hover:border-primary hover:text-primary transition-all\" data-open-shared-drawing=\"\" type=\"button\">Upload Drawing</button>\n</div>\n<div class=\"mt-3 flex flex-wrap gap-2 shared-drawing-list\" data-sync-target=\"tolerance\">\n<span class=\"text-[12px] text-on-surface-variant\" data-empty-text=\"\">No supplementary drawing uploaded yet. Once uploaded, it will sync to the threads and tapped holes section.</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"flex flex-col gap-4\">\n<div class=\"flex justify-between items-center\">\n<label class=\"text-label-md font-bold\">Threads and Tapped Holes (AI Detected)</label>\n<button class=\"text-primary text-[12px] font-bold flex items-center gap-1 hover:underline\" type=\"button\">\n<span class=\"material-symbols-outlined text-[16px]\">add</span> Add Manually\n                                </button>\n</div>\n<div class=\"bg-surface-container-low rounded-lg p-4 border border-outline-variant\">\n<table class=\"w-full text-body-sm\">\n<thead>\n<tr class=\"text-on-surface-variant border-b border-outline-variant\">\n<th class=\"text-left pb-2 font-medium\">Specification</th>\n<th class=\"text-left pb-2 font-medium\">Depth</th>\n<th class=\"text-left pb-2 font-medium\">Quantity</th>\n<th class=\"text-right pb-2 font-medium\">Action</th>\n</tr>\n</thead>\n<tbody>\n<tr class=\"border-b border-outline-variant/30\">\n<td class=\"py-3\">M4 x 0.7</td>\n<td class=\"py-3\">12 mm (Through Hole)</td>\n<td class=\"py-3\">4</td>\n<td class=\"py-3 text-right\">\n<button class=\"text-primary hover:text-primary-container transition-colors\"><span class=\"material-symbols-outlined text-[18px]\">edit</span></button>\n</td>\n</tr>\n<tr>\n<td class=\"py-3\">M8 x 1.25</td>\n<td class=\"py-3\">18 mm (Blind Hole)</td>\n<td class=\"py-3\">2</td>\n<td class=\"py-3 text-right\">\n<button class=\"text-primary hover:text-primary-container transition-colors\"><span class=\"material-symbols-outlined text-[18px]\">edit</span></button>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"section-upload-panel\">\n<div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-3\">\n<div>\n<p class=\"font-bold text-on-surface\">Threads and Tapped Holes Supplementary 2D Drawing</p>\n<p class=\"text-[12px] text-on-surface-variant mt-1\">If thread depth, pilot hole, tolerance, or special tapping specifications require clarification, please upload a 2D drawing. The same drawing will automatically sync with the tolerance section.</p>\n</div>\n<button class=\"px-4 py-2 rounded-lg border border-outline-variant bg-white text-label-md hover:border-primary hover:text-primary transition-all\" data-open-shared-drawing=\"\" type=\"button\">Upload Drawing</button>\n</div>\n<div class=\"mt-3 flex flex-wrap gap-2 shared-drawing-list\" data-sync-target=\"thread\">\n<span class=\"text-[12px] text-on-surface-variant\" data-empty-text=\"\">No 2D drawing uploaded yet. After upload, the same content will appear here and in the tolerance section.</span>\n</div>\n</div>\n</div>\n</section>\n<section class=\"flex flex-col gap-4\">\n<h3 class=\"text-label-md font-bold flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">attachment</span>\n                            Remarks and Supporting Attachments\n                        </h3>\n<div class=\"flex flex-col gap-6\">\n<div class=\"flex flex-col gap-2\">\n<label class=\"text-label-md font-bold\" for=\"quote-remark\">Remarks</label>\n<textarea class=\"w-full min-h-[140px] rounded-xl border border-outline-variant bg-white px-4 py-3 text-body-sm text-on-surface focus:border-primary focus:ring-2 focus:ring-primary/15 outline-none resize-y\" id=\"quote-remark\" placeholder=\"Add assembly requirements, inspection standards, critical dimension risks, packaging notes, delivery expectations, or any other instructions here.\"></textarea>\n</div>\n<div class=\"section-upload-panel\">\n<div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-3\">\n<div>\n<p class=\"font-bold text-on-surface\">Supporting Attachment Upload</p>\n<p class=\"text-[12px] text-on-surface-variant mt-1\">Upload purchasing specs, reference drawings, quality requirements, assembly notes, contract attachments, and any other supporting documents.</p>\n</div>\n<button class=\"px-4 py-2 rounded-lg bg-primary text-on-primary text-label-md hover:opacity-90 transition-all\" id=\"general-attachment-trigger\" type=\"button\">Upload Attachment</button>\n</div>\n<div class=\"mt-3 flex flex-wrap gap-2\" id=\"general-attachment-list\">\n<span class=\"text-[12px] text-on-surface-variant\" data-empty-text=\"\">Supported formats include PDF, DWG, DXF, PNG, JPG, XLSX, ZIP, and other common engineering files.</span>\n</div>\n</div>\n<input accept=\".pdf,.dwg,.dxf,.png,.jpg,.jpeg,.xlsx,.xls,.zip,.doc,.docx\" class=\"hidden\" id=\"general-attachment-input\" multiple=\"\" type=\"file\"/>\n<input accept=\".pdf,.dwg,.dxf,.png,.jpg,.jpeg\" class=\"hidden\" id=\"shared-drawing-input\" multiple=\"\" type=\"file\"/>\n</div>\n</section>\n<!-- Post-processing -->\n<section>\n<h3 class=\"text-label-md font-bold mb-4 flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">texture</span>\n                            Post-Processing &amp; Surface Finish\n                        </h3>\n<div class=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n<div class=\"border border-outline-variant p-4 rounded-xl flex flex-col gap-3 group cursor-pointer hover:border-primary/50 transition-all\">\n<div class=\"w-full h-16 rounded-lg bg-gray-200 overflow-hidden relative\">\n<div class=\"absolute inset-0 bg-[#e2e8f0]\"></div>\n<div class=\"absolute inset-0 opacity-20\" style=\"background-image: repeating-linear-gradient(45deg, #000, #000 1px, transparent 1px, transparent 10px);\"></div>\n</div>\n<span class=\"text-label-md text-center\">As-Machined</span>\n</div>\n<div class=\"border-2 border-primary bg-primary/5 p-4 rounded-xl flex flex-col gap-3 group cursor-pointer transition-all\">\n<div class=\"w-full h-16 rounded-lg bg-primary overflow-hidden relative\">\n<div class=\"absolute inset-0 bg-[#1e40af] opacity-80\"></div>\n<div class=\"absolute inset-0 bg-white/10 blur-[1px]\"></div>\n</div>\n<span class=\"text-label-md font-bold text-center\">Anodized (Blue)</span>\n</div>\n<div class=\"border border-outline-variant p-4 rounded-xl flex flex-col gap-3 group cursor-pointer hover:border-primary/50 transition-all\">\n<div class=\"w-full h-16 rounded-lg bg-zinc-600 overflow-hidden relative\">\n<div class=\"absolute inset-0 bg-[#52525b]\"></div>\n<div class=\"absolute inset-0 flex items-center justify-center\">\n<div class=\"w-full h-full opacity-30\" style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 4px 4px;\"></div>\n</div>\n</div>\n<span class=\"text-label-md text-center\">Sandblasted</span>\n</div>\n<div class=\"border border-outline-variant p-4 rounded-xl flex flex-col gap-3 group cursor-pointer hover:border-primary/50 transition-all\">\n<div class=\"w-full h-16 rounded-lg border-2 border-dashed border-outline-variant flex items-center justify-center bg-surface-container-low\">\n<span class=\"material-symbols-outlined text-outline text-[24px]\">add</span>\n</div>\n<span class=\"text-label-md text-center\">More Options</span>\n</div>\n</div>\n</section>\n</div>\n</div>\n<!-- Right Column: Sticky Sidebar -->\n<div class=\"col-span-12 lg:col-span-4 lg:sticky lg:top-24\">\n<div class=\"token-card shadow-lg p-6 flex flex-col gap-6\">\n<h3 class=\"text-headline-sm font-bold border-b border-outline-variant pb-4\">Live Quote Preview</h3>\n<div class=\"flex flex-col gap-4\">\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface-variant\">Manufacturing Process</span>\n<span class=\"font-medium\" id=\"quote-process-label\">CNC 5-Axis Milling</span>\n</div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface-variant\">Base Machining Cost</span>\n<span class=\"font-medium\" id=\"quote-base-price\">¥ 1,850.00</span>\n</div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface-variant\">Material Cost (6061-T6)</span>\n<span class=\"font-medium\" id=\"quote-material-price\">¥ 345.00</span>\n</div>\n<div class=\"flex justify-between items-center text-body-sm\" id=\"quote-tolerance-row\">\n<span class=\"text-on-surface-variant\" id=\"quote-tolerance-label\">Precision Tolerance Surcharge (±0.05 mm)</span>\n<span class=\"font-medium\" id=\"quote-tolerance-price\">¥ 120.00</span>\n</div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface-variant\">Anodizing Fee</span>\n<span class=\"font-medium\" id=\"quote-finishing-price\">¥ 85.00</span>\n</div>\n<div class=\"flex justify-between items-center text-body-sm\">\n<span class=\"text-on-surface-variant\">Logistics &amp; Shipping Estimate</span>\n<span class=\"font-medium\" id=\"quote-shipping-price\">¥ 50.00</span>\n</div>\n</div>\n<div class=\"h-[1px] bg-outline-variant my-2\"></div>\n<div class=\"hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-4\" id=\"quote-manual-review\">\n<p class=\"text-[12px] font-bold text-[#b45309]\">Pending manual review for final quote confirmation</p>\n<p class=\"text-[12px] text-[#92400e] mt-1\">A custom process has been selected. An engineer will continue the quote review based on the model, notes, and uploaded attachments.</p>\n</div>\n<div class=\"flex justify-between items-end\" id=\"quote-total-block\">\n<div class=\"flex flex-col\">\n<span class=\"text-[12px] text-on-surface-variant uppercase font-bold tracking-wider\">Estimated Total</span>\n<span class=\"text-headline-lg font-extrabold text-primary\" id=\"quote-total-price\">¥ 2,450.00</span>\n</div>\n<div class=\"text-right\">\n<span class=\"text-[10px] text-on-surface-variant bg-surface-container-high px-2 py-1 rounded\">Excluding VAT</span>\n</div>\n</div>\n<div class=\"flex flex-col gap-3 mt-4\">\n<button class=\"w-full bg-primary py-4 rounded-xl text-on-primary font-bold shadow-md hover:bg-primary-container active:scale-[0.98] transition-all flex items-center justify-center gap-2\">\n<span class=\"material-symbols-outlined\">save</span>\n                            Save Changes &amp; Requote\n                        </button>\n<button class=\"w-full bg-surface-container-lowest border border-outline-variant py-3 rounded-xl text-on-surface-variant font-bold hover:bg-surface-container-low transition-all\">\n                            Cancel and Go Back\n                        </button>\n</div>\n<div class=\"flex items-start gap-3 p-4 bg-primary/5 rounded-lg border border-primary/10\">\n<span class=\"material-symbols-outlined text-primary text-[20px]\">info</span>\n<p class=\"text-[12px] text-on-secondary-container leading-relaxed\" id=\"quote-info-copy\">\n                            This price is a preliminary estimate generated by AI. The final price will be confirmed by a factory engineer after manual review within 2 hours.\n                        </p>\n</div>\n</div>\n</div>\n</div>"
}
