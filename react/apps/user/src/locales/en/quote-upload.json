  "mainHtml": "<div class=\"max-w-6xl mx-auto\">\n<!-- Header Section -->\n<div class=\"flex flex-col mb-10\">\n<h1 class=\"text-headline-lg font-headline-lg text-on-surface mb-2\">New Quote Generation</h1>\n<p class=\"text-body-lg font-body-lg text-on-surface-variant\">Upload your CAD models for instant AI-driven DFM analysis and precision pricing.</p>\n</div>\n<!-- Bento Layout Grid -->\n<div class=\"grid grid-cols-12 gap-6 items-start\">\n<!-- Left Column: Upload Area -->\n<div class=\"col-span-12 lg:col-span-8\">\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-8 shadow-sm flex flex-col items-center justify-center min-h-[450px] transition-all border-dashed border-2 hover:border-primary group cursor-pointer relative overflow-hidden\" id=\"drop-zone\">\n<!-- Decorative Abstract Background -->\n<div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\">\n<div class=\"absolute top-0 right-0 w-64 h-64 bg-primary rounded-full blur-[80px]\"></div>\n<div class=\"absolute bottom-0 left-0 w-64 h-64 bg-secondary rounded-full blur-[80px]\"></div>\n</div>\n<div class=\"bg-primary-container/10 p-6 rounded-full mb-6 group-hover:scale-110 transition-transform duration-300\">\n<span class=\"material-symbols-outlined text-[64px] text-primary\" data-icon=\"cloud_upload\">cloud_upload</span>\n</div>\n<h3 class=\"text-headline-md font-headline-md text-on-surface mb-3\">Drag and drop your 3D files</h3>\n<p class=\"text-body-lg font-body-lg text-on-surface-variant mb-8 text-center max-w-md\">Securely upload individual parts or assembly files for high-precision industrial quoting.</p>\n<button class=\"bg-primary text-on-primary px-8 py-3 rounded-lg font-label-md text-label-md shadow-sm hover:opacity-90 transition-all flex items-center gap-2 mb-8\">\n<span class=\"material-symbols-outlined\" data-icon=\"add\">add</span>\n                            Select Files from Device\n                        </button>\n<!-- Supported Formats -->\n<div class=\"flex flex-wrap justify-center gap-3\">\n<span class=\"px-3 py-1 bg-surface-container rounded-full text-label-sm font-label-sm text-on-surface-variant border border-outline-variant\">.STEP</span>\n<span class=\"px-3 py-1 bg-surface-container rounded-full text-label-sm font-label-sm text-on-surface-variant border border-outline-variant\">.STL</span>\n<span class=\"px-3 py-1 bg-surface-container rounded-full text-label-sm font-label-sm text-on-surface-variant border border-outline-variant\">.IGES</span>\n<span class=\"px-3 py-1 bg-surface-container rounded-full text-label-sm font-label-sm text-on-surface-variant border border-outline-variant\">.OBJ</span>\n<span class=\"px-3 py-1 bg-surface-container rounded-full text-label-sm font-label-sm text-on-surface-variant border border-outline-variant\">.PARASOLID</span>\n</div>\n<p class=\"mt-6 text-label-sm font-label-sm text-outline\">Maximum file size: 250MB per model</p>\n</div>\n<!-- Additional Upload Info -->\n<div class=\"mt-6 grid grid-cols-1 md:grid-cols-2 gap-4\">\n<div class=\"flex items-center gap-4 p-4 bg-surface-container-low rounded-lg border border-outline-variant\">\n<div class=\"p-2 bg-on-tertiary-container rounded-lg\">\n<span class=\"material-symbols-outlined text-tertiary\" data-icon=\"history\">history</span>\n</div>\n<div>\n<h4 class=\"text-label-md font-label-md text-on-surface\">Recent Models</h4>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">Re-quote from your model center</p>\n</div>\n</div>\n<div class=\"flex items-center gap-4 p-4 bg-surface-container-low rounded-lg border border-outline-variant\">\n<div class=\"p-2 bg-secondary-container rounded-lg\">\n<span class=\"material-symbols-outlined text-secondary\" data-icon=\"hub\">hub</span>\n</div>\n<div>\n<h4 class=\"text-label-md font-label-md text-on-surface\">Cloud Integration</h4>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">Import from Fusion360 or SolidWorks</p>\n</div>\n</div>\n</div>\n</div>\n<!-- Right Column: Features/Status -->\n<div class=\"col-span-12 lg:col-span-4 space-y-6\">\n<!-- Instant Analysis Card -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-6 shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-4 mb-4\">\n<div class=\"w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"bolt\">bolt</span>\n</div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Instant Analysis</h3>\n</div>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">Our AI engine automatically identifies geometric complexities, thread counts, and volume tolerances within seconds of upload.</p>\n</div>\n<!-- IP Protection Card -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-6 shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-4 mb-4\">\n<div class=\"w-12 h-12 rounded-lg bg-green-50 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-green-600\" data-icon=\"shield_lock\">shield_lock</span>\n</div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">IP Protection</h3>\n</div>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">Enterprise-grade encryption and NDA-compliant processing ensure your proprietary designs never leave our secure, firewalled server clusters.</p>\n</div>\n<!-- Live Inventory Card -->\n<div class=\"bg-surface-container-lowest rounded-xl border border-outline-variant p-6 shadow-sm hover:shadow-md transition-shadow\">\n<div class=\"flex items-center gap-4 mb-4\">\n<div class=\"w-12 h-12 rounded-lg bg-amber-50 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-amber-600\" data-icon=\"inventory_2\">inventory_2</span>\n</div>\n<h3 class=\"text-headline-sm font-headline-sm text-on-surface\">Live Inventory</h3>\n</div>\n<p class=\"text-body-sm font-body-sm text-on-surface-variant\">Pricing is dynamically adjusted based on real-time global material stock, energy costs, and machine availability in our network.</p>\n</div>\n<!-- Quote Progress/Steps -->\n<div class=\"bg-surface-container rounded-xl p-6 border border-outline-variant\">\n<h4 class=\"text-label-md font-label-md text-on-surface mb-4\">Quoting Process</h4>\n<div class=\"space-y-4\">\n<div class=\"flex items-start gap-3\">\n<div class=\"w-6 h-6 rounded-full bg-primary flex items-center justify-center text-[10px] text-on-primary font-bold\">1</div>\n<div class=\"flex-1\">\n<p class=\"text-label-sm font-label-sm text-on-surface\">Upload CAD</p>\n<p class=\"text-[11px] text-on-surface-variant\">Supported in 5+ formats</p>\n</div>\n<span class=\"material-symbols-outlined text-primary text-sm\" data-icon=\"check_circle\">check_circle</span>\n</div>\n<div class=\"flex items-start gap-3 opacity-50\">\n<div class=\"w-6 h-6 rounded-full bg-outline flex items-center justify-center text-[10px] text-white font-bold\">2</div>\n<div class=\"flex-1\">\n<p class=\"text-label-sm font-label-sm text-on-surface\">DFM Analysis</p>\n<p class=\"text-[11px] text-on-surface-variant\">AI-driven manufacturability check</p>\n</div>\n</div>\n<div class=\"flex items-start gap-3 opacity-50\">\n<div class=\"w-6 h-6 rounded-full bg-outline flex items-center justify-center text-[10px] text-white font-bold\">3</div>\n<div class=\"flex-1\">\n<p class=\"text-label-sm font-label-sm text-on-surface\">Select Finishing</p>\n<p class=\"text-[11px] text-on-surface-variant\">Anodizing, coating, or polishing</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>"
