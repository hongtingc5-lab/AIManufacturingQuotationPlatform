  "mainHtml": "<nav class=\"flex items-center space-x-2 mb-4 text-on-surface-variant\">\n<a class=\"font-label-md text-label-md hover:text-primary transition-colors\" href=\"/orders\">订单中心</a>\n<span class=\"material-symbols-outlined text-sm\">chevron_right</span>\n<span class=\"font-label-md text-label-md text-primary font-semibold\">报价详情</span>\n</nav><h1 class=\"font-headline-lg text-headline-lg mb-6 text-on-surface\">报价详情</h1><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-lg items-start\">\n<!-- Left Column -->\n<div class=\"lg:col-span-8 space-y-lg\">\n<!-- Model Summary Card -->\n<section class=\"token-card overflow-hidden\">\n<div class=\"p-lg\">\n<div class=\"flex flex-col sm:flex-row gap-lg\">\n<div class=\"w-full sm:w-48 h-48 bg-surface-container rounded-lg overflow-hidden border border-outline-variant relative\">\n<img alt=\"3D Model\" class=\"w-full h-full object-cover\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCuUdnqwY2gEawl6adQL7s94Fggs2Ur9tw0QD9MO9B6LDtCETGEHOExvvi8Q3ZIOo-b8-x81i4OZmnNaQi-48GkNGxPb3pOQDinC42uEzb2z56xGz9aggZ2jupBvkb43joFK1Y3SylJD0QYr-QEUPkYJ9xF6bdSJDNpGVdv-sgDk61y_DiiiX44Hna7JprNUOGoVRgh02tovU_jvFf6J9nZNTMR5fmCZFEOhm-kJS3DY61S1fS2vd_vkvpRi-fOO8RyUU__9hv6SoI\"/>\n<div class=\"absolute bottom-sm right-sm bg-white/90 backdrop-blur-sm p-xs rounded-lg border border-outline-variant shadow-sm flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-primary text-[18px]\">view_in_ar</span>\n</div>\n</div>\n<div class=\"flex-1 flex flex-col justify-between\">\n<div>\n<div class=\"flex items-center justify-between mb-lg\">\n<h1 class=\"font-headline-sm text-headline-sm text-on-surface\">housing_v4_final.step</h1>\n<span class=\"px-sm py-1 bg-[#E8F5E9] text-[#2E7D32] text-label-sm font-bold rounded-lg flex items-center gap-xs\">\n<span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>\n              已验证零件\n            </span>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-md\">\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">材料</p>\n<p class=\"font-medium text-on-surface\">Aluminum 6061-T6</p>\n</div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">工艺</p>\n<p class=\"font-medium text-on-surface\">CNC 5-Axis Milling</p>\n</div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">表面处理</p>\n<p class=\"font-medium text-on-surface\">透明阳极氧化</p>\n</div>\n<div><p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">数量（件）</p><div class=\"flex items-center border border-outline-variant rounded-lg overflow-hidden h-10 w-32\"><button class=\"w-10 h-full flex items-center justify-center hover:bg-surface-container transition-colors border-r border-outline-variant\"><span class=\"material-symbols-outlined text-on-surface text-[18px]\">remove</span></button><input class=\"w-12 h-full text-center border-none focus:ring-0 font-bold text-on-surface bg-transparent text-sm\" type=\"number\" value=\"12\"/><button class=\"w-10 h-full flex items-center justify-center hover:bg-surface-container transition-colors border-l border-outline-variant\"><span class=\"material-symbols-outlined text-on-surface text-[18px]\">add</span></button></div></div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">单位</p>\n<p class=\"font-medium text-on-surface\">mm</p>\n</div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">长宽高</p>\n<p class=\"font-medium text-on-surface\">120 x 85 x 45</p>\n</div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">体积</p>\n<p class=\"font-medium text-on-surface\">142.5 cm3</p>\n</div>\n<div>\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">螺纹</p>\n<p class=\"font-medium text-on-surface\">M6 x 1，8 孔</p>\n</div></div>\n<div class=\"mt-md rounded-lg border border-outline-variant bg-surface-container-lowest px-md py-sm\">\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">备注</p>\n<p class=\"text-body-sm text-on-surface-variant\">外观 A 面避免夹伤，关键基准 B 面保持平面度，包装前需单独加保护膜。</p>\n<!-- <p class=\"text-label-sm text-primary mt-2\">最新上传版本: 2026-07-08 14:20，预计交付日期会随新文件与工厂负载自动刷新。</p> -->\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"bg-surface-container-low px-lg py-3 border-t border-outline-variant flex items-center justify-between\">\n<a class=\"px-4 py-2 border border-outline-variant rounded-lg text-label-md font-medium hover:bg-surface-container transition-colors inline-flex items-center justify-center\" href=\"/quotes/edit\">修改报价要求</a>\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors text-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">content_copy</span>\n        复制\n      </button>\n<button class=\"flex items-center gap-1 text-error hover:opacity-80 transition-colors text-label-md\">\n<span class=\"material-symbols-outlined text-[18px]\">delete</span>\n        删除\n      </button>\n</div>\n</div>\n</section>\n<!-- 订单配置 Card -->\n<section class=\"token-card p-lg\">\n<h2 class=\"font-headline-sm text-headline-sm mb-lg\">订单配置</h2>\n<div class=\"space-y-xl\">\n<!-- Quantity -->\n<!-- Speed Toggle -->\n<div class=\"flex flex-col sm:flex-row sm:items-start justify-between gap-md pb-lg border-b border-outline-variant\">\n<div>\n<h3 class=\"font-medium text-on-surface mb-xs\">预计交付</h3>\n<p class=\"text-body-sm text-on-surface-variant\">基于当前工厂负载与最新上传模型自动计算交付日期。</p>\n</div>\n<div class=\"sm:min-w-[280px]\">\n<div class=\"flex p-1 bg-surface-container-low rounded-lg border border-outline-variant\" id=\"delivery-speed-toggle\">\n<button class=\"px-lg py-sm rounded-md bg-white shadow-sm font-medium text-primary text-body-sm border border-outline-variant/30\" data-offset-days=\"9\" data-speed-label=\"标准交付\">标准交付</button>\n<button class=\"px-lg py-sm rounded-md font-medium text-on-surface-variant hover:text-on-surface text-body-sm transition-all\" data-offset-days=\"5\" data-speed-label=\"加急交付\">加急交付</button>\n</div>\n<div class=\"mt-sm rounded-lg border border-outline-variant bg-surface-container-lowest px-md py-sm\">\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">预计交付日期</p>\n<p class=\"font-bold text-primary text-headline-sm\" id=\"deliveryDateValue\"></p>\n<p class=\"text-label-sm text-on-surface-variant\" id=\"deliveryDateHint\">基于 2026-07-08 最新上传模型与当前工厂负载动态测算。</p>\n</div>\n</div>\n</div>\n<!-- Address -->\n<div class=\"flex items-start justify-between pt-sm\">\n<div class=\"flex gap-md\">\n<span class=\"material-symbols-outlined text-outline mt-1\">local_shipping</span>\n<div>\n<h3 class=\"font-medium text-on-surface mb-sm\">收货地址</h3>\n<div class=\"text-body-sm text-on-surface-variant leading-relaxed\">\n<p class=\"font-bold text-on-surface mb-xs\">格罗博动力公司</p>\n<p class=\"\">工业大道 888 号</p>\n<p class=\"\">上海高新区，201203</p>\n</div>\n</div>\n</div>\n<button class=\"p-xs text-primary hover:bg-primary/5 rounded-full transition-all\">\n<span class=\"material-symbols-outlined\">edit</span>\n</button>\n</div>\n</div>\n</section>\n<!-- 精度增强服务 Grid -->\n<div class=\"border-2 border-dashed border-outline-variant rounded-xl p-lg bg-surface-container-lowest hover:border-primary/40 transition-all cursor-pointer flex flex-col items-center justify-center gap-md group\">\n<div class=\"w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-outline group-hover:text-primary transition-colors\">\n<span class=\"material-symbols-outlined text-[28px]\">upload_file</span>\n</div>\n<div class=\"text-center\">\n<p class=\"font-bold text-on-surface\">拖拽以添加另一个模型</p>\n<p class=\"text-body-sm text-on-surface-variant\">支持 .STEP、.STP、.STL、.OBJ（最大 50MB）</p>\n</div>\n</div><section>\n<h2 class=\"font-headline-sm text-headline-sm mb-lg\">精度增强服务</h2>\n<div class=\"grid grid-cols-1 sm:grid-cols-3 gap-md\">\n<div class=\"token-card p-lg flex flex-col items-center text-center\">\n<div class=\"w-12 h-12 rounded-full bento-icon-wrapper flex items-center justify-center mb-md text-primary\">\n<span class=\"material-symbols-outlined text-[24px]\">architecture</span>\n</div>\n<h4 class=\"font-bold mb-sm text-on-surface\">公差校验</h4>\n<p class=\"text-body-sm text-on-surface-variant\">针对关键尺寸提供 ±0.005mm 的数字测头检测。</p>\n</div>\n<div class=\"token-card p-lg flex flex-col items-center text-center\">\n<div class=\"w-12 h-12 rounded-full bento-icon-wrapper flex items-center justify-center mb-md text-primary\">\n<span class=\"material-symbols-outlined text-[24px]\">verified</span>\n</div>\n<h4 class=\"font-bold mb-sm text-on-surface\">材料认证</h4>\n<p class=\"text-body-sm text-on-surface-variant\">提供官方材质证明（MTR），支持整批次追溯。</p>\n</div>\n<div class=\"token-card p-lg flex flex-col items-center text-center\">\n<div class=\"w-12 h-12 rounded-full bento-icon-wrapper flex items-center justify-center mb-md text-primary\">\n<span class=\"material-symbols-outlined text-[24px]\">package_2</span>\n</div>\n<h4 class=\"font-bold mb-sm text-on-surface\">高级包装</h4>\n<p class=\"text-body-sm text-on-surface-variant\">提供定制真空封装与抗冲击板条箱，确保运输安全。</p>\n</div>\n</div>\n</section>\n</div>\n<!-- Right Column -->\n<div class=\"lg:col-span-4 space-y-lg\">\n<!-- Pricing Card -->\n<aside class=\"token-card p-lg\">\n<h2 class=\"font-headline-sm text-headline-sm mb-lg\">总成本拆分</h2>\n<div class=\"space-y-md border-b border-outline-variant pb-lg mb-lg\">\n<div class=\"flex justify-between text-body-sm\">\n<span class=\"text-on-surface-variant\">材料成本</span>\n<span class=\"font-medium\">¥4,280.00</span>\n</div>\n<div class=\"flex justify-between text-body-sm\">\n<span class=\"text-on-surface-variant\">加工成本（人工与刀具）</span>\n<span class=\"font-medium\">¥8,540.00</span>\n</div>\n<div class=\"flex justify-between text-body-sm\">\n<span class=\"text-on-surface-variant\">表面处理</span>\n<span class=\"font-medium\">¥1,200.00</span>\n</div>\n<div class=\"flex justify-between text-body-sm\">\n<span class=\"text-on-surface-variant\">物流与搬运</span>\n<span class=\"font-medium\">¥650.00</span>\n</div>\n<div class=\"flex justify-between text-body-sm\">\n<span class=\"text-on-surface-variant\">税费（增值税 13%）</span>\n<span class=\"font-medium\">¥1,489.00</span>\n</div>\n</div>\n<div class=\"mb-lg\">\n<p class=\"text-[11px] text-outline uppercase font-bold tracking-widest mb-xs\">总金额</p>\n<p class=\"text-headline-lg font-bold text-primary\">¥16,159.00</p>\n</div>\n<button class=\"w-full bg-primary hover:bg-[#1d4ed8] text-white font-bold py-md rounded-lg flex items-center justify-center gap-md transition-all active:scale-[0.98] shadow-lg shadow-primary/20\">\n                        去支付\n                        <span class=\"material-symbols-outlined text-[20px]\">arrow_forward</span>\n</button>\n<p class=\"mt-md text-center text-label-sm text-on-surface-variant\">报价在未来 48 小时内有效。</p>\n</aside>\n<!-- Assistance Card -->\n<aside class=\"token-card p-lg bg-surface-container-low border-dashed border-primary/40\">\n<div class=\"flex items-center gap-md mb-md\">\n<div class=\"w-10 h-10 rounded-lg bg-primary text-white flex items-center justify-center\">\n<span class=\"material-symbols-outlined\">support_agent</span>\n</div>\n<h3 class=\"font-bold text-headline-sm\">需要协助？</h3>\n</div>\n<p class=\"text-body-sm text-on-surface-variant mb-lg\">我们的工程团队可协助提供 DFM 反馈与批量价格调整建议。</p>\n<a class=\"text-primary font-bold flex items-center gap-xs hover:underline decoration-2 underline-offset-4\" href=\"#\">\n                        联系专家\n                        <span class=\"material-symbols-outlined text-[18px]\">forum</span>\n</a>\n</aside>\n</div>\n</div>"
}
