  "mainHtml": "<header class=\"mb-8\">\n<h1 class=\"font-headline-lg text-headline-lg text-on-surface mb-2\">账户中心</h1>\n<p class=\"text-on-surface-variant font-body-lg\">管理您的个人资料、企业认证与安全设置。</p>\n</header><div class=\"grid grid-cols-12 gap-8\">\n<!-- Sidebar Navigation for Account Sections -->\n<div class=\"col-span-12 lg:col-span-3\">\n<div class=\"bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm sticky top-0\">\n<ul class=\"flex flex-col\">\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent active-tab\" id=\"nav-personal-info\" onclick=\"scrollToSection('personal-info')\">个人信息</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-contacts\" onclick=\"scrollToSection('contacts')\">联系人</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-shipping\" onclick=\"scrollToSection('shipping')\">收货地址</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-invoice\" onclick=\"scrollToSection('invoice')\">发票管理</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-certification\" onclick=\"scrollToSection('certification')\">企业认证</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-security\" onclick=\"scrollToSection('security')\">安全设置</button></li>\n<li class=\"\"><button class=\"w-full flex items-center gap-3 px-5 py-4 text-left font-label-md text-label-md hover:bg-surface transition-colors border-r-4 border-transparent\" id=\"nav-system\" onclick=\"scrollToSection('system')\">系统设置</button></li>\n</ul>\n</div>\n</div>\n<!-- Form Sections -->\n<div class=\"col-span-12 lg:col-span-9 space-y-8\">\n<!-- Section: Personal Info -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"personal-info\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">个人信息</h3>\n<span class=\"material-symbols-outlined text-outline\">badge</span>\n</div>\n<div class=\"p-8\">\n<div class=\"flex items-center gap-6 mb-8\">\n<div class=\"relative group\">\n<img class=\"w-20 h-20 rounded-full border-2 border-primary-fixed object-cover\" data-alt=\"Professional headshot of 张伟, senior engineer, studio lighting, corporate portrait, minimalist background, high detail.\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBv4gWTwUY6rz7CmOFtBUJG3vz1iRgABHipXeY8crOyuGSiYf1g1yavynFRttR1QD4jW2wuWbJWCtJES5up7jzrmCwnvty4fXz-7NTxf8gz1haTvQdBajsaUirU-wdQ2M-dib6SZ7iy_o2S9X9TIv8J7ALIGwwMpLeMI3jn1mMijm_UhQg1uNYCNKc7R35I9VNbo9aAxdhjwuHyM8JvmPDZUEF0ggNdCy-C09ATxqX-K6hze1TpStA1Pcu0oG_q1u0QuuIgh1W89qY\"/>\n<button class=\"absolute bottom-0 right-0 bg-primary text-white p-1.5 rounded-full shadow-lg border-2 border-white hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-[16px]\">edit</span>\n</button>\n</div>\n<div>\n<h4 class=\"font-headline-sm text-on-surface\">张伟</h4>\n<p class=\"text-on-surface-variant font-label-md\">高级机械工程师 · 研发部</p>\n</div>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">姓名</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all\" type=\"text\" value=\"张伟\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">专业职称</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all\" type=\"text\" value=\"高级工程师\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">所属部门</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all\" type=\"text\" value=\"研发 / 工业自动化\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">手机号码</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all\" type=\"tel\" value=\"+86 138-xxxx-8888\"/>\n</div>\n<div class=\"md:col-span-2 space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">电子邮箱</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all\" type=\"email\" value=\"wei.zhang@industrial-tech.com\"/>\n</div>\n</div>\n<div class=\"mt-8 flex justify-end\">\n<button class=\"px-8 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-colors shadow-sm active:scale-95\">保存修改</button>\n</div>\n</div>\n</section>\n<!-- Section: Contacts -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"contacts\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">联系人</h3>\n<button class=\"flex items-center gap-1.5 px-3 py-1.5 text-primary font-label-md hover:bg-surface transition-colors rounded-lg\">\n<span class=\"material-symbols-outlined text-[18px]\">add</span>\n                                新增联系人\n                            </button>\n</div>\n<div class=\"p-8\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n<div class=\"p-4 border border-outline-variant rounded-xl flex items-center justify-between hover:bg-surface-container-low transition-colors group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-secondary-fixed rounded-full flex items-center justify-center text-primary font-bold\">LJ</div>\n<div>\n<p class=\"font-label-md text-on-surface\">李俊</p>\n<p class=\"text-[12px] text-on-surface-variant\">采购经理</p>\n</div>\n</div>\n<div class=\"flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity\">\n<button class=\"p-2 text-on-surface-variant hover:text-primary\"><span class=\"material-symbols-outlined text-[20px]\">edit</span></button>\n<button class=\"p-2 text-on-surface-variant hover:text-error\"><span class=\"material-symbols-outlined text-[20px]\">delete</span></button>\n</div>\n</div>\n<div class=\"p-4 border border-outline-variant rounded-xl flex items-center justify-between hover:bg-surface-container-low transition-colors group\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 bg-tertiary-fixed rounded-full flex items-center justify-center text-tertiary font-bold\">XY</div>\n<div>\n<p class=\"font-label-md text-on-surface\">肖妍</p>\n<p class=\"text-[12px] text-on-surface-variant\">财务负责人</p>\n</div>\n</div>\n<div class=\"flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity\">\n<button class=\"p-2 text-on-surface-variant hover:text-primary\"><span class=\"material-symbols-outlined text-[20px]\">edit</span></button>\n<button class=\"p-2 text-on-surface-variant hover:text-error\"><span class=\"material-symbols-outlined text-[20px]\">delete</span></button>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Shipping Address -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"shipping\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">收货地址</h3>\n<button class=\"flex items-center gap-1.5 px-3 py-1.5 text-primary font-label-md hover:bg-surface transition-colors rounded-lg\">\n<span class=\"material-symbols-outlined text-[18px]\">location_on</span>\n                                新增地址\n                            </button>\n</div>\n<div class=\"p-8 space-y-4\">\n<div class=\"p-5 border border-primary-fixed bg-surface-container-low rounded-xl relative\">\n<span class=\"absolute top-4 right-4 bg-primary-container text-white text-[10px] px-2 py-0.5 rounded font-bold\">默认</span>\n<div class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-primary mt-1\">home_pin</span>\n<div>\n<p class=\"font-label-md text-on-surface\">精密制造园区创新大道 888 号</p>\n<p class=\"text-on-surface-variant body-sm\">中国上海市浦东新区</p>\n<p class=\"mt-2 text-on-surface font-label-md\">张伟 | +86 138-xxxx-8888</p>\n</div>\n</div>\n<div class=\"mt-4 pt-4 border-t border-outline-variant flex gap-4\">\n<button class=\"text-[12px] font-bold text-primary hover:underline\">编辑地址</button>\n<button class=\"text-[12px] font-bold text-error hover:underline\">删除</button>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Invoice Management -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"invoice\">\n<div class=\"p-6 border-b border-outline-variant\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">发票管理</h3>\n</div>\n<div class=\"p-8 grid grid-cols-1 md:grid-cols-2 gap-6\">\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">企业抬头</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none\" type=\"text\" value=\"工业自动化解决方案有限公司\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">纳税人识别号 (Tax ID)</label>\n<input class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none\" type=\"text\" value=\"91310115MA1Kxxxxxx\"/>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block font-label-md text-on-surface-variant\">发票类型</label>\n<select class=\"w-full p-3 rounded-lg border border-outline-variant focus:border-primary outline-none bg-white\">\n<option>增值税专用发票</option>\n<option>增值税普通发票</option>\n<option>电子发票</option>\n</select>\n</div>\n<div class=\"md:col-span-2 mt-4 flex justify-end\">\n<button class=\"px-8 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-colors shadow-sm\">更新发票信息</button>\n</div>\n</div>\n</section>\n<!-- Section: Enterprise Certification -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"certification\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">企业认证</h3>\n<div class=\"flex items-center gap-2 px-3 py-1 bg-green-100 text-green-700 rounded-full\">\n<span class=\"material-symbols-outlined text-[18px]\" style=\"font-variation-settings: 'FILL' 1;\">verified</span>\n<span class=\"text-[12px] font-bold\">已认证</span>\n</div>\n</div>\n<div class=\"p-8\">\n<div class=\"bg-surface-container-low p-6 rounded-xl border-l-4 border-green-500\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">企业主体</p>\n<p class=\"font-headline-sm text-on-surface\">工业自动化解决方案有限公司</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">统一社会信用代码</p>\n<p class=\"font-label-md text-on-surface\">91310115MA1K7Y7G09</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">认证日期</p>\n<p class=\"font-label-md text-on-surface\">2023-11-15</p>\n</div>\n<div>\n<p class=\"text-on-surface-variant text-[12px] font-bold uppercase tracking-wide mb-1\">账户等级</p>\n<p class=\"font-label-md text-primary font-bold\">企业铂金级</p>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: Security Settings -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"security\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">安全设置</h3>\n<span class=\"material-symbols-outlined text-outline\">security</span>\n</div>\n<div class=\"p-8\">\n<div class=\"space-y-6\">\n<div class=\"flex items-center justify-between p-4 bg-surface rounded-xl border border-outline-variant\">\n<div class=\"flex items-center gap-4\">\n<div class=\"p-2 bg-primary-fixed rounded-lg\"><span class=\"material-symbols-outlined text-primary\">lock</span></div>\n<div>\n<p class=\"font-label-md text-on-surface\">登录密码</p>\n<p class=\"text-[12px] text-on-surface-variant\">上次修改于 45 天前</p>\n</div>\n</div>\n<button class=\"px-4 py-2 border border-primary text-primary font-bold rounded-lg hover:bg-primary-container hover:text-white transition-all\">编辑密码</button>\n</div>\n<div class=\"flex items-center justify-between p-4 bg-surface rounded-xl border border-outline-variant\">\n<div class=\"flex items-center gap-4\">\n<div class=\"p-2 bg-secondary-fixed rounded-lg\"><span class=\"material-symbols-outlined text-secondary\">phonelink_lock</span></div>\n<div>\n<p class=\"font-label-md text-on-surface\">双重身份验证 (2FA)</p>\n<p class=\"text-[12px] text-on-surface-variant\">启用后可提升账户安全性</p>\n</div>\n</div>\n<div class=\"relative inline-block w-12 h-6 rounded-full bg-outline-variant cursor-pointer transition-colors\" id=\"toggle-2fa\" onclick=\"this.classList.toggle('bg-primary')\">\n<div class=\"absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform transform translate-x-0 group-active:scale-90\" id=\"dot-2fa\"></div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Section: System Settings -->\n<section class=\"bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden scroll-mt-8\" id=\"system\">\n<div class=\"p-6 border-b border-outline-variant\">\n<h3 class=\"font-headline-sm text-headline-sm text-on-surface\">系统设置</h3>\n</div>\n<div class=\"p-8 grid grid-cols-1 md:grid-cols-2 gap-8\">\n<div class=\"space-y-4\">\n<h4 class=\"font-label-md text-on-surface font-bold\">偏好设置</h4>\n<div class=\"space-y-3\">\n<div class=\"flex items-center justify-between\">\n<span class=\"text-body-sm\">推送通知</span>\n<input checked=\"\" class=\"rounded text-primary focus:ring-primary h-5 w-5\" type=\"checkbox\"/>\n</div>\n<div class=\"flex items-center justify-between\">\n<span class=\"text-body-sm\">邮件报告</span>\n<input checked=\"\" class=\"rounded text-primary focus:ring-primary h-5 w-5\" type=\"checkbox\"/>\n</div>\n<div class=\"flex items-center justify-between\">\n<span class=\"text-body-sm\">新报价提醒</span>\n<input class=\"rounded text-primary focus:ring-primary h-5 w-5\" type=\"checkbox\"/>\n</div>\n</div>\n</div>\n<div class=\"space-y-4\">\n<h4 class=\"font-label-md text-on-surface font-bold\">外观</h4>\n<div class=\"space-y-3\">\n<div class=\"space-y-2\">\n<label class=\"block text-[12px] text-on-surface-variant\">语言</label>\n<select class=\"w-full p-2.5 rounded-lg border border-outline-variant text-body-sm outline-none\">\n<option>简体中文</option>\n<option>英语（美国）</option>\n<option>德语</option>\n</select>\n</div>\n<div class=\"space-y-2\">\n<label class=\"block text-[12px] text-on-surface-variant\">主题模式</label>\n<div class=\"flex gap-2\">\n<button class=\"flex-1 py-2 rounded-lg border border-primary bg-primary-container text-white font-bold text-[12px]\">浅色</button>\n<button class=\"flex-1 py-2 rounded-lg border border-outline-variant text-on-surface-variant font-bold text-[12px] hover:bg-surface\">深色</button>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"px-8 pb-8 flex justify-end\">\n<button class=\"px-8 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-colors shadow-sm\">保存偏好设置</button>\n</div>\n</section>\n</div>\n</div><div class=\"h-16\"></div>"
