  "mainHtml": "<section class=\"p-8 space-y-8\">\n<div class=\"flex items-start justify-between gap-6\">\n<div>\n<h2 class=\"text-headline-lg font-headline-lg mb-2\">模型中心</h2>\n<p class=\"text-body-lg font-body-lg text-on-surface-variant\">管理我的模型库、企业共享模型和模型社区资源，支持上传、收藏、下载、报价复用与公开分享。</p>\n</div>\n<button class=\"inline-flex items-center gap-2 rounded-lg border border-outline-variant bg-white px-4 py-3 text-label-md font-label-md hover:bg-surface-container-low\"><span class=\"material-symbols-outlined\">tune</span>筛选</button>\n</div>\n<div class=\"grid grid-cols-12 gap-6\">\n<article class=\"col-span-12 md:col-span-3 bg-white rounded-xl border border-outline-variant p-5 card-shadow\"><p class=\"text-label-sm text-outline mb-2\">我的模型</p><div class=\"flex items-end justify-between\"><strong class=\"text-3xl\">128</strong><span class=\"text-primary text-label-sm\">+12 本月</span></div></article>\n<article class=\"col-span-12 md:col-span-3 bg-white rounded-xl border border-outline-variant p-5 card-shadow\"><p class=\"text-label-sm text-outline mb-2\">企业共享</p><div class=\"flex items-end justify-between\"><strong class=\"text-3xl\">36</strong><span class=\"text-secondary text-label-sm\">8 个项目组</span></div></article>\n<article class=\"col-span-12 md:col-span-3 bg-white rounded-xl border border-outline-variant p-5 card-shadow\"><p class=\"text-label-sm text-outline mb-2\">社区收藏</p><div class=\"flex items-end justify-between\"><strong class=\"text-3xl\">54</strong><span class=\"text-primary text-label-sm\">可下载 29</span></div></article>\n<article class=\"col-span-12 md:col-span-3 bg-white rounded-xl border border-outline-variant p-5 card-shadow\"><p class=\"text-label-sm text-outline mb-2\">空间用量</p><div class=\"flex items-end justify-between\"><strong class=\"text-3xl\">68%</strong><span class=\"text-secondary text-label-sm\">13.6 / 20GB</span></div></article>\n</div>\n<div class=\"grid grid-cols-12 gap-6\">\n<section class=\"col-span-12 xl:col-span-8 bg-white rounded-xl border border-outline-variant card-shadow overflow-hidden\">\n<div class=\"p-6 border-b border-outline-variant flex items-center justify-between gap-4\">\n<div><h3 class=\"text-headline-sm font-headline-sm\">我的模型库</h3><p class=\"text-body-sm text-on-surface-variant mt-1\">按私有、企业共享、公开模型进行版本管理和报价复用。</p></div>\n<div class=\"inline-flex rounded-lg bg-surface-container-low p-1\">\n<button class=\"px-4 py-2 rounded-md bg-primary text-white text-label-md font-label-md\">全部</button>\n<button class=\"px-4 py-2 rounded-md text-on-surface-variant text-label-md font-label-md\">私有</button>\n<button class=\"px-4 py-2 rounded-md text-on-surface-variant text-label-md font-label-md\">共享</button>\n<button class=\"px-4 py-2 rounded-md text-on-surface-variant text-label-md font-label-md\">公开</button>\n</div>\n</div>\n<div class=\"overflow-x-auto\">\n<table class=\"w-full text-left\">\n<thead class=\"bg-surface-container text-label-sm text-on-surface-variant\"><tr><th class=\"px-6 py-3\">模型名称</th><th class=\"px-6 py-3\">格式</th><th class=\"px-6 py-3\">权限</th><th class=\"px-6 py-3\">版本</th><th class=\"px-6 py-3\">操作</th></tr></thead>\n<tbody class=\"divide-y divide-outline-variant text-body-sm\">\n<tr><td class=\"px-6 py-4 font-semibold\">轴承座-CNC-铝合金</td><td class=\"px-6 py-4\">STEP</td><td class=\"px-6 py-4\"><span class=\"rounded-full bg-secondary-container px-2 py-1 text-label-sm\">企业共享</span></td><td class=\"px-6 py-4\">v3.2</td><td class=\"px-6 py-4\"><button class=\"text-primary font-label-md\">去报价</button></td></tr>\n<tr><td class=\"px-6 py-4 font-semibold\">航空支架轻量化方案</td><td class=\"px-6 py-4\">IGES</td><td class=\"px-6 py-4\"><span class=\"rounded-full bg-surface-container px-2 py-1 text-label-sm\">私有</span></td><td class=\"px-6 py-4\">v1.8</td><td class=\"px-6 py-4\"><button class=\"text-primary font-label-md\">管理</button></td></tr>\n<tr><td class=\"px-6 py-4 font-semibold\">机器人末端夹具</td><td class=\"px-6 py-4\">STL</td><td class=\"px-6 py-4\"><span class=\"rounded-full bg-primary/10 px-2 py-1 text-primary text-label-sm\">公开</span></td><td class=\"px-6 py-4\">v2.0</td><td class=\"px-6 py-4\"><button class=\"text-primary font-label-md\">查看</button></td></tr>\n</tbody>\n</table>\n</div>\n</section>\n<aside class=\"col-span-12 xl:col-span-4 space-y-6\">\n<section class=\"bg-white rounded-xl border border-outline-variant p-6 card-shadow\">\n<h3 class=\"text-headline-sm font-headline-sm mb-4\">快速操作</h3>\n<div class=\"grid grid-cols-2 gap-3\">\n<button class=\"rounded-lg border border-outline-variant p-4 text-left hover:bg-surface-container-low\"><span class=\"material-symbols-outlined text-primary mb-3\">upload_file</span><p class=\"font-label-md\">上传模型</p></button>\n<button class=\"rounded-lg border border-outline-variant p-4 text-left hover:bg-surface-container-low\"><span class=\"material-symbols-outlined text-primary mb-3\">share</span><p class=\"font-label-md\">分享模型</p></button>\n<button class=\"rounded-lg border border-outline-variant p-4 text-left hover:bg-surface-container-low\"><span class=\"material-symbols-outlined text-primary mb-3\">favorite</span><p class=\"font-label-md\">收藏夹</p></button>\n<button class=\"rounded-lg border border-outline-variant p-4 text-left hover:bg-surface-container-low\"><span class=\"material-symbols-outlined text-primary mb-3\">history</span><p class=\"font-label-md\">版本记录</p></button>\n</div>\n</section>\n<section class=\"bg-white rounded-xl border border-outline-variant p-6 card-shadow\">\n<h3 class=\"text-headline-sm font-headline-sm mb-4\">热门模型排行</h3>\n<ol class=\"space-y-4 text-body-sm\">\n<li class=\"flex items-center justify-between\"><span>教学夹具模板</span><strong class=\"text-primary\">1,284</strong></li>\n<li class=\"flex items-center justify-between\"><span>通用齿轮箱壳体</span><strong class=\"text-primary\">976</strong></li>\n<li class=\"flex items-center justify-between\"><span>快拆支架组件</span><strong class=\"text-primary\">842</strong></li>\n</ol>\n</section>\n</aside>\n</div>\n<section class=\"bg-white rounded-xl border border-outline-variant p-6 card-shadow\">\n<div class=\"flex items-center justify-between mb-5\"><h3 class=\"text-headline-sm font-headline-sm\">模型社区</h3><a class=\"text-primary font-label-md\" href=\"#\">查看全部</a></div>\n<div class=\"grid grid-cols-12 gap-4\">\n<article class=\"col-span-12 md:col-span-4 rounded-xl border border-outline-variant overflow-hidden\"><div class=\"h-32 bg-surface-container flex items-center justify-center\"><span class=\"material-symbols-outlined text-5xl text-primary\">view_in_ar</span></div><div class=\"p-4\"><div class=\"flex items-center justify-between\"><h4 class=\"font-semibold\">推荐模型</h4><span class=\"text-label-sm text-primary\">精选</span></div><p class=\"text-body-sm text-on-surface-variant mt-2\">适合 CNC 快速报价的标准治具、支架、外壳模板。</p></div></article>\n<article class=\"col-span-12 md:col-span-4 rounded-xl border border-outline-variant overflow-hidden\"><div class=\"h-32 bg-surface-container flex items-center justify-center\"><span class=\"material-symbols-outlined text-5xl text-primary\">local_fire_department</span></div><div class=\"p-4\"><div class=\"flex items-center justify-between\"><h4 class=\"font-semibold\">今日热门</h4><span class=\"text-label-sm text-primary\">热度 +18%</span></div><p class=\"text-body-sm text-on-surface-variant mt-2\">社区下载、收藏和报价复用增长最快的公开模型。</p></div></article>\n<article class=\"col-span-12 md:col-span-4 rounded-xl border border-outline-variant overflow-hidden\"><div class=\"h-32 bg-surface-container flex items-center justify-center\"><span class=\"material-symbols-outlined text-5xl text-primary\">school</span></div><div class=\"p-4\"><div class=\"flex items-center justify-between\"><h4 class=\"font-semibold\">教学模型</h4><span class=\"text-label-sm text-primary\">入门</span></div><p class=\"text-body-sm text-on-surface-variant mt-2\">用于学习模型精度、面数、格式转换和报价参数配置。</p></div></article>\n</div>\n</section>\n</section>"
}
