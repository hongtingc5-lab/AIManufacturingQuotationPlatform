ncy improved by 12% compared to v3.</p>\n<div class=\"mt-md pt-md border-t border-outline-variant flex gap-md\">\n<button class=\"flex-1 py-2 bg-primary-container text-on-primary-container rounded-lg font-label-md text-label-md font-bold hover:opacity-90\">查看报告</button>\n<button class=\"flex-1 py-2 border border-outline text-on-surface-variant rounded-lg font-label-md text-label-md hover:bg-surface-container-low\">确认方案</button>\n</div>\n</div>\n</div>\n<!-- Order Message -->\n<div class=\"flex flex-col items-start max-w-2xl\">\n<div class=\"bg-white border border-outline-variant rounded-xl p-md shadow-sm\">\n<div class=\"flex items-center gap-sm mb-2\">\n<span class=\"material-symbols-outlined text-tertiary-container text-[18px]\">shopping_cart</span>\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">订单中心</span>\n<span class=\"text-[11px] text-outline ml-auto\">11:15 AM</span>\n</div>\n<div class=\"flex gap-md bg-surface-container-low p-sm rounded-lg border border-outline-variant/30 mb-sm\">\n<div class=\"w-12 h-12 bg-surface-container-high rounded flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">precision_manufacturing</span>\n</div>\n<div>\n<p class=\"font-label-md text-label-md font-bold text-on-surface\">#QT-20240525-001</p>\n<p class=\"text-[12px] text-on-surface-variant\">状态更新：已通过</p>\n</div>\n</div>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant\">订单 #QT-20240525-001 已由采购经理批准，制造排程将很快开始。</p>\n</div>\n</div>\n<!-- System Notification -->\n<div class=\"flex flex-col items-start max-w-2xl\">\n<div class=\"bg-white border border-outline-variant rounded-xl p-md shadow-sm\">\n<div class=\"flex items-center gap-sm mb-2\">\n<span class=\"material-symbols-outlined text-error text-[18px]\">error</span>\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">系统管理员</span>\n<span class=\"text-[11px] text-outline ml-auto\">昨天</span>\n</div>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant font-bold mb-1\">即将到来的维护提醒</p>\n<p class=\"font-body-lg text-body-lg text-on-surface-variant\">系统维护计划于 5 月 26 日 02:00 至 04:00 UTC 进行，期间可能出现间歇性连接中断。</p>\n</div>\n</div>\n<!-- Decorative Background Element -->\n<div class=\"absolute bottom-10 right-10 opacity-5 pointer-events-none\">\n<span class=\"material-symbols-outlined text-[300px]\">manufacturing</span>\n</div>\n</div>\n</section><section class=\"w-[320px] bg-surface-container-low border-l border-outline-variant flex flex-col\">\n<header class=\"p-md border-b border-outline-variant bg-surface-container-lowest\">\n<div class=\"relative\">\n<input class=\"w-full bg-surface-container-low border-outline-variant rounded-lg pl-10 text-label-md py-2 focus:ring-primary focus:border-primary\" placeholder=\"Search categories...\" type=\"text\"/>\n<span class=\"material-symbols-outlined absolute left-3 top-2.5 text-on-surface-variant text-[20px]\">search</span>\n</div>\n</header>\n<div class=\"flex-1 overflow-y-auto\">\n<!-- System Notifications -->\n<div class=\"p-md flex items-start gap-md hover:bg-surface-container transition-colors cursor-pointer border-b border-outline-variant/30\">\n<div class=\"p-2 bg-error-container rounded-lg\">\n<span class=\"material-symbols-outlined text-on-error-container\">campaign</span>\n</div>\n<div class=\"flex-1 overflow-hidden\">\n<div class=\"flex justify-between items-center mb-0.5\">\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">系统通知</span>\n<span class=\"text-[10px] text-outline\">昨天</span>\n</div>\n<p class=\"text-[12px] text-on-surface-variant truncate\">5月26日计划维护...</p>\n</div>\n</div>\n<!-- AI Reminders (ACTIVE) -->\n<div class=\"p-md flex items-start gap-md active-category transition-colors cursor-pointer border-b border-outline-variant/30 shadow-inner\">\n<div class=\"p-2 bg-primary-container rounded-lg\">\n<span class=\"material-symbols-outlined text-white\">auto_awesome</span>\n</div>\n<div class=\"flex-1 overflow-hidden\">\n<div class=\"flex justify-between items-center mb-0.5\">\n<span class=\"font-label-md text-label-md font-bold text-primary\">AI提醒</span>\n<span class=\"text-[10px] text-primary\">09:42 AM</span>\n</div>\n<p class=\"text-[12px] text-on-surface-variant truncate font-semibold\">模型 housing_v4 分析完成...</p>\n</div>\n</div>\n<!-- Order Messages -->\n<div class=\"p-md flex items-start gap-md hover:bg-surface-container transition-colors cursor-pointer border-b border-outline-variant/30\">\n<div class=\"p-2 bg-secondary-fixed rounded-lg\">\n<span class=\"material-symbols-outlined text-on-secondary-fixed\">inventory_2</span>\n</div>\n<div class=\"flex-1 overflow-hidden\">\n<div class=\"flex justify-between items-center mb-0.5\">\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">订单消息</span>\n<span class=\"text-[10px] text-outline\">11:15 AM</span>\n</div>\n<p class=\"text-[12px] text-on-surface-variant truncate\">订单 #QT-20240525-001 已...</p>\n</div>\n</div>\n<!-- Review Messages -->\n<div class=\"p-md flex items-start gap-md hover:bg-surface-container transition-colors cursor-pointer border-b border-outline-variant/30\">\n<div class=\"p-2 bg-tertiary-fixed rounded-lg\">\n<span class=\"material-symbols-outlined text-on-tertiary-fixed\">fact_check</span>\n</div>\n<div class=\"flex-1 overflow-hidden\">\n<div class=\"flex justify-between items-center mb-0.5\">\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">审核消息</span>\n<span class=\"text-[10px] text-outline\">周二</span>\n</div>\n<p class=\"text-[12px] text-on-surface-variant truncate\">零件 Z 需要进行设计校验...</p>\n</div>\n<div class=\"mt-1 w-2 h-2 bg-primary rounded-full\"></div>\n</div>\n<!-- Customer Service -->\n<div class=\"p-md flex items-start gap-md hover:bg-surface-container transition-colors cursor-pointer\">\n<div class=\"p-2 bg-surface-container-highest rounded-lg\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">support_agent</span>\n</div>\n<div class=\"flex-1 overflow-hidden\">\n<div class=\"flex justify-between items-center mb-0.5\">\n<span class=\"font-label-md text-label-md font-bold text-on-surface\">客服消息</span>\n<span class=\"text-[10px] text-outline\">周一</span>\n</div>\n<p class=\"text-[12px] text-on-surface-variant truncate\">我可以如何帮助您处理...</p>\n</div>\n</div>\n</div>\n<!-- Footer for Category Stats -->\n<footer class=\"p-md border-t border-outline-variant text-center\">\n<p class=\"font-label-sm text-label-sm text-outline\">您有 1 条未读重要消息</p>\n</footer>\n</section>"
