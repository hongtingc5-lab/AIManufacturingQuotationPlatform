label>\n<label class=\"block\">\n<span class=\"mb-2 block text-[12px] font-medium text-on-surface-variant\">备注</span>\n<textarea class=\"min-h-[88px] w-full rounded-xl border border-outline-variant bg-surface-container-low px-3 py-2 text-body-sm focus:border-primary focus:ring-primary\" id=\"orderRemarksInput\" placeholder=\"补充交付、检验或装配说明\">优先保证刚度与装配孔精度</textarea>\n</label>\n</div>\n</div>\n</div>\n<div class=\"p-4 border-t border-outline-variant bg-surface-container-lowest space-y-2\">\n<button class=\"w-full rounded-xl bg-primary px-4 py-3 text-body-sm font-bold text-on-primary hover:opacity-90 transition-opacity\" type=\"button\">快速下单</button>\n<button class=\"w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 text-body-sm font-bold text-on-surface hover:bg-surface-container transition-colors\" type=\"button\">提交订单</button>\n<button class=\"w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 text-body-sm font-bold text-on-surface hover:bg-surface-container transition-colors\" data-service-followup=\"\" type=\"button\">客服跟进</button>\n<button class=\"w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3 text-body-sm font-bold text-primary hover:bg-primary/10 transition-colors\" data-human-support=\"\" type=\"button\">转人工复核</button>\n</div>\n</aside>"
