{"title": "资源中心 | 敏捷智造", "hasInlineStyle": false, "inlineStyle": "", "body": "<header class=\"site-header\">\n  <div class=\"topbar\">\n    <a class=\"brand\" href=\"/\" aria-label=\"敏捷智造首页\"><svg class=\"brand-symbol\" viewbox=\"0 0 56 58\" aria-hidden=\"true\" focusable=\"false\"><path class=\"brand-symbol-secondary\" d=\"M28 3 4 17l9.8 5.7L28 14.5l14.2 8.2L52 17 28 3Z\"></path><path class=\"brand-symbol-primary\" d=\"M2 20.8 28 36l26-15.2v29.4l-9.8 5.7V37.7L28 47 11.8 37.7v18.2L2 50.2V20.8Z\"></path><path class=\"brand-symbol-secondary\" d=\"M17 42.7 28 49l11-6.3v8.8L28 58l-11-6.5v-8.8Z\"></path></svg><span class=\"brand-wordmark\"><strong>敏捷智造</strong><span>AGILE MANUFACTURING</span></span></a>\n    <nav class=\"nav\" aria-label=\"主导航\">\n      <div class=\"nav-capability\"><a class=\"nav-item nav-item--capability\" href=\"#\">能力中心</a><div class=\"capability-menu\"><div class=\"capability-cats\"><a class=\"capability-cat is-active\" href=\"/capabilities\" data-menu-category=\"process\"><span class=\"capability-cat-copy\"><strong>工艺</strong><span>加工、成型与增材制造能力</span></span><img src=\"/precision/service-cnc.jpg\" alt=\"工艺\"></a><a class=\"capability-cat\" href=\"/capabilities/service\" data-menu-category=\"service\"><span class=\"capability-cat-copy\"><strong>服务</strong><span>从单项加工到一站式交付</span></span><img src=\"/precision/manufacturing-service.png\" alt=\"服务\"></a><a class=\"capability-cat\" href=\"/capabilities/material\" data-menu-category=\"material\"><span class=\"capability-cat-copy\"><strong>材料</strong><span>金属、塑料与复合材料选择</span></span><img src=\"/precision/product-flange.jpg\" alt=\"材料\"></a><a class=\"capability-cat\" href=\"/capabilities/finish\" data-menu-category=\"finish\"><span class=\"capability-cat-copy\"><strong>表面处理</strong><span>外观、耐腐蚀与功能增强</span></span><img src=\"/precision/product-shaft.jpg\" alt=\"表面处理\"></a></div><div class=\"capability-main\"><div class=\"capability-panel is-active\" data-menu-panel=\"process\"><ul class=\"mega-grid mega-grid--